---
import BaseLayout from './BaseLayout.astro';
import BackToWorks from '../components/BackToWorks.astro';
import { extraLinks, type UrlEntry } from '../utils/links';

// The "urls"/"features" listed formats (same as the timeline's info-tab buttons):
// each entry renders as a labelled link in the post header. A button shows its
// `title`; with none it falls back to the URL's host label (see ../utils/links).
// `features` ("featured in") entries follow the `urls` ones.
interface Props {
  title: string;
  date: Date;
  description: string;
  readingTime: string;
  urls?: UrlEntry[];
  features?: UrlEntry[];
}

const { title, date, description, readingTime, urls = [], features = [] } = Astro.props;
const links = [...extraLinks(urls), ...extraLinks(features)];
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <BackToWorks />
  <article class="prose">
    <header>
      <h1>{title}</h1>
      <span class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time> – {readingTime}
      </span>
      {links.length > 0 && (
        <div class="post-links">
          {links.map(l => (
            <a href={l.url} target="_blank" rel="noopener noreferrer">{l.label}</a>
          ))}
        </div>
      )}
    </header>
    <hr />
    <slot />
  </article>
</BaseLayout>

<style>
  .post-meta {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  /* Mirrors the timeline info-tab's `.d-links` button row. */
  .post-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .post-links a {
    font-size: 0.82rem;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    color: var(--accent);
  }

  .post-links a:hover {
    border-color: var(--accent);
  }
</style>
