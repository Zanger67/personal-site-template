---
import BaseLayout from './BaseLayout.astro';

// The "urls" listed format (same as the timeline's info-tab buttons): each entry
// renders as a labelled link in the post header. A button shows its `title`;
// with none it falls back to the URL's host label (e.g. "github.com" → "github").
interface UrlEntry { title?: string | null; url?: string | null; }
interface Props {
  title: string;
  date: Date;
  description: string;
  readingTime: string;
  urls?: UrlEntry[];
}

function hostLabel(raw: string): string {
  try {
    const host = new URL(/^[a-z][a-z0-9+.-]*:\/\//i.test(raw) ? raw : `https://${raw}`)
      .hostname.replace(/^www\./, '');
    const parts = host.split('.').filter(Boolean);
    return parts.length >= 2 ? parts[parts.length - 2] : (parts[0] || raw);
  } catch {
    return raw;
  }
}

const { title, date, description, readingTime, urls = [] } = Astro.props;
const links = (urls ?? [])
  .filter((u): u is { title?: string | null; url: string } => !!u && !!u.url)
  .map(u => ({ label: (u.title && u.title.trim()) || hostLabel(u.url!), url: u.url! }));
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="prose">
    <header>
      <h1>{title}</h1>
      <span class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time> – {readingTime}
      </span>
      {links.length > 0 && (
        <div class="post-links">
          {links.map(l => (
            <a href={l.url} target="_blank" rel="noopener noreferrer">{l.label}</a>
          ))}
        </div>
      )}
    </header>
    <hr />
    <slot />
  </article>
</BaseLayout>

<style>
  .post-meta {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  /* Mirrors the timeline info-tab's `.d-links` button row. */
  .post-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .post-links a {
    font-size: 0.82rem;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    color: var(--accent);
  }

  .post-links a:hover {
    border-color: var(--accent);
  }
</style>
