---
import BaseLayout from './BaseLayout.astro';
import BackToWorks from '../components/BackToWorks.astro';
import Metrics from '../components/Metrics.astro';
import RelatedItems from '../components/RelatedItems.astro';
import Contributors from '../components/Contributors.astro';
import { hostLabel, type UrlEntry } from '../utils/links';
import type { Metrics as MetricsDict } from '../utils/metrics';
import type { RelatedItem } from '../utils/works';
import type { Contributions } from '../utils/marks';

// The "urls"/"features" listed formats (same as the timeline's info-tab buttons):
// each entry renders as a labelled link in the project header. A button shows its
// `title`; with none it falls back to the URL's host label (see ../utils/links).
// The primary `url` (label "Live") and `repo` (label "Repo") lead the row, then
// the `urls` list, then the `features` ("featured in") list.
interface Props {
  title: string;
  description: string;
  role?: string | null;
  affiliations?: string[];
  collaborators?: string[];
  // Contributor-level marks for the names above (see src/utils/marks.ts).
  contributions?: Contributions | null;
  startDate: Date;
  endDate?: Date | null;
  tags?: string[];
  url?: string | null;
  repo?: string | null;
  template?: string | null;
  sample?: string | null;
  urls?: UrlEntry[];
  features?: UrlEntry[];
  metrics?: MetricsDict | null;
  // "Related" list shown at the bottom — works sharing a relation-group or
  // affiliation (see getRelatedWorks). `relatedLabel` carries the "(…)" suffix.
  related?: RelatedItem[];
  relatedLabel?: string;
}

const { title, description, role, affiliations = [], collaborators = [], contributions = null, startDate, endDate, tags = [], url, repo, template, sample, urls = [], features = [], metrics = null, related = [], relatedLabel = 'Related' } = Astro.props;

const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
const dateRange = endDate ? `${fmt(startDate)} – ${fmt(endDate)}` : `${fmt(startDate)} – Present`;

const links = [
  url ? { label: 'Live', url } : null,
  repo ? { label: 'Repo', url: repo } : null,
  template ? { label: 'Template', url: template } : null,
  sample ? { label: 'Sample', url: sample } : null,
  ...(urls ?? []),
  ...(features ?? []),
]
  .filter((u): u is { label?: string; title?: string | null; url: string } => !!u && !!u.url)
  .map(u => ({ label: ('label' in u && u.label) || (u.title && u.title.trim()) || hostLabel(u.url), url: u.url }));
---

<BaseLayout title={title} description={description}>
  <BackToWorks />
  <article class="prose">
    <header>
      <h1>{title}</h1>
      {role && <p class="post-role">{role}</p>}
      {affiliations.length > 0 && (
        <div class="post-affils">
          {affiliations.map(a => <span class="affil-chip" title={`Affiliated with ${a}`}>{a}</span>)}
        </div>
      )}
      <Contributors label="Contributors" collaborators={collaborators} contributions={contributions} />
      <span class="post-meta">{dateRange}</span>
      {tags.length > 0 && (
        <div class="tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
      {links.length > 0 && (
        <div class="post-links">
          {links.map(l => (
            <a href={l.url} target="_blank" rel="noopener noreferrer">{l.label}</a>
          ))}
        </div>
      )}
      <Metrics metrics={metrics} />
    </header>
    <hr />
    <slot />
  </article>
  <RelatedItems label={relatedLabel} items={related} />
</BaseLayout>

<style>
  /* Role line under the title — mirrors WorkCard's italic subtitle. */
  .post-role {
    font-size: 0.95rem;
    font-style: italic;
    color: var(--accent);
    margin: 0.2rem 0 0.35rem;
  }

  .post-meta {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  /* Affiliation chips — mirror WorkCard's outlined "@ org" chips. */
  .post-affils {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0 0 0.6rem;
  }

  .affil-chip {
    font-size: 0.75rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  .affil-chip::before {
    content: '@';
    margin-right: 0.15rem;
    opacity: 0.6;
  }

  /* The contributor line's styles live with it, in <Contributors>. */

  /* Mirrors WorkCard's tag chips. */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.6rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  /* Mirrors the timeline info-tab's `.d-links` button row. */
  .post-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .post-links a {
    font-size: 0.82rem;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    color: var(--accent);
  }

  .post-links a:hover {
    border-color: var(--accent);
  }
</style>
