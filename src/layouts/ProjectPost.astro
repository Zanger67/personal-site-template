---
import BaseLayout from './BaseLayout.astro';
import BackToWorks from '../components/BackToWorks.astro';
import { hostLabel, type UrlEntry } from '../utils/links';

// The "urls"/"features" listed formats (same as the timeline's info-tab buttons):
// each entry renders as a labelled link in the project header. A button shows its
// `title`; with none it falls back to the URL's host label (see ../utils/links).
// The primary `url` (label "Live") and `repo` (label "Repo") lead the row, then
// the `urls` list, then the `features` ("featured in") list.
interface Props {
  title: string;
  description: string;
  startDate: Date;
  endDate?: Date;
  tags?: string[];
  url?: string;
  repo?: string;
  urls?: UrlEntry[];
  features?: UrlEntry[];
}

const { title, description, startDate, endDate, tags = [], url, repo, urls = [], features = [] } = Astro.props;

const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
const dateRange = endDate ? `${fmt(startDate)} – ${fmt(endDate)}` : `${fmt(startDate)} – Present`;

const links = [
  url ? { label: 'Live', url } : null,
  repo ? { label: 'Repo', url: repo } : null,
  ...(urls ?? []),
  ...(features ?? []),
]
  .filter((u): u is { label?: string; title?: string | null; url: string } => !!u && !!u.url)
  .map(u => ({ label: ('label' in u && u.label) || (u.title && u.title.trim()) || hostLabel(u.url), url: u.url }));
---

<BaseLayout title={title} description={description}>
  <BackToWorks />
  <article class="prose">
    <header>
      <h1>{title}</h1>
      <span class="post-meta">{dateRange}</span>
      {tags.length > 0 && (
        <div class="tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
      {links.length > 0 && (
        <div class="post-links">
          {links.map(l => (
            <a href={l.url} target="_blank" rel="noopener noreferrer">{l.label}</a>
          ))}
        </div>
      )}
    </header>
    <hr />
    <slot />
  </article>
</BaseLayout>

<style>
  .post-meta {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  /* Mirrors WorkCard's tag chips. */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.6rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  /* Mirrors the timeline info-tab's `.d-links` button row. */
  .post-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .post-links a {
    font-size: 0.82rem;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    color: var(--accent);
  }

  .post-links a:hover {
    border-color: var(--accent);
  }
</style>
