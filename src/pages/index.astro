---
import BaseLayout from '../layouts/BaseLayout.astro';
import NorthAmericaMap from '../components/NorthAmericaMap.astro';
import { showHomeSection, isRouteEnabled, friendsFirstNameOnly } from '@config/site';
import { getCollection, getEntry, render } from 'astro:content';
import { resolvePeople } from '../utils/collaborators';
import { withIncoming } from '../utils/incoming';
import profile from '../data/profile.json';
import affiliations from '../data/affiliations.json';
import publications from '../data/publications.json';
import education from '../data/education.json';
import languages from '../data/languages.json';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const profileShape = profile.profileShape as 'circle' | 'rectangle';

// Affiliations use the same org-array shape as organizations.json (see
// experience.astro). What appears in this homepage sidebar is an EXPLICIT
// curation, independent of the timeline's current/past: a role (or the blanket
// `membership`) opts in with `homepage: true`. Each org that contributes at
// least one homepage row is listed, with its opted-in role names (+ a "Member"
// row when the membership is featured). A homepage role may also carry
// `homepage_org_name` to override the group's title here (e.g. a short form)
// without affecting the org's full name used elsewhere.
// A future-dated role/membership (start month later than now) is tagged
// "(incoming)" here just as on the experience page, via the shared withIncoming
// helper — so a homepage-featured role that hasn't begun reads the same way.
interface AffilRole { role: string; roleDetail?: string; start?: string | null; homepage?: boolean; homepage_org_name?: string; }
interface AffilOrg {
  organization: string;
  url?: string | null;
  membership?: { start?: string | null; homepage?: boolean };
  roles?: AffilRole[];
}
const affilOrgs = affiliations as AffilOrg[];
const currentGroups = affilOrgs
  .map(o => {
    const homepageRoles = (o.roles ?? []).filter(r => r.homepage);
    const homepageOrgName = homepageRoles.find(r => r.homepage_org_name)?.homepage_org_name;
    return {
      entity: homepageOrgName ?? o.organization,
      url: o.url ?? null,
      roles: [
        ...homepageRoles.map(r => withIncoming(r.roleDetail ?? r.role, r.start)),
        ...(o.membership?.homepage ? [withIncoming('Member', o.membership.start)] : []),
      ],
    };
  })
  .filter(g => g.roles.length > 0);

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

type ProjectEntry = { data: { endDate?: Date; startDate: Date } };
function projectSort(a: ProjectEntry, b: ProjectEntry): number {
  if (!a.data.endDate && b.data.endDate) return -1;
  if (a.data.endDate && !b.data.endDate) return 1;
  const endDiff = (b.data.endDate?.valueOf() ?? 0) - (a.data.endDate?.valueOf() ?? 0);
  if (endDiff !== 0) return endDiff;
  return b.data.startDate.valueOf() - a.data.startDate.valueOf();
}
const allProjects = (await getCollection('projects')).sort(projectSort);
const projects = [
  ...allProjects.filter(p => p.data.pinned),
  ...allProjects.filter(p => !p.data.pinned),
].slice(0, 3);

const introEntry = await getEntry('sections', 'intro');
const { Content: Intro } = await render(introEntry);
---

<BaseLayout title={profile.homeTitle} rawTitle>
  <div class="home-layout">
    <aside class="sidebar">
      <img
        src={`${base}${profile.profileImage}`}
        alt="Profile photo"
        class:list={['profile-img', { 'profile-rect': profileShape === 'rectangle' }]}
        width="150"
        height="150"
      />

      {showHomeSection('education') && education.length > 0 && (
        <div class="sidebar-section">
          <h3>Education</h3>
          <div class="edu-list">
            {education.map(ed => (
              <div class="edu-item">
                <div class="edu-degree">{ed.degree}</div>
                <div class="edu-school">
                  {ed.url
                    ? <a href={ed.url} target="_blank" rel="noopener noreferrer">{ed.institutionShort ?? ed.institution}</a>
                    : ed.institutionShort ?? ed.institution}
                </div>
                {ed.honors && <div class="edu-honors">{ed.honors}</div>}
              </div>
            ))}
          </div>
        </div>
      )}

      {showHomeSection('affiliations') && currentGroups.length > 0 && (
        <div class="sidebar-section">
          <h3>Affiliations (current)</h3>
          <div class="aff-groups">
            {currentGroups.map(group => (
              <div class="aff-group">
                <div class="aff-entity">
                  {group.url
                    ? <a href={group.url} target="_blank" rel="noopener noreferrer">{group.entity}</a>
                    : group.entity}
                </div>
                {group.roles.map((role, i) => {
                  const isLast = i === group.roles.length - 1;
                  const glyph = isLast ? '└' : '├';
                  return (
                    <div class="aff-role-row">
                      <span class="bracket">{glyph}</span>
                      <span class="aff-role">{role}</span>
                    </div>
                  );
                })}
              </div>
            ))}
          </div>
          {isRouteEnabled('experience') && <a href={`${base}/experience`} class="view-all">All experience &rarr;</a>}
        </div>
      )}

      {showHomeSection('languages') && languages.length > 0 && (
        <div class="sidebar-section">
          <h3>Languages</h3>
          <div class="lang-list">
            {languages.map(lang => (
              <div class="lang-item">
                <span class="lang-name">{lang.language}</span>
                <span class="lang-fluency">{lang.fluency}</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </aside>

    <div class="main-col">
      <h1>{profile.greeting}</h1>
      <p class="subtitle">{profile.subtitle}</p>
      <div class="intro"><Intro /></div>

      {showHomeSection('places') && (
        <section>
          <div class="section-header">
            <h2>Places</h2>
            {isRouteEnabled('map') && <a href={`${base}/map`}>View full map &rarr;</a>}
          </div>
          <NorthAmericaMap />
        </section>
      )}

      {showHomeSection('projects') && isRouteEnabled('projects') && projects.length > 0 && (
        <section>
          <div class="section-header">
            <h2>Projects</h2>
            <a href={`${base}/works#projects`}>View all &rarr;</a>
          </div>
          <ul class="link-list">
            {projects.map(project => (
              <li>
                <a href={`${base}/projects/${project.id}`}>{project.data.title}</a>
                <span class="muted"> &mdash; {project.data.description}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      {showHomeSection('publications') && isRouteEnabled('publications') && publications.length > 0 && (
        <section>
          <div class="section-header">
            <h2>Publications</h2>
            <a href={`${base}/works#publications`}>View all &rarr;</a>
          </div>
          <ul class="link-list">
            {publications.slice(0, 3).map(pub => (
              <li>
                {pub.url
                  ? <a href={pub.url} target="_blank" rel="noopener noreferrer">{pub.title}</a>
                  : <span class="pub-title">{pub.title}</span>}
                <span class="muted"> &mdash; {pub.venue}, {pub.date}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      {showHomeSection('recentPosts') && isRouteEnabled('blog') && posts.length > 0 && (
        <section>
          <div class="section-header">
            <h2>Recent Posts</h2>
            <a href={`${base}/works#blog`}>View all &rarr;</a>
          </div>
          <ul class="link-list">
            {posts.map(post => (
              <li>
                <a href={`${base}/blog/${post.id}`}>{post.data.title}</a>
                <span class="muted"> &mdash; {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      {showHomeSection('friends') && (
        <section>
          <div class="section-header">
            <h2>Misc.</h2>
          </div>
          <div class="misc-row">
            <span class="misc-label">{profile.friendsLabel}:</span>
            <ul class="inline-list">
              {/* Friends are name references into the shared people registry
                  (src/data/collaborators.json) — same source projects/publications
                  resolve names from. A registered name with a `url` links out;
                  an unknown name (or one without a url) renders as plain text. */}
              {resolvePeople(profile.friends).map(friend => {
                const label = friendsFirstNameOnly() ? friend.name.split(' ')[0] : friend.name;
                return (
                  <li>
                    {friend.url
                      ? <a href={friend.url} target="_blank" rel="noopener noreferrer">{label}</a>
                      : <span>{label}</span>}
                  </li>
                );
              })}
            </ul>
          </div>
        </section>
      )}

      {profile.llmNote && (
        <p class="llm-note"><em>{profile.llmNote}</em></p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .home-layout {
    display: flex;
    gap: 2.5rem;
  }

  :global(main:has(.home-layout)) {
    max-width: 1012px;
  }

  .main-col {
    flex: 1;
    min-width: 0;
    order: 1;
  }

  .main-col h1 {
    font-size: 1.75rem;
    margin-bottom: 0.2rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin-bottom: 1rem;
  }

  .intro {
    margin-bottom: 2rem;
  }

  .llm-note {
    font-size: 0.7rem;
    color: var(--text-muted);
    opacity: 0.5;
    margin-top: 2rem;
  }

  /* Sidebar */

  .sidebar {
    width: 230px;
    flex-shrink: 0;
    padding-top: 0.25rem;
    order: 2;
  }

  .profile-img {
    border-radius: 50%;
    display: block;
    margin-bottom: 1.25rem;
    object-fit: cover;
  }

  .profile-img.profile-rect {
    border-radius: 8px;
    width: 100%;
    height: auto;
  }

  .sidebar-section {
    margin-bottom: 1.5rem;
  }

  .sidebar-section:last-child {
    margin-bottom: 0;
  }

  .sidebar-section h3 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .aff-groups {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .aff-entity {
    font-size: 0.82rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .aff-role-row {
    display: flex;
    align-items: baseline;
    padding: 0.05rem 0;
  }


  .bracket {
    font-family: monospace;
    color: var(--text-muted);
    width: 1rem;
    flex-shrink: 0;
    user-select: none;
    font-size: 0.8rem;
  }

  .aff-role {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .view-all {
    display: inline-block;
    font-size: 0.78rem;
    margin-top: 0.75rem;
  }

  .edu-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .edu-degree {
    font-size: 0.82rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .edu-school {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .edu-honors {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .lang-list {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .lang-item {
    display: flex;
    justify-content: space-between;
    font-size: 0.78rem;
  }

  .lang-name {
    font-weight: 500;
  }

  .lang-fluency {
    color: var(--text-muted);
  }

  /* Main column sections */

  section {
    margin-bottom: 2rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .section-header h2 {
    margin-bottom: 0;
  }

  .section-header a {
    font-size: 0.85rem;
  }

  .link-list {
    list-style: none;
    padding: 0;
  }

  .link-list li {
    padding: 0.4rem 0;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .pub-title {
    font-size: 0.95rem;
  }

  .muted {
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  .misc-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    font-size: 0.92rem;
  }

  .misc-label {
    color: var(--text-muted);
    font-weight: 500;
  }

  .inline-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0;
  }

  .inline-list li {
    display: inline;
  }

  .inline-list li:not(:last-child)::after {
    content: '·';
    color: var(--text-muted);
    margin: 0 0.4rem;
  }

  @media (max-width: 640px) {
    .home-layout {
      flex-direction: column;
      gap: 1.5rem;
    }

    .main-col {
      order: 2;
    }

    .sidebar {
      order: 1;
    }

    :global(main:has(.home-layout)) {
      max-width: var(--max-width);
    }

    /* Profile image + the three sidebar sections (education, affiliations,
       languages) flow into two height-balanced columns instead of one
       squished row, so the four items settle into roughly 2x2. column-fill
       defaults to balance, which splits by content height (first half /
       second half when heights are even); break-inside keeps each item
       whole within a column. */
    .sidebar {
      width: 100%;
      columns: 2;
      column-gap: 1rem;
    }

    .sidebar > * {
      break-inside: avoid;
      margin: 0 0 1.25rem;
    }

    .sidebar > *:last-child {
      margin-bottom: 0;
    }

    /* Image sits at 90% of the column width. aspect-ratio keeps the circle
       square; the rectangle keeps its natural portrait ratio. */
    .profile-img {
      width: 90%;
      height: auto;
      aspect-ratio: 1;
    }

    .profile-img.profile-rect {
      width: 90%;
      aspect-ratio: auto;
    }
  }
</style>
