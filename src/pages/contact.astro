---
import BaseLayout from '../layouts/BaseLayout.astro';
import contactsData from '../data/contacts.json';

interface SubLink {
  label?: string;
  url: string;
  display: string;
}

interface ContactItem {
  label: string;
  value?: string;
  url?: string;
  display?: string;
  subs?: SubLink[];
}

const contacts = contactsData as ContactItem[];
---

<BaseLayout title="Contact — Buzz" description="Get in touch with Buzz.">
  <h1>Contact</h1>
  <p>
    Want to book me for an event or just say hello? Reach out below.
  </p>

  <ul class="contact-list">
    {contacts.map(item => {
      const subs = item.subs ?? [];
      return (
        <li>
          <strong>{item.label}</strong>
          <div class="value-cell">
            {item.url
              ? <a href={item.url} target="_blank" rel="noopener noreferrer">{item.display}</a>
              : <span>{item.value}</span>}
            {subs.length > 0 && (
              <div class="sub-links">
                {subs.map((sub, i) => {
                  const glyph = i === subs.length - 1 ? '└' : '├';
                  return (
                    <div class="sub-row">
                      <span class="bracket">{glyph}</span>
                      <a href={sub.url} target="_blank" rel="noopener noreferrer">{sub.label ?? sub.display}</a>
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        </li>
      );
    })}
  </ul>
</BaseLayout>

<style>
  /* Single grid shared across all rows so the label column auto-sizes
     to the widest label and every value link lines up in one column. */
  .contact-list {
    list-style: none;
    padding: 0;
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: max-content 1fr;
  }

  .contact-list > li {
    display: contents;
  }

  .contact-list > li > strong {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .contact-list > li > .value-cell {
    padding: 0.75rem 0 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    min-width: 0;
  }

  .contact-list > li:last-child > strong,
  .contact-list > li:last-child > .value-cell {
    border-bottom: none;
  }

  .sub-links {
    margin-top: 0.35rem;
    display: flex;
    flex-direction: column;
  }

  .sub-row {
    display: flex;
    align-items: baseline;
    gap: 0;
    padding: 0.15rem 0;
  }

  /* Bracket left edge sits at the link column start, so └ lines up
     with the first character of the link on the row above. */
  .bracket {
    font-family: monospace;
    color: var(--text-muted);
    width: 1.2rem;
    flex-shrink: 0;
    user-select: none;
  }

</style>
