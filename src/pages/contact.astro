---
import BaseLayout from '../layouts/BaseLayout.astro';
import { isRouteEnabled } from '@config/site';
import contactsData from '../data/contacts.json';
import profile from '../data/profile.json';

if (!isRouteEnabled('contact')) return Astro.rewrite('/404');

interface SubLink {
  label?: string;
  url: string;
  display: string;
}

// Split-and-join + encoded email: each fragment is base64(rot12(piece)) of a
// piece of the address (u = local part, d = domain, t = TLD). The joined address
// never appears in the HTML source; it's decoded and assembled into a mailto: at runtime.
interface EmailParts {
  u: string;
  d: string;
  t: string;
}

interface ContactItem {
  label: string;
  value?: string;
  url?: string;
  display?: string;
  email?: EmailParts;
  subs?: SubLink[];
}

const contacts = contactsData as ContactItem[];

// Booking link surfaced inline in the intro as "Schedule a chat"; omitted when
// no such entry exists (keeps the layout byte-identical when a repo has none).
const scheduleCall = contacts.find(item => item.label === 'Book a Call' && item.url);
---

<BaseLayout title="Contact" description={profile.pageMeta.contact}>
  <h1>Contact</h1>
  <p>
    {profile.contactIntro}
  </p>
  {scheduleCall && (
    <p class="schedule-line">
      Schedule a <a href={scheduleCall.url} target="_blank" rel="noopener noreferrer">chat</a>.
    </p>
  )}

  <ul class="contact-list">
    {contacts.map(item => {
      const subs = item.subs ?? [];
      return (
        <li>
          <strong>{item.label}</strong>
          <div class="value-cell">
            {item.email
              ? <>
                  <a class="js-email" data-u={item.email.u} data-d={item.email.d} data-t={item.email.t} aria-label="Email address (revealed by JavaScript)">email me</a>
                  <noscript><span class="value-note"> — enable JavaScript to reveal</span></noscript>
                </>
              : item.url
              ? <a href={item.url} target="_blank" rel="noopener noreferrer">{item.display}</a>
              : <span>{item.value}</span>}
            {subs.length > 0 && (
              <div class="sub-links">
                {subs.map((sub, i) => {
                  const glyph = i === subs.length - 1 ? '└' : '├';
                  return (
                    <div class="sub-row">
                      <span class="bracket">{glyph}</span>
                      <a href={sub.url} target="_blank" rel="noopener noreferrer">{sub.label ?? sub.display}</a>
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        </li>
      );
    })}
  </ul>
</BaseLayout>

<script>
  // Reassemble the address at runtime from split, doubly-encoded fragments.
  // Mirrors the build-time encoder: each fragment is base64(rot12(piece)), so
  // decoding is atob() then a -12 Caesar shift. Nothing joinable is in the HTML.
  const rot = (s: string, n: number): string =>
    s.replace(/[a-zA-Z]/g, (c) => {
      const base = c <= 'Z' ? 65 : 97;
      return String.fromCharCode(((c.charCodeAt(0) - base + n) % 26 + 26) % 26 + base);
    });
  const dec = (s: string): string => rot(atob(s), -12);
  document.querySelectorAll<HTMLAnchorElement>('a.js-email').forEach((a) => {
    const { u, d, t } = a.dataset;
    if (!u || !d || !t) return;
    const [lu, ld, lt] = [dec(u), dec(d), dec(t)];
    a.href = `mailto:${lu}@${ld}.${lt}`;               // working link (real address)
    a.textContent = `${lu} [at] ${ld} [dot] ${lt}`;    // shown obfuscated to the reader
  });
</script>

<style>
  /* Single grid shared across all rows so the label column auto-sizes
     to the widest label and every value link lines up in one column. */
  .contact-list {
    list-style: none;
    padding: 0;
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: max-content 1fr;
  }

  .contact-list > li {
    display: contents;
  }

  .contact-list > li > strong {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .contact-list > li > .value-cell {
    padding: 0.75rem 0 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    min-width: 0;
  }

  .contact-list > li:last-child > strong,
  .contact-list > li:last-child > .value-cell {
    border-bottom: none;
  }

  .schedule-line {
    margin-top: 0.5rem;
  }

  .value-note {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .sub-links {
    margin-top: 0.35rem;
    display: flex;
    flex-direction: column;
  }

  .sub-row {
    display: flex;
    align-items: baseline;
    gap: 0;
    padding: 0.15rem 0;
  }

  /* Bracket left edge sits at the link column start, so └ lines up
     with the first character of the link on the row above. */
  .bracket {
    font-family: monospace;
    color: var(--text-muted);
    width: 1.2rem;
    flex-shrink: 0;
    user-select: none;
  }

</style>
