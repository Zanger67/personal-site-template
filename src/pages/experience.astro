  .tl-bar.dim {
    background: var(--bg);
    border-color: color-mix(in srgb, var(--border) 45%, var(--bg));
    border-left-color: color-mix(in srgb, var(--border) 60%, var(--bg)) !important;
    color: color-mix(in srgb, var(--text-muted) 45%, var(--bg));
