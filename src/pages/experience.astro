---
import BaseLayout from '../layouts/BaseLayout.astro';
import affiliations from '../data/affiliations.json';
import leadership from '../data/leadership.json';
import awards from '../data/awards.json';
import involvements from '../data/involvements.json';

interface Affiliation {
  entity: string;
  role: string;
  startDate: string;
  endDate: string | null;
  url: string | null;
}

interface OrgGroup {
  entity: string;
  url: string | null;
  roles: { role: string; startDate: string; endDate: string | null }[];
}

function formatDate(dateStr: string | null): string {
  if (!dateStr) return 'Present';
  const [year, month] = dateStr.split('-');
  const date = new Date(parseInt(year), parseInt(month) - 1);
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function dateRange(start: string | null, end: string | null): string | null {
  if (!start && !end) return null;
  if (start && !end) return `${formatDate(start)} \u2013 Present`;
  if (!start && end) return `... \u2013 ${formatDate(end)}`;
  return `${formatDate(start)} \u2013 ${formatDate(end)}`;
}

function sortKey(item: { endDate: string | null; startDate: string }): number {
  return new Date(item.endDate ?? item.startDate).valueOf();
}

function groupByEntity(items: Affiliation[]): OrgGroup[] {
  const groups: OrgGroup[] = [];
  const seen = new Map<string, OrgGroup>();
  for (const item of items) {
    if (seen.has(item.entity)) {
      seen.get(item.entity)!.roles.push({ ...item, role: item.roleDetail || item.role });
    } else {
      const group: OrgGroup = {
        entity: item.entity,
        url: item.url,
        roles: [{ role: item.roleDetail || item.role, startDate: item.startDate, endDate: item.endDate }],
      };
      groups.push(group);
      seen.set(item.entity, group);
    }
  }
  for (const group of groups) {
    group.roles.sort((a, b) => sortKey(b) - sortKey(a));
  }
  return groups;
}

const currentGroups = groupByEntity(affiliations.current);
const pastGroups = groupByEntity(affiliations.past);

interface LeaderGroup {
  org: string;
  roles: typeof leadership;
}

function groupLeadership(items: typeof leadership): LeaderGroup[] {
  const groups: LeaderGroup[] = [];
  const seen = new Map<string, typeof leadership>();
  for (const item of items) {
    if (seen.has(item.organization)) {
      seen.get(item.organization)!.push(item);
    } else {
      const roles = [item];
      groups.push({ org: item.organization, roles });
      seen.set(item.organization, roles);
    }
  }
  return groups;
}

const leaderGroups = groupLeadership(leadership);
---

<BaseLayout title="Experience — Buzz" description="Current and past affiliations.">
  <h1>Experience</h1>
  <p style="color: var(--text-muted); margin-bottom: 1.5rem;">
    Current and past affiliations.
  </p>

  <h2>Current</h2>
  <div class="groups">
    {currentGroups.map(group => (
      <div class="org-group">
        <div class="org-name">
          {group.url
            ? <a href={group.url} target="_blank" rel="noopener noreferrer">{group.entity}</a>
            : group.entity}
        </div>
        <div class="roles">
          {group.roles.map((r, i) => {
            const isLast = i === group.roles.length - 1;
            const glyph = isLast ? '└' : '├';
            return (
              <div class="role-row">
                <span class="bracket">{glyph}</span>
                <span class="role-name">{r.role}</span>
                <span class="role-dates">{dateRange(r.startDate, r.endDate)}</span>
              </div>
            );
          })}
        </div>
      </div>
    ))}
  </div>

  <h2>Past</h2>
  <div class="groups">
    {pastGroups.map(group => (
      <div class="org-group">
        <div class="org-name">
          {group.url
            ? <a href={group.url} target="_blank" rel="noopener noreferrer">{group.entity}</a>
            : group.entity}
        </div>
        <div class="roles">
          {group.roles.map((r, i) => {
            const isLast = i === group.roles.length - 1;
            const glyph = isLast ? '└' : '├';
            return (
              <div class="role-row">
                <span class="bracket">{glyph}</span>
                <span class="role-name">{r.role}</span>
                <span class="role-dates">{dateRange(r.startDate, r.endDate)}</span>
              </div>
            );
          })}
        </div>
      </div>
    ))}
  </div>

  {leaderGroups.length > 0 && (
    <>
      <h2>Leadership</h2>
      <div class="groups">
        {leaderGroups.map(group => (
          <div class="org-group">
            <div class="org-name">{group.org}</div>
            {group.roles.map((item, i) => {
              const isLast = i === group.roles.length - 1;
              const glyph = isLast ? '└' : '├';
              const dates = dateRange(item.start, item.end);
              return (
                <div class="role-row">
                  <span class="bracket">{glyph}</span>
                  <span class="role-name">{item.role}</span>
                  {dates && <span class="role-dates">{dates}</span>}
                </div>
              );
            })}
          </div>
        ))}
      </div>
    </>
  )}

  {awards.length > 0 && (
    <>
      <h2>Awards & Honors</h2>
      <ul class="involvement-list">
        {awards.map(award => (
          <li class="award-row">
            <span class="inv-name">{award.name}</span>
            <span class="role-dates">{formatDate(award.date)}</span>
          </li>
        ))}
      </ul>
    </>
  )}

  {involvements.length > 0 && (
    <>
      <h2>Involvements</h2>
      <ul class="involvement-list">
        {involvements.map(inv => (
          <li>
            <span class="inv-name">{inv.name}</span>
            {inv.role && <span class="inv-role"> &mdash; {inv.role}</span>}
          </li>
        ))}
      </ul>
    </>
  )}
</BaseLayout>

<style>
  h2 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .groups {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .org-group {
    border-bottom: 1px solid var(--border);
    padding-bottom: 1.25rem;
  }

  .org-group:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .org-name {
    font-weight: 500;
    margin-bottom: 0.3rem;
  }

  .role-row {
    display: flex;
    align-items: baseline;
    gap: 0;
    padding: 0.15rem 0;
  }

  .role-row.indented {
    padding-left: 1.2rem;
  }

  .bracket {
    font-family: monospace;
    color: var(--text-muted);
    width: 1.2rem;
    flex-shrink: 0;
    user-select: none;
  }

  .role-name {
    font-size: 0.92rem;
    color: var(--text-muted);
  }

  .role-dates {
    font-size: 0.82rem;
    color: var(--text-muted);
    white-space: nowrap;
    margin-left: auto;
    padding-left: 1rem;
  }

  .award-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .involvement-list {
    list-style: none;
    padding: 0;
  }

  .involvement-list li {
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.92rem;
  }

  .involvement-list li:last-child {
    border-bottom: none;
  }

  .inv-name {
    font-weight: 500;
  }

  .inv-role {
    color: var(--text-muted);
    font-size: 0.85rem;
  }
</style>
