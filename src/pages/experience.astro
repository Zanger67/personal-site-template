---
import BaseLayout from '../layouts/BaseLayout.astro';
import { isRouteEnabled } from '@config/site';
import { getCollection } from 'astro:content';
import affiliations from '../data/affiliations.json';
import education from '../data/education.json';
import publications from '../data/publications.json';
import organizations from '../data/organizations.json';
import awards from '../data/awards.json';
import conferences from '../data/conferences.json';
import misc from '../data/misc.json';
import profile from '../data/profile.json';

if (!isRouteEnabled('experience')) return Astro.rewrite('/404');

// ===========================================================================
// This page hosts two views of the same career data, swapped via a selector
// at the top. The "Timeline" view (default) is a Gantt-style chart; the
// "Experience" view is an organisation-grouped list. The selector toggles
// which <section class="view …"> is shown; only the active timeline view gets
// the wide layout (see the gated `main:has(.view-timeline.active)` rules).
// ===========================================================================

// ---------------------------------------------------------------------------
// EXPERIENCE (list) view — org-grouped tree of current/past/leadership roles
// plus awards, conferences and involvements.
// ---------------------------------------------------------------------------
function formatDate(dateStr: string | null): string {
  if (!dateStr) return 'Present';
  const [year, month] = dateStr.split('-');
  const date = new Date(parseInt(year), parseInt(month) - 1);
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function dateRange(start: string | null, end: string | null): string | null {
  if (!start && !end) return null;
  if (start && !end) return `${formatDate(start)} – Present`;
  if (!start && end) return `... – ${formatDate(end)}`;
  return `${formatDate(start)} – ${formatDate(end)}`;
}

// ---------------------------------------------------------------------------
// "urls" — the listed extra-links format. ANY timeline entry (role, project,
// publication, award, conference, …) may carry an optional
// `urls: { title?, url }[]`. Each entry becomes an extra info-tab button,
// appended AFTER the entry's main `url` (and a project's `repo`). `url` stays
// the single "main" link and `repo` the GitHub one; `urls` is purely the added
// list. A button shows its `title`; with none it falls back to the URL's host
// label (e.g. "https://www.github.com/foo/bar" → "github").
interface UrlEntry { title?: string | null; url?: string | null; }
// Strip protocol + leading "www.", then take the registrable name — the label
// before the public suffix: "github.com" → "github", "arxiv.org" → "arxiv".
// (A bare host with no dot, e.g. "localhost", is returned whole; an unparseable
// value falls back to itself so a label always renders.)
function hostLabel(raw: string): string {
  try {
    const host = new URL(/^[a-z][a-z0-9+.-]*:\/\//i.test(raw) ? raw : `https://${raw}`)
      .hostname.replace(/^www\./, '');
    const parts = host.split('.').filter(Boolean);
    return parts.length >= 2 ? parts[parts.length - 2] : (parts[0] || raw);
  } catch {
    return raw;
  }
}
// Turn a `urls` list into info-tab links: drop empties, label each by its
// `title` (trimmed) or the derived host label.
function extraLinks(urls?: UrlEntry[] | null): { label: string; url: string }[] {
  return (urls ?? [])
    .filter((u): u is { title?: string | null; url: string } => !!u && !!u.url)
    .map(u => ({ label: (u.title && u.title.trim()) || hostLabel(u.url!), url: u.url! }));
}

// ---------------------------------------------------------------------------
// ORGANISATIONS — the single source for clubs/societies (was leadership.json +
// involvements.json). Each org carries its specific `roles`, plus two optional
// org-level fallback windows: `membership` (the blanket "general member" span,
// carved around the specific roles on the timeline) and `alumnus` (a former-
// member span, shown only in the bottom "Alumni" strip, never as a bar).
//   `displayTimeline` is the org-level master toggle (omitted ⇒ on): when on,
// every role charts without per-role flags; when off, the org charts no bar and
// instead surfaces in the "Other involvements" strip below the chart — only a
// role that sets its own `displayTimeline: true` still charts. The list view
// ignores the flag — it's the full record. See organizations.json.
interface Span { start: string | null; end: string | null; description?: string | null; url?: string | null; urls?: UrlEntry[]; homepage?: boolean; }
interface OrgRole {
  role: string;
  // Optional longer label used by the list view only (the bar keeps `role`).
  roleDetail?: string;
  start: string | null;
  end: string | null;
  displayTimeline?: boolean;
  main?: boolean;
  description?: string | null;
  url?: string | null;
  // Extra info-tab buttons for this role, appended after its main `url`.
  urls?: UrlEntry[];
  location?: string | null;
  relationGroups?: string[];
  // Affiliations only: timeline categories (first = primary colour/lane, rest are
  // extra filters). Clubs ignore this — they are always the "clubs" category.
  categories?: string[];
  // Affiliations only: opt this role into the homepage "Affiliations" sidebar
  // (index.astro). Independent of the timeline's current/past split.
  homepage?: boolean;
}
interface Org {
  organization: string;
  organizationShort?: string;
  url?: string | null;
  // Org-level extra links: appended to EVERY one of this org's role/membership
  // bars (parallels how `url` is each bar's main-link fallback).
  urls?: UrlEntry[];
  location?: string | null;
  displayTimeline?: boolean;
  main?: boolean;
  relationGroups?: string[];
  membership?: Span;
  alumnus?: Span;
  roles?: OrgRole[];
  // Affiliations only: default categories for this org's roles (see OrgRole).
  categories?: string[];
}
const orgs = organizations as Org[];
// Work affiliations share organizations.json's shape (array of orgs, each with
// `roles`, optional `membership`/`alumnus` windows), differing only by carrying
// `categories` (clubs are always "clubs"). They reuse every org helper below.
const affilOrgs = affiliations as Org[];

// displayTimeline resolution: org default is on; a role inherits the org's flag
// unless it sets its own.
const orgShown = (org: Org): boolean => org.displayTimeline ?? true;
const roleShown = (org: Org, role: OrgRole): boolean => role.displayTimeline ?? orgShown(org);

// "Alumnus (2020)" label from a span's year (start preferred, else end).
function alumnusLabel(a: Span): string {
  const yr = (a.start ?? a.end ?? '').slice(0, 4);
  return yr ? `Alumnus (${yr})` : 'Alumnus';
}
// The flat detail line for an involvement: its role label(s), else the alum tag.
function involvementRoleLabel(org: Org): string | null {
  const names = (org.roles ?? []).map(r => r.role).filter(Boolean);
  if (names.length) return names.join(', ');
  if (org.alumnus) return alumnusLabel(org.alumnus);
  return null;
}

// List view split (auto-derived, displayTimeline-independent): an org with at
// least one DATED role reads as "Leadership"; everything else is a plain
// "Involvement". Membership/alumnus windows alone don't promote an org.
const hasDatedRole = (org: Org): boolean => (org.roles ?? []).some(r => !!r.start);

// ---------------------------------------------------------------------------
// LIST-VIEW INFO TAB dataset. The list view mirrors the timeline's click → info
// tab: every clickable row registers a self-contained detail record (the same
// fields the drawer renders — title, category, date, subtitle, description,
// links) and the rendered row carries its `id` in `data-li`. The client reads
// #tl-list-data, opens the identically-styled .tl-detail panel, and derives a
// "Related" list from rows sharing this row's `entity` or a `relationGroup`.
//   Links mirror the timeline: the main `url` first, then the listed `urls`
// extras (deduped by URL). Build order is irrelevant — a row references its own
// id — but each detail is registered as its row is built, so markup and dataset
// stay in lockstep.
interface ListDetail {
  id: number; title: string; type: CatKey; dateLabel: string | null;
  subtitle: string | null; description: string | null;
  links: { label: string; url: string }[]; entity: string;
  relationGroups: string[]; main: boolean;
}
const listItems: ListDetail[] = [];
const pushDetail = (d: Omit<ListDetail, 'id'>): number => { const id = listItems.length; listItems.push({ id, ...d }); return id; };
// Drop empty links, then de-dupe by URL (keep first) — same rule as mkItem.
const detailLinks = (ls: { label: string; url: string | null | undefined }[]): { label: string; url: string }[] =>
  ls.filter((l): l is { label: string; url: string } => !!l && !!l.url)
    .filter((l, i, arr) => arr.findIndex(x => x.url === l.url) === i);

// Rows for an org's tree: its specific roles, then the blanket `membership` shown
// at FULL (uncarved) span, then any `alumnus` tag — registering a detail per row.
// `club` is the only thing that differs between the two callers: it picks the
// category (clubs vs the affiliation's own `categories`).
interface ListRole { id: number; role: string; start: string | null; end: string | null; url: string | null; }
function buildRoleRows(org: Org, club: boolean): ListRole[] {
  const subtitleOf = (loc: string | null | undefined): string | null =>
    [org.organization, loc ?? org.location].filter(Boolean).join(' · ') || null;
  const catOf = (r?: OrgRole): CatKey => club ? 'clubs' : affilCats(org, r).type;
  const rows: ListRole[] = [];
  for (const r of org.roles ?? []) {
    const id = pushDetail({
      title: r.roleDetail ?? r.role, type: catOf(r), dateLabel: dateRange(r.start, r.end),
      subtitle: subtitleOf(r.location), description: r.description ?? null,
      links: detailLinks([{ label: 'Website', url: r.url ?? org.url }, ...extraLinks(r.urls), ...extraLinks(org.urls)]),
      entity: org.organization, relationGroups: r.relationGroups ?? org.relationGroups ?? [],
      main: r.main ?? org.main ?? false,
    });
    rows.push({ id, role: r.roleDetail ?? r.role, start: r.start, end: r.end, url: r.url ?? null });
  }
  if (org.membership) {
    const id = pushDetail({
      title: 'Member', type: catOf(), dateLabel: dateRange(org.membership.start, org.membership.end),
      subtitle: subtitleOf(null), description: org.membership.description ?? null,
      links: detailLinks([{ label: 'Website', url: org.membership.url ?? org.url }, ...extraLinks(org.membership.urls), ...extraLinks(org.urls)]),
      entity: org.organization, relationGroups: org.relationGroups ?? [], main: !!org.main,
    });
    rows.push({ id, role: 'Member', start: org.membership.start, end: org.membership.end, url: org.membership.url ?? null });
  }
  if (org.alumnus) {
    const id = pushDetail({
      title: alumnusLabel(org.alumnus), type: catOf(),
      dateLabel: dateRange(org.alumnus.start, org.alumnus.end) ?? alumnusLabel(org.alumnus),
      subtitle: subtitleOf(null), description: org.alumnus.description ?? null,
      links: detailLinks([{ label: 'Website', url: org.url }, ...extraLinks(org.urls)]),
      entity: org.organization, relationGroups: org.relationGroups ?? [], main: !!org.main,
    });
    rows.push({ id, role: alumnusLabel(org.alumnus), start: org.alumnus.start, end: org.alumnus.end, url: null });
  }
  return rows;
}

const leaderListGroups = orgs.filter(hasDatedRole).map(o => ({
  organization: o.organization,
  url: o.url ?? null,
  location: o.location ?? null,
  roles: buildRoleRows(o, true),
}));
const involvementListItems = orgs.filter(o => !hasDatedRole(o)).map(o => ({
  name: o.organization,
  url: o.url ?? null,
  role: involvementRoleLabel(o),
  liId: pushDetail({
    title: o.organization, type: 'clubs', dateLabel: orgInvolvementRange(o),
    subtitle: o.location ?? null, description: null,
    links: detailLinks([{ label: 'Website', url: o.url }, ...extraLinks(o.urls)]),
    entity: o.organization, relationGroups: o.relationGroups ?? [], main: !!o.main,
  }),
}));

// AFFILIATIONS (work) list view — same {organization, url, location, roles}
// shape as leaderListGroups, so they render through the identical markup. Split
// into Current / Past by whether the org is still active (an open-ended role or
// membership), mirroring how organisations derive "active" from dates rather
// than a hand-maintained current/past split. Roles are newest-first.
const roleRecency = (r: ListRole): number => new Date(r.end ?? r.start ?? '1970-01').valueOf();
const affilGroup = (o: Org) => ({
  organization: o.organization,
  url: o.url ?? null,
  location: o.location ?? null,
  roles: buildRoleRows(o, false).sort((a, b) => roleRecency(b) - roleRecency(a)),
});
const currentAffilGroups = affilOrgs.filter(o => orgActive(o)).map(affilGroup);
const pastAffilGroups = affilOrgs.filter(o => !orgActive(o)).map(affilGroup);

// Award & conference list rows, each registering an info-tab detail (point events,
// so the date is a single month; an entry with no date shows none).
const awardRows = (awards as any[]).map(a => ({
  ...a,
  liId: pushDetail({
    title: a.name, type: 'awards', dateLabel: a.date ? formatDate(a.date) : null,
    subtitle: null, description: a.description ?? null,
    links: detailLinks([{ label: 'View', url: a.url }, ...extraLinks(a.urls)]),
    entity: a.name, relationGroups: a.relationGroups ?? [], main: !!a.main,
  }),
}));
const conferenceRows = (conferences as any[]).map(c => ({
  ...c,
  liId: pushDetail({
    title: c.name, type: 'misc', dateLabel: c.date ? formatDate(c.date) : null,
    subtitle: c.location ?? null, description: c.description ?? null,
    links: detailLinks([{ label: 'View', url: c.url }, ...extraLinks(c.urls)]),
    entity: c.name, relationGroups: c.relationGroups ?? [], main: !!c.main,
  }),
}));

// ---------------------------------------------------------------------------
// TIMELINE view — ported from jackswitzer.com/projects "Timeline" view,
// adapted to our data and colour scheme. Years are rows (newest first);
// months are columns; each item is a lane-packed horizontal bar. Summer
// (May–Aug) columns are shaded. Clicking a bar selects its "group" (same
// category + same organisation), dims everything else, and opens a drawer.
// ---------------------------------------------------------------------------
type CatKey = 'education' | 'work' | 'research' | 'awards' | 'projects' | 'clubs' | 'misc';
const CATEGORIES: { key: CatKey; label: string; color: string }[] = [
  { key: 'education', label: 'Education', color: '#5b8def' },
  { key: 'work',      label: 'Work',      color: 'var(--accent)' },
  { key: 'research',  label: 'Research',  color: '#a06fd6' },
  { key: 'awards',    label: 'awards/pubs', color: '#d4a017' },
  { key: 'projects',  label: 'Projects',  color: '#e0883c' },
  { key: 'clubs',     label: 'Clubs',     color: '#e06c84' },
  { key: 'misc',      label: 'Misc.',     color: '#3aa6ad' },
];
const TYPE_ORDER: Record<CatKey, number> = { education: 0, work: 1, research: 2, awards: 3, projects: 4, clubs: 5, misc: 6 };
const MONTH_LABELS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const SUMMER_COLS = [4, 5, 6, 7]; // May–Aug

interface Item {
  id: number;
  title: string;
  type: CatKey;
  start: number;
  end: number | null;
  startMonthNum: number;        // absolute month index of the bar's start column
  endMonthNum: number | null;   // absolute month index one past the last filled column (null = Present)
  dateLabel: string;
  description: string | null;
  subtitle: string | null;   // org · location context line (clubs/work-style items)
  links: { label: string; url: string }[];
  // Grouping: items in the same group stay lit together when one is selected.
  entity: string;          // organisation / institution / (project = own title)
  entityShort: string;     // shortform org label for the compact bar; defaults to `entity`
  group: string;           // `${type}::${entity}`
  affiliations: string[];  // (projects) org/role names this project is tagged to
  // Relation-groups: free-form shared tags that link items across the whole
  // timeline. Selecting an item highlights every other item that shares any of
  // its relation-groups (independent of category/org). Many-to-many — give
  // items the same tag and they group; no per-pair linking required.
  relationGroups: string[];
  main: boolean;           // cross-cutting "main"/highlights flag (orthogonal to type)
  cats: CatKey[];          // every category this item matches (primary `type` first).
                           // Extras let one item appear under multiple filters (e.g. a
                           // lab role that is both Research and Work). Colour/lane still
                           // follow the primary `type`.
}

function parseDate(v: string | Date | null | undefined): Date | null {
  if (!v) return null;
  // Content-collection dates (z.coerce.date) arrive as UTC-midnight Date objects,
  // while JSON dates are strings parsed as LOCAL midnight below. Rebuild Date
  // inputs from their UTC parts so both paths land on the same local day — without
  // this, a UTC-midnight date rolls back a day (and sometimes a month) in any
  // timezone behind UTC, e.g. a Feb-only project rendering as "Jan – Feb".
  if (v instanceof Date) return new Date(v.getUTCFullYear(), v.getUTCMonth(), v.getUTCDate());
  const [y, m, d] = v.split('-');
  return new Date(parseInt(y), m ? parseInt(m) - 1 : 0, d ? parseInt(d) : 1);
}
const fmtMonth = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
// A month-granular end date is INCLUSIVE of its named month: a role running
// "Nov 2023 – Oct 2024" is active *through* October, so its bar must fill the
// whole October column. parseDate lands on the 1st, so the exclusive bar end is
// the first instant of the following month. (The display label keeps the named
// month — see mkItem.)
const exclusiveEnd = (d: Date): Date => new Date(d.getFullYear(), d.getMonth() + 1, 1);
// Absolute month index (year * 12 + month) — a timezone-proof column coordinate.
// The timeline renders bars by whole months (see pct), so a bar starting any day
// of a month fills that whole column; storing the index here (rather than deriving
// it from the ms timestamp client-side) avoids a month-boundary slip across zones.
const monthNum = (d: Date): number => d.getFullYear() * 12 + d.getMonth();

let _id = 0;
interface ItemOpts {
  title: string; type: CatKey; start: any; end?: any; point?: boolean;
  entity?: string; entityShort?: string | null; description?: string | null; subtitle?: string | null; links?: ({ label: string; url: string | null | undefined })[];
  affiliations?: string[]; main?: boolean; also?: CatKey[];
  relationGroups?: string[];
}
function mkItem(o: ItemOpts): Item | null {
  const s = parseDate(o.start);
  if (!s) return null;
  let start: number, end: number | null, dateLabel: string, endMonthNum: number | null;
  if (o.point) {
    const yearOnly = typeof o.start === 'string' && o.start.length === 4;
    const e = new Date(s.getFullYear(), s.getMonth() + 1, 1); // one month
    start = s.getTime(); end = e.getTime(); endMonthNum = monthNum(e); dateLabel = yearOnly ? o.start : fmtMonth(s);
  } else {
    const e = parseDate(o.end);
    const ex = e ? exclusiveEnd(e) : null;
    start = s.getTime();
    // Inclusive end: the bar covers through the named end month (see exclusiveEnd).
    end = ex ? ex.getTime() : null;
    endMonthNum = ex ? monthNum(ex) : null;
    dateLabel = e ? `${fmtMonth(s)} – ${fmtMonth(e)}` : `${fmtMonth(s)} – Present`;
  }
  // Drop empties, then de-dupe by URL (keep the first) so a `urls` entry that
  // repeats the main `url`/`repo` — or an org-level link already on the role —
  // doesn't render the same destination twice.
  const links = (o.links || [])
    .filter((l): l is { label: string; url: string } => !!l && !!l.url)
    .filter((l, i, arr) => arr.findIndex(x => x.url === l.url) === i);
  const description = o.description || null;
  const entity = o.entity || o.title;
  const entityShort = o.entityShort || entity; // falls back to the long-form org
  const cats = Array.from(new Set<CatKey>([o.type, ...(o.also || [])]));
  return {
    id: _id++, title: o.title, type: o.type, start, end, startMonthNum: monthNum(s), endMonthNum, dateLabel,
    description, subtitle: o.subtitle || null, links, entity, entityShort, group: `${o.type}::${entity}`,
    affiliations: o.affiliations || [],
    relationGroups: o.relationGroups || [],
    main: !!o.main, cats,
  };
}

// ---------------------------------------------------------------------------
// Blanket "Member" windows. Both affiliations.json and organizations.json give
// an org an optional `membership` span — the general "member" stretch that
// brackets its specific roles. On the timeline we carve that span so it yields
// to each specific role and resumes in the gaps between them: when a role starts
// the Member ends; when the role ends, if the membership still has time left, it
// picks back up. A membership fully covered by specific roles produces no bar at
// all. This shapes the timeline only — the list view shows the full, uncarved
// span. A former-member relationship is instead recorded as an `alumnus` window,
// which never charts (it would otherwise run to "Present" forever) and surfaces
// in the bottom "Alumni" strip. See carveMemberRanges / membershipSegments below.
const PRESENT = Number.POSITIVE_INFINITY;
const toMs = (d: string | null): number => { const p = parseDate(d); return p ? p.getTime() : PRESENT; };
// Exclusive end in ms — the first instant of the month AFTER the named end month,
// so an inclusive end ("active through Oct") carves as covering all of October.
const toEndMs = (d: string | null): number => { const p = parseDate(d); return p ? exclusiveEnd(p).getTime() : PRESENT; };
const monthStr = (ms: number): string => { const d = new Date(ms); return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`; };
// The inclusive last-active month for an EXCLUSIVE end instant (a first-of-month):
// step back one month. Carved segments emit this so mkItem's inclusive-end
// handling reconstructs the same exclusive boundary instead of double-counting it.
const monthStrEnd = (ms: number): string => { const d = new Date(ms); return monthStr(new Date(d.getFullYear(), d.getMonth() - 1, 1).getTime()); };

// Return the member's [start, end) window minus the union of the specific roles'
// windows, as a list of gap segments. `end` is null on a segment that runs to an
// open-ended ("Present") member end so it keeps rendering as ongoing.
function carveMemberRanges(
  memberStart: string,
  memberEnd: string | null,
  specifics: { start: string | null; end: string | null }[],
): { start: string; end: string | null }[] {
  const mStart = toMs(memberStart);
  const open = memberEnd == null;                 // member runs to "Present"
  const mEnd = open ? PRESENT : toEndMs(memberEnd);   // inclusive: through the member's end month
  if (!(mEnd > mStart)) return [];

  // Specific role windows, clipped to the member window, earliest first. Role
  // ends are exclusive instants too, so the Member resumes the month AFTER a role
  // (not overlapping the role's final month).
  const blocks = specifics
    .map(s => ({ start: Math.max(toMs(s.start), mStart), end: Math.min(s.end == null ? PRESENT : toEndMs(s.end), mEnd) }))
    .filter(b => b.end > b.start)
    .sort((a, b) => a.start - b.start);

  const out: { start: string; end: string | null }[] = [];
  // `b` is an exclusive boundary; emit the inclusive last-active month so mkItem
  // re-expands it to the same boundary (an open trailing segment stays null).
  const emit = (a: number, b: number) => { if (b > a) out.push({ start: monthStr(a), end: b === mEnd && open ? null : monthStrEnd(b) }); };
  let cursor = mStart;
  for (const b of blocks) {
    if (b.start > cursor) emit(cursor, b.start); // gap before this specific role
    if (b.end > cursor) cursor = b.end;          // advance past it (merges overlaps)
  }
  emit(cursor, mEnd);                            // trailing gap after the last role
  return out;
}

// Charted roles for an org: those that pass displayTimeline AND carry a start
// date (an undated role can't be a bar). alumnus never charts.
function orgTimelineRoles(org: Org): OrgRole[] {
  return (org.roles ?? []).filter(r => roleShown(org, r) && !!r.start);
}
// Carve an org's blanket `membership` window around its charted dated roles,
// yielding "Member" segments (timeline only). Empty unless the org charts and
// the membership has a concrete start.
function membershipSegments(org: Org): { start: string; end: string | null }[] {
  if (!org.membership?.start || !orgShown(org)) return [];
  const specifics = orgTimelineRoles(org).map(r => ({ start: r.start, end: r.end ?? null }));
  return carveMemberRanges(org.membership.start, org.membership.end ?? null, specifics);
}
// Does the org produce any timeline bar at all? (a charted dated role, or a
// charted membership segment)
function orgHasBars(org: Org): boolean {
  return orgTimelineRoles(org).length > 0 || membershipSegments(org).length > 0;
}
// Any concrete date anywhere on the org (role start, membership start, alum span)?
function orgHasDates(org: Org): boolean {
  return (org.roles ?? []).some(r => !!r.start) || !!org.membership?.start || !!org.alumnus?.start || !!org.alumnus?.end;
}
// Currently active — some open-ended (no-end) role or membership span.
function orgActive(org: Org): boolean {
  return (org.roles ?? []).some(r => r.start && !r.end) || (!!org.membership?.start && !org.membership?.end);
}

const projects = await getCollection('projects');

// Timeline category for an affiliation role: its own `categories`, else the
// org's, else plain "work". First entry is the primary (colour/lane); the rest
// become extra filters the item also shows under.
function affilCats(org: Org, r?: OrgRole): { type: CatKey; also: CatKey[] } {
  const c = (r?.categories ?? org.categories ?? ['work']) as CatKey[];
  return { type: c[0] ?? 'work', also: c.slice(1) };
}

const items: Item[] = [
  ...(education as any[]).map(e => mkItem({
    title: e.degree, type: 'education', start: e.start, end: e.end, entity: e.institution, entityShort: e.institutionShort,
    description: [e.institution, e.honors].filter(Boolean).join(' · '),
    links: [{ label: 'Website', url: e.url }, ...extraLinks(e.urls)], main: e.main,
    relationGroups: e.relationGroups,
  })),
  // Work affiliations share the org shape, so they build exactly like clubs
  // (below) — only the category differs (their `categories`, default "work").
  ...affilOrgs.flatMap(org => [
    ...orgTimelineRoles(org).map(r => mkItem({
      title: r.role, ...affilCats(org, r),
      start: r.start, end: r.end, entity: org.organization, entityShort: org.organizationShort,
      subtitle: [org.organization, r.location ?? org.location].filter(Boolean).join(' · ') || null,
      description: r.description ?? null,
      links: [{ label: 'Website', url: r.url ?? org.url }, ...extraLinks(r.urls), ...extraLinks(org.urls)],
      main: r.main ?? org.main,
      relationGroups: r.relationGroups ?? org.relationGroups,
    })),
    // Blanket `membership` carved into "Member" segments around those roles.
    ...membershipSegments(org).map(seg => mkItem({
      title: 'Member', ...affilCats(org),
      start: seg.start, end: seg.end, entity: org.organization, entityShort: org.organizationShort,
      subtitle: [org.organization, org.location].filter(Boolean).join(' · ') || null,
      description: org.membership?.description ?? null,
      links: [{ label: 'Website', url: org.membership?.url ?? org.url }, ...extraLinks(org.membership?.urls), ...extraLinks(org.urls)],
      main: org.main,
      relationGroups: org.relationGroups,
    })),
  ]),
  ...(publications as any[]).map(p => mkItem({
    // Publications share the "awards/pubs" category with awards/scholarships.
    title: p.title, type: 'awards', start: p.date, point: true, entity: p.title,
    description: [(p.authors && p.authors.length) ? p.authors.join(', ') : null, p.venue].filter(Boolean).join(' — '),
    links: [{ label: 'Read', url: p.url }, ...extraLinks(p.urls)], main: p.main,
    relationGroups: p.relationGroups,
  })),
  ...(awards as any[]).map(a => mkItem({
    // Awards, honors & scholarships — point events under "awards/pubs".
    title: a.name, type: 'awards', start: a.date, point: true, entity: a.name,
    links: [{ label: 'View', url: a.url }, ...extraLinks(a.urls)], main: a.main,
    relationGroups: a.relationGroups,
  })),
  ...orgs.flatMap(org => [
    // Clubs mirror work roles: the role is the title, while the organisation,
    // location and an optional freeform detail line live in the drawer body.
    // Only charted, dated roles become bars (see orgTimelineRoles).
    ...orgTimelineRoles(org).map(r => mkItem({
      title: r.role, type: 'clubs', start: r.start, end: r.end, entity: org.organization, entityShort: org.organizationShort,
      subtitle: [org.organization, r.location ?? org.location].filter(Boolean).join(' · ') || null,
      description: r.description ?? null,
      links: [{ label: 'Website', url: r.url ?? org.url }, ...extraLinks(r.urls), ...extraLinks(org.urls)],
      main: r.main ?? org.main,
      relationGroups: r.relationGroups ?? org.relationGroups,
    })),
    // Blanket `membership` carved into "Member" segments around those roles. The
    // literal title "Member" keeps the client's lane-chain detection working.
    ...membershipSegments(org).map(seg => mkItem({
      title: 'Member', type: 'clubs', start: seg.start, end: seg.end, entity: org.organization, entityShort: org.organizationShort,
      subtitle: [org.organization, org.location].filter(Boolean).join(' · ') || null,
      description: org.membership?.description ?? null,
      links: [{ label: 'Website', url: org.membership?.url ?? org.url }, ...extraLinks(org.membership?.urls), ...extraLinks(org.urls)],
      main: org.main,
      relationGroups: org.relationGroups,
    })),
  ]),
  ...projects.map(p => mkItem({
    title: p.data.title, type: 'projects', start: p.data.startDate, end: p.data.endDate, entity: p.data.title,
    description: p.data.description, affiliations: p.data.affiliations || [],
    links: [{ label: 'Visit', url: p.data.url }, { label: 'Repo', url: p.data.repo }, ...extraLinks(p.data.urls)], main: p.data.main,
    relationGroups: p.data.relationGroups,
  })),
  // "Misc." — a catch-all for conferences attended and any other one-off timeline
  // events worth noting (talks, trips, ceremonies, milestones, etc.). Conferences
  // come from conferences.json; freeform entries from misc.json. Both render as
  // point markers, unless a misc entry sets an `end` (then it becomes a ranged bar).
  ...(conferences as any[]).map(c => mkItem({
    title: c.name, type: 'misc', start: c.date, point: true, entity: c.name,
    subtitle: c.location || null, description: c.description ?? null,
    links: [{ label: 'View', url: c.url }, ...extraLinks(c.urls)], main: c.main,
    relationGroups: c.relationGroups,
  })),
  ...(misc as any[]).map(m => mkItem({
    title: m.name, type: 'misc', start: m.date, end: m.end, point: !m.end, entity: m.name,
    subtitle: m.location || null, description: m.description ?? null,
    links: [{ label: 'View', url: m.url }, ...extraLinks(m.urls)], main: m.main,
    relationGroups: m.relationGroups,
  })),
].filter((s): s is Item => s !== null);

// ---------------------------------------------------------------------------
// Bottom strips. Things that aren't (or can't be) bars, shown as chips beneath
// the chart, split into labelled groups:
//   • Other involvements — any org/affiliation that charts no bar: explicitly
//               hidden via `displayTimeline: false`, OR simply undated. Dated
//               entries lead (each with its involvement span); undated entries
//               trail in a separate paragraph. alumnus orgs are excluded (their
//               own strip below).
//   • Undated — point events (awards, publications, conferences, misc) with no
//               date recorded, so they can never be charted; surfaced here
//               instead of vanishing.
//   • Alumni  — a former-member relationship: an `alumnus` window on a club or a
//               work affiliation (its category colours the chip)
// Every entry shares the chip shape { title, category, detail, url, main }; a
// group renders as one or more paragraphs (chip rows).
interface BottomEntry { title: string; category: CatKey; detail: string | null; url: string | null; main: boolean; }

// Overall involvement span (specific roles + the blanket membership window;
// alumnus is its own strip) for an org that charts no bar. null when nothing on
// the org carries a date — those entries fall to the undated paragraph.
function orgInvolvementRange(org: Org): string | null {
  const segs = [
    ...(org.roles ?? []).map(r => ({ start: r.start, end: r.end ?? null })),
    ...(org.membership?.start ? [{ start: org.membership.start, end: org.membership.end ?? null }] : []),
  ].filter(s => !!s.start);
  if (!segs.length) return null;
  const minStart = segs.map(s => s.start!).sort()[0];
  const open = segs.some(s => !s.end);                            // an ongoing span ⇒ "Present"
  const maxEnd = open ? null : segs.map(s => s.end!).sort().slice(-1)[0];
  return dateRange(minStart, maxEnd);
}
// Newest activity of an involvement, for ordering the dated paragraph (an open
// span ranks as Present via toMs(null) = +∞).
const invRecency = (org: Org): number =>
  Math.max(...[...(org.roles ?? []), ...(org.membership?.start ? [org.membership] : [])]
    .filter(s => !!s.start).map(s => toMs(s.end ?? null)));
// A chip for an "Other involvements" org: its role label(s) and, when dated, its
// involvement span — "Role · Sep 2021 – May 2023".
const involvementChip = (o: Org, category: CatKey): BottomEntry => ({
  title: o.organization, category,
  detail: [involvementRoleLabel(o), orgInvolvementRange(o)].filter(Boolean).join(' · ') || null,
  url: o.url ?? null, main: !!o.main,
});

// Other involvements: every non-alumnus org that makes no bar (hidden via
// `displayTimeline: false`, or undated), clubs and work affiliations alike.
const involvementOrgs: { o: Org; category: CatKey }[] = [
  ...affilOrgs.filter(o => !o.alumnus && !orgHasBars(o)).map(o => ({ o, category: affilCats(o).type })),
  ...orgs.filter(o => !o.alumnus && !orgHasBars(o)).map(o => ({ o, category: 'clubs' as CatKey })),
];
// Dated lead (newest first, with their span); undated trail in a separate row.
const datedInv = involvementOrgs.filter(x => orgInvolvementRange(x.o) !== null)
  .sort((a, b) => invRecency(b.o) - invRecency(a.o))
  .map(x => involvementChip(x.o, x.category));
const undatedInv = involvementOrgs.filter(x => orgInvolvementRange(x.o) === null)
  .map(x => involvementChip(x.o, x.category));

// Undated point events — awards/pubs/conferences/misc with no `date`, which can't
// be charted (mkItem drops them); surfaced here so they don't silently vanish.
const undatedPoints: BottomEntry[] = [
  ...(publications as any[]).filter(p => !p.date).map(p => ({ title: p.title, category: 'awards' as CatKey, detail: p.venue ?? null, url: p.url ?? null, main: !!p.main })),
  ...(awards as any[]).filter(a => !a.date).map(a => ({ title: a.name, category: 'awards' as CatKey, detail: null, url: a.url ?? null, main: !!a.main })),
  ...(conferences as any[]).filter(c => !c.date).map(c => ({ title: c.name, category: 'misc' as CatKey, detail: c.location ?? null, url: c.url ?? null, main: !!c.main })),
  ...(misc as any[]).filter(m => !m.date).map(m => ({ title: m.name, category: 'misc' as CatKey, detail: m.location ?? null, url: m.url ?? null, main: !!m.main })),
];

const alumni: BottomEntry[] = [
  ...affilOrgs.filter(o => o.alumnus).map(o => ({
    title: o.organization, category: affilCats(o).type, detail: alumnusLabel(o.alumnus!), url: o.url ?? null, main: !!o.main,
  })),
  ...orgs.filter(o => o.alumnus).map(o => ({
    title: o.organization, category: 'clubs' as CatKey, detail: alumnusLabel(o.alumnus!), url: o.url ?? null, main: !!o.main,
  })),
];

// Each group is one or more paragraphs (chip rows). "Other involvements" splits
// into a dated and an undated paragraph; the rest are a single paragraph. Empty
// paragraphs/groups drop out.
const bottomGroups = [
  { key: 'other',   label: 'Other involvements', paragraphs: [datedInv, undatedInv] },
  { key: 'undated', label: 'Undated',            paragraphs: [undatedPoints] },
  { key: 'alumni',  label: 'Alumni',             paragraphs: [alumni] },
].map(g => ({ ...g, paragraphs: g.paragraphs.filter(p => p.length > 0) }))
 .filter(g => g.paragraphs.length > 0);
const bottomItems: BottomEntry[] = bottomGroups.flatMap(g => g.paragraphs.flat());

const nowYear = new Date().getFullYear();
const yearsOf = items.flatMap(it => [new Date(it.start).getFullYear(), new Date(it.end ?? Date.now()).getFullYear()]);
const minYear = Math.min(...yearsOf);
const maxYear = Math.max(...yearsOf, nowYear);
const years: number[] = [];
for (let y = maxYear; y >= minYear; y--) years.push(y);

const counts: Record<string, number> = { all: items.length + bottomItems.length };
for (const c of CATEGORIES) {
  counts[c.key] = items.filter(s => s.cats.includes(c.key)).length + bottomItems.filter(u => u.category === c.key).length;
}
counts.main = items.filter(s => s.main).length + bottomItems.filter(u => u.main).length;

// Only surface a filter (and legend entry) for categories that actually have
// at least one item; likewise hide the Main filter when nothing is flagged.
const shownCategories = CATEGORIES.filter(c => counts[c.key] > 0);
const showMain = counts.main > 0;

const cfg = { categories: CATEGORIES, typeOrder: TYPE_ORDER, summerCols: SUMMER_COLS };
---

<BaseLayout title="Experience" description={profile.pageMeta.experience}>
  <script is:inline>
    // Runs before the view markup is parsed: honour the URL's view up-front so a
    // reload on the list view renders the list straight away — no flash of the
    // timeline and no replay of its shrink. The module script below removes
    // `view-init` after the first paint, re-enabling transitions for clicks.
    (function () {
      var de = document.documentElement;
      de.classList.add('view-init');
      var hash = location.hash.replace('#', '');
      // The Gantt timeline is unwieldy on a narrow screen, so phones default to
      // the list view. `#list` always wins; an empty hash falls back to list on
      // phones / timeline elsewhere; any other hash is a category filter, which
      // implies the timeline view. (The module script below mirrors this.)
      var phone = window.matchMedia('(max-width: 640px)').matches;
      de.dataset.initialView = (hash === 'list' || (hash === '' && phone)) ? 'list' : 'timeline';
    })();
  </script>
  <h1>Experience</h1>

  <div class="view-switch" role="group" aria-label="Choose how to view experience">
    <button class="view-btn active" data-view="timeline" aria-pressed="true">Timeline</button>
    <button class="view-btn" data-view="list" aria-pressed="false">List</button>
  </div>

  {/* ===================== TIMELINE VIEW (default) ===================== */}
  <section class="view view-timeline active" data-view="timeline" aria-label="Timeline view">
    <div class="tl-layout">
      <div class="tl-content">
        <p class="view-intro">
          Years run down the page; months across. Summer months are shaded. Click any bar to see details and
          highlight everything from the same organisation. Filter by category.
        </p>

        <div class="tl-filters" role="group" aria-label="Filter timeline by category">
          <button class="tl-filter active" data-filter="all">All <span class="count">{counts.all}</span></button>
          {showMain && <button class="tl-filter tl-filter-main" data-filter="main">★ Main <span class="count">{counts.main}</span></button>}
          {showMain && shownCategories.length > 0 && <span class="tl-filter-sep" aria-hidden="true"></span>}
          {shownCategories.map(c => (
            <button class="tl-filter" data-filter={c.key}>{c.label} <span class="count">{counts[c.key]}</span></button>
          ))}
        </div>

        <div class="gantt-wrap">
          <div class="gantt">
            {years.map((year, i) => (
              <div class="tl-row">
                <div class="tl-rail">
                  <div class="tl-year"><span>{year}</span></div>
                  <div class="tl-rail-line"></div>
                </div>
                <div class="tl-panel">
                  <div class="tl-months">
                    {MONTH_LABELS.map((m, mi) => (
                      <div class:list={['tl-month', { summer: SUMMER_COLS.includes(mi) }]}>{m}</div>
                    ))}
                  </div>
                  <div class="tl-body" data-year={year}>
                    <div class="tl-grid">
                      {MONTH_LABELS.map((_, mi) => (
                        <div class:list={['tl-grid-cell', { summer: SUMMER_COLS.includes(mi) }]}></div>
                      ))}
                    </div>
                    <div class="tl-bars"></div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="tl-legend">
          {shownCategories.map(c => (
            <span class="leg"><span class="sw" style={`background:${c.color}`}></span>{c.label}</span>
          ))}
          <span class="leg leg-summer"><span class="sw sw-summer"></span>Summer</span>
        </div>

        {bottomGroups.map(g => (
          <div class="undated" data-group={g.key}>
            <span class="undated-label">{g.label}</span>
            {g.paragraphs.map(p => (
              <div class="undated-items">
                {p.map(u => (
                  <span class="undated-item" data-category={u.category} data-main={String(u.main)} style={`--cat: ${CATEGORIES.find(c => c.key === u.category)!.color}`}>
                    {u.url ? <a href={u.url} target="_blank" rel="noopener noreferrer">{u.title}</a> : u.title}
                    {u.detail && <span class="undated-detail"> — {u.detail}</span>}
                  </span>
                ))}
              </div>
            ))}
          </div>
        ))}
      </div>

      {/* ===== INFO TAB — the sticky detail panel that slides in on the right
          when a bar is clicked. Its top stays pinned to the viewport and it
          scrolls independently of the timeline. (a.k.a. `.tl-detail`.) ===== */}
      <aside class="tl-detail" aria-hidden="true">
        <div class="tl-detail-panel">
          <button class="tl-detail-close" aria-label="Close details (Esc)">
            <svg class="tl-detail-close-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            <span class="tl-detail-close-label">esc</span>
          </button>
          <div class="tl-detail-body"></div>
        </div>
      </aside>
    </div>
  </section>

  {/* ===================== EXPERIENCE (list) VIEW ===================== */}
  <section class="view view-list" data-view="list" aria-label="Experience list view" hidden>
    {/* Mirrors the timeline's layout: the list sits in .tl-content with its own
        sliding info tab (.tl-detail) to the right. Every row carries a `data-li`
        id into the #tl-list-data dataset; clicking it opens the panel. */}
    <div class="tl-layout">
      <div class="tl-content">
    <p class="view-intro">Current and past affiliations. Click any entry for details.</p>

    <h2>Current</h2>
    <div class="groups">
      {currentAffilGroups.map(group => (
        <div class="org-group">
          <div class="entity-row">
            <span class="org-name">
              {group.url
                ? <a href={group.url} target="_blank" rel="noopener noreferrer">{group.organization}</a>
                : group.organization}
            </span>
            {group.location && <span class="org-location">{group.location}</span>}
          </div>
          <div class="roles">
            {group.roles.map((r, i) => {
              const isLast = i === group.roles.length - 1;
              const glyph = isLast ? '└' : '├';
              const dates = dateRange(r.start, r.end);
              return (
                <div class="role-row" data-li={r.id} role="button" tabindex="0">
                  <span class="bracket">{glyph}</span>
                  <span class="role-name">{r.role}</span>
                  {dates && <span class="role-dates">{dates}</span>}
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <h2>Past</h2>
    <div class="groups">
      {pastAffilGroups.map(group => (
        <div class="org-group">
          <div class="entity-row">
            <span class="org-name">
              {group.url
                ? <a href={group.url} target="_blank" rel="noopener noreferrer">{group.organization}</a>
                : group.organization}
            </span>
            {group.location && <span class="org-location">{group.location}</span>}
          </div>
          <div class="roles">
            {group.roles.map((r, i) => {
              const isLast = i === group.roles.length - 1;
              const glyph = isLast ? '└' : '├';
              const dates = dateRange(r.start, r.end);
              return (
                <div class="role-row" data-li={r.id} role="button" tabindex="0">
                  <span class="bracket">{glyph}</span>
                  <span class="role-name">{r.role}</span>
                  {dates && <span class="role-dates">{dates}</span>}
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    {leaderListGroups.length > 0 && (
      <>
        <h2>Leadership</h2>
        <div class="groups">
          {leaderListGroups.map(group => (
            <div class="org-group">
              <div class="entity-row">
                <span class="org-name">
                  {group.url
                    ? <a href={group.url} target="_blank" rel="noopener noreferrer">{group.organization}</a>
                    : group.organization}
                </span>
                {group.location && <span class="org-location">{group.location}</span>}
              </div>
              {group.roles.map((item, i) => {
                const isLast = i === group.roles.length - 1;
                const glyph = isLast ? '└' : '├';
                const dates = dateRange(item.start, item.end);
                return (
                  <div class="role-row" data-li={item.id} role="button" tabindex="0">
                    <span class="bracket">{glyph}</span>
                    <span class="role-name">{item.role}</span>
                    {dates && <span class="role-dates">{dates}</span>}
                  </div>
                );
              })}
            </div>
          ))}
        </div>
      </>
    )}

    {awardRows.length > 0 && (
      <>
        <h2>Awards & Honors</h2>
        <ul class="involvement-list">
          {awardRows.map(award => (
            <li class="award-row" data-li={award.liId} role="button" tabindex="0">
              <span class="inv-name">{award.name}</span>
              <span class="role-dates">{formatDate(award.date)}</span>
            </li>
          ))}
        </ul>
      </>
    )}

    {conferenceRows.length > 0 && (
      <>
        <h2>Conferences</h2>
        <ul class="involvement-list">
          {conferenceRows.map(conf => (
            <li class="award-row" data-li={conf.liId} role="button" tabindex="0">
              <span class="inv-name">{conf.name}</span>
              <span class="role-dates">{formatDate(conf.date)}</span>
            </li>
          ))}
        </ul>
      </>
    )}

    {involvementListItems.length > 0 && (
      <>
        <h2>Involvements</h2>
        <ul class="involvement-list">
          {involvementListItems.map(inv => (
            <li data-li={inv.liId} role="button" tabindex="0">
              <span class="inv-name">{inv.name}</span>
              {inv.role && <span class="inv-role"> &mdash; {inv.role}</span>}
            </li>
          ))}
        </ul>
      </>
    )}
      </div>

      {/* ===== INFO TAB for the list view — the same sliding panel as the
          timeline's, opened by clicking a list row. ===== */}
      <aside class="tl-detail tl-detail-list" aria-hidden="true">
        <div class="tl-detail-panel">
          <button class="tl-detail-close" aria-label="Close details (Esc)">
            <svg class="tl-detail-close-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            <span class="tl-detail-close-label">esc</span>
          </button>
          <div class="tl-detail-body"></div>
        </div>
      </aside>
    </div>
  </section>

  {/* Dimming layer behind the info tab when it floats as an overlay on narrow
      screens. Click it (or Esc, or the panel's close button) to dismiss. */}
  <div class="tl-scrim" aria-hidden="true"></div>

  <script type="application/json" id="tl-data" set:html={JSON.stringify(items)}></script>
  <script type="application/json" id="tl-cfg" set:html={JSON.stringify(cfg)}></script>
  <script type="application/json" id="tl-list-data" set:html={JSON.stringify(listItems)}></script>
</BaseLayout>

<!-- Page-only: width + globally-styled JS-created bars. Width rules are gated on
     the timeline view being the active one, so the list view keeps the default
     (narrower) page width. -->
<style is:global>
  /* The timeline view is a wide, FLUID two-pane layout: the chart fills `main`,
     and opening the info tab makes the chart reflow narrower to share the row
     with the tab — both always fit, no overflow, no overlap. Widths are screen-
     proportional so the split scales with the viewport (the original fixed-width
     "grow the page so the chart never moves" trick was what squeezed the chart on
     mid-size screens). The max-width transition animates the LIST view's grow and
     the view→view width change.
       --tl-detail-gap is the breathing room between content and the info tab's
     border; --tl-detail-w is the tab's (screen-proportional) width, shared by the
     tab's flex-basis, its panel width, and the list view's open width. Both are
     declared here on a common ancestor so `main`'s calc() and the descendant
     .tl-detail can read them. */
  main:has(.view-switch) {
    --tl-detail-gap: 1.25rem;
    --tl-detail-w: clamp(280px, 26vw, 360px);
    transition: max-width 0.55s cubic-bezier(0.4, 0, 0.2, 1);
  }
  /* Timeline: ONE fluid width for both states. Closed, the chart fills it; open,
     the chart gives part of it back to the tab (see .tl-content / .tl-detail), so
     the chart reflows narrower instead of the page growing or the chart being
     squeezed past its content. */
  main:has(.view-timeline.active) { max-width: min(1360px, 94vw); }
  /* List: the list column is narrow, so rather than squeeze it we WIDEN `main`
     to seat the tab beside it — capped at the viewport so it never overflows
     (when it can't grow, the flex content reflows to fit). */
  main:has(.view-list:not([hidden]) .tl-detail.open) {
    max-width: min(calc(var(--max-width) + var(--tl-detail-w) + var(--tl-detail-gap)), 94vw);
  }
  /* Always reserve the page scrollbar gutter so widths don't jump on scroll. */
  html:has(.view-timeline.active) { scrollbar-gutter: stable; }
  html:has(.view-list:not([hidden])) { scrollbar-gutter: stable; }

  /* ===== NARROW SCREENS: info-tab OVERLAY ================================
     Below this width the chart and side panel can't share the row comfortably,
     so the info tab floats OVER everything as a full-screen overlay (see the
     scoped styles) instead of pushing. We must not widen `main` for it, and we
     lock the page behind it. (Phones — ≤640px — additionally default to the list
     view; see the inline + module scripts.) */
  @media (max-width: 830px) {
    main:has(.view-list:not([hidden]) .tl-detail.open) { max-width: var(--max-width); }
    /* Lock scroll behind the panel, and drop the reserved gutter (no scrollbar
       while locked) so the fixed panel's `right: 0` reaches the true edge. */
    html:has(.tl-detail.open) { overflow: hidden; scrollbar-gutter: auto; }
  }

  /* Pre-hydration: the inline script at the top of the page sets these on <html>
     from the URL hash BEFORE the view markup is parsed, so a reload on the list
     view shows the list immediately — no timeline flash, no shrink replay. All
     rules are gated on `.view-init`, which the view script removes once the
     correct view has painted; normal class/[hidden] control + the width
     transition then take over. */
  html.view-init main { transition: none !important; }
  html.view-init[data-initial-view='list'] main:has(.view-timeline.active) { max-width: var(--max-width); }
  html.view-init[data-initial-view='list'] .view-timeline { display: none; }
  html.view-init[data-initial-view='list'] .view-list { display: block; }
  /* …and match the selector's active button to the initial view, so the
     "Timeline" button doesn't flash highlighted before the script flips it. */
  html.view-init[data-initial-view='list'] .view-btn[data-view='timeline'].active {
    background: var(--bg);
    color: var(--text-muted);
  }
  html.view-init[data-initial-view='list'] .view-btn[data-view='list'] {
    background: var(--accent);
    color: var(--bg);
  }

  .tl-bar {
    position: absolute; display: flex; align-items: center; gap: 0;
    padding: 0 0.375rem; font-size: 10px; overflow: hidden; white-space: nowrap;
    background: var(--bg); border: 1px solid color-mix(in srgb, var(--text-muted) 55%, var(--border)); border-left-width: 3px;
    color: var(--text); text-decoration: none; box-sizing: border-box; cursor: pointer;
    transition: opacity 0.15s ease, border-color 0.12s ease, box-shadow 0.12s ease;
  }
  .tl-bar .t { font-weight: 500; flex: 0 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; }
  /* Organisation suffix, shown after the title "space permitting". Its huge
     flex-shrink makes it surrender width first, so a tight bar truncates (then
     drops) the org before the title ever has to ellipsise. */
  .tl-bar .o {
    flex: 0 1000 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis;
    color: var(--text-muted); font-weight: 400;
  }
  /* Middle-dot separator before the org; non-breaking spaces keep it from being
     trimmed or wrapped against the title's (nowrap) line. */
  .tl-bar .o::before { content: '\00a0·\00a0'; }
  .tl-bar:hover { border-color: var(--accent); }
  .tl-bar:hover { text-decoration: none; }
  /* Selection emphasis, layered above the dimmed background:
     sel-primary = the selected role + its continuations (same role, other years) — filled box, strong border
     sel-related = same organisation (other roles) / tagged projects / shared relation-groups — lighter fill + border
     dim         = everything unrelated */
  .tl-bar.sel-related {
    background: color-mix(in srgb, var(--accent) 10%, var(--bg));
    border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
    z-index: 1;
  }
  .tl-bar.sel-primary {
    background: color-mix(in srgb, var(--accent) 24%, var(--bg));
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
    z-index: 2;
  }
  .tl-bar.sel-primary .t { font-weight: 700; }
  /* Dim by fading colours toward --bg rather than lowering opacity: an opaque
