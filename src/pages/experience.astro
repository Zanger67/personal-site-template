---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import affiliations from '../data/affiliations.json';
import education from '../data/education.json';
import publications from '../data/publications.json';
import leadership from '../data/leadership.json';
import involvements from '../data/involvements.json';
import awards from '../data/awards.json';
import conferences from '../data/conferences.json';
import misc from '../data/misc.json';

// ===========================================================================
// This page hosts two views of the same career data, swapped via a selector
// at the top. The "Timeline" view (default) is a Gantt-style chart; the
// "Experience" view is an organisation-grouped list. The selector toggles
// which <section class="view …"> is shown; only the active timeline view gets
// the wide layout (see the gated `main:has(.view-timeline.active)` rules).
// ===========================================================================

// ---------------------------------------------------------------------------
// EXPERIENCE (list) view — org-grouped tree of current/past/leadership roles
// plus awards, conferences and involvements.
// ---------------------------------------------------------------------------
interface Affiliation {
  entity: string;
  role: string;
  roleDetail?: string;
  startDate: string;
  endDate: string | null;
  url: string | null;
  location?: string | null;
}

interface OrgGroup {
  entity: string;
  url: string | null;
  location: string | null;
  roles: { role: string; startDate: string; endDate: string | null }[];
}

function formatDate(dateStr: string | null): string {
  if (!dateStr) return 'Present';
  const [year, month] = dateStr.split('-');
  const date = new Date(parseInt(year), parseInt(month) - 1);
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function dateRange(start: string | null, end: string | null): string | null {
  if (!start && !end) return null;
  if (start && !end) return `${formatDate(start)} – Present`;
  if (!start && end) return `... – ${formatDate(end)}`;
  return `${formatDate(start)} – ${formatDate(end)}`;
}

function sortKey(item: { endDate: string | null; startDate: string }): number {
  return new Date(item.endDate ?? item.startDate).valueOf();
}

function groupByEntity(items: Affiliation[]): OrgGroup[] {
  const groups: OrgGroup[] = [];
  const seen = new Map<string, OrgGroup>();
  for (const item of items) {
    if (seen.has(item.entity)) {
      const g = seen.get(item.entity)!;
      g.roles.push({ role: item.roleDetail || item.role, startDate: item.startDate, endDate: item.endDate });
      if (!g.location && item.location) g.location = item.location;
    } else {
      const group: OrgGroup = {
        entity: item.entity,
        url: item.url,
        location: item.location ?? null,
        roles: [{ role: item.roleDetail || item.role, startDate: item.startDate, endDate: item.endDate }],
      };
      groups.push(group);
      seen.set(item.entity, group);
    }
  }
  for (const group of groups) {
    group.roles.sort((a, b) => sortKey(b) - sortKey(a));
  }
  return groups;
}

const currentGroups = groupByEntity(affiliations.current);
const pastGroups = groupByEntity(affiliations.past);

interface LeaderRole {
  role: string;
  url?: string | null;
  start: string | null;
  end: string | null;
}

interface LeaderOrg {
  organization: string;
  url: string | null;
  location?: string | null;
  roles: LeaderRole[];
}

const leaderGroups = leadership as LeaderOrg[];

// ---------------------------------------------------------------------------
// TIMELINE view — ported from jackswitzer.com/projects "Timeline" view,
// adapted to our data and colour scheme. Years are rows (newest first);
// months are columns; each item is a lane-packed horizontal bar. Summer
// (May–Aug) columns are shaded. Clicking a bar selects its "group" (same
// category + same organisation), dims everything else, and opens a drawer.
// ---------------------------------------------------------------------------
type CatKey = 'education' | 'work' | 'research' | 'awards' | 'projects' | 'clubs' | 'misc';
const CATEGORIES: { key: CatKey; label: string; color: string }[] = [
  { key: 'education', label: 'Education', color: '#5b8def' },
  { key: 'work',      label: 'Work',      color: 'var(--accent)' },
  { key: 'research',  label: 'Research',  color: '#a06fd6' },
  { key: 'awards',    label: 'awards/pubs', color: '#d4a017' },
  { key: 'projects',  label: 'Projects',  color: '#e0883c' },
  { key: 'clubs',     label: 'Clubs',     color: '#e06c84' },
  { key: 'misc',      label: 'Misc.',     color: '#3aa6ad' },
];
const TYPE_ORDER: Record<CatKey, number> = { education: 0, work: 1, research: 2, awards: 3, projects: 4, clubs: 5, misc: 6 };
const MONTH_LABELS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const SUMMER_COLS = [4, 5, 6, 7]; // May–Aug

interface Item {
  id: number;
  title: string;
  type: CatKey;
  start: number;
  end: number | null;
  dateLabel: string;
  description: string | null;
  subtitle: string | null;   // org · location context line (clubs/work-style items)
  links: { label: string; url: string }[];
  // Grouping: items in the same group stay lit together when one is selected.
  entity: string;          // organisation / institution / (project = own title)
  group: string;           // `${type}::${entity}`
  affiliations: string[];  // (projects) org/role names this project is tagged to
  // Explicit item-to-item links (independent of org/group). `slug` is a stable
  // human-readable handle other items reference; `relatedSlugs` are the handles
  // this item declares (transient — resolved into `related` ids below, then
  // dropped); `related` is the resolved set of linked ids, made bidirectional.
  slug: string | null;
  relatedSlugs: string[];
  related: number[];
  main: boolean;           // cross-cutting "main"/highlights flag (orthogonal to type)
  cats: CatKey[];          // every category this item matches (primary `type` first).
                           // Extras let one item appear under multiple filters (e.g. a
                           // lab role that is both Research and Work). Colour/lane still
                           // follow the primary `type`.
}

function parseDate(v: string | Date | null | undefined): Date | null {
  if (!v) return null;
  if (v instanceof Date) return v;
  const [y, m, d] = v.split('-');
  return new Date(parseInt(y), m ? parseInt(m) - 1 : 0, d ? parseInt(d) : 1);
}
const fmtMonth = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

let _id = 0;
interface ItemOpts {
  title: string; type: CatKey; start: any; end?: any; point?: boolean;
  entity?: string; description?: string | null; subtitle?: string | null; links?: ({ label: string; url: string | null | undefined })[];
  affiliations?: string[]; main?: boolean; also?: CatKey[];
  slug?: string | null; related?: string[];
}
function mkItem(o: ItemOpts): Item | null {
  const s = parseDate(o.start);
  if (!s) return null;
  let start: number, end: number | null, dateLabel: string;
  if (o.point) {
    const yearOnly = typeof o.start === 'string' && o.start.length === 4;
    const e = new Date(s.getFullYear(), s.getMonth() + 1, 1); // one month
    start = s.getTime(); end = e.getTime(); dateLabel = yearOnly ? o.start : fmtMonth(s);
  } else {
    const e = parseDate(o.end);
    start = s.getTime(); end = e ? e.getTime() : null;
    dateLabel = e ? `${fmtMonth(s)} – ${fmtMonth(e)}` : `${fmtMonth(s)} – Present`;
  }
  const links = (o.links || []).filter((l): l is { label: string; url: string } => !!l && !!l.url);
  const description = o.description || null;
  const entity = o.entity || o.title;
  const cats = Array.from(new Set<CatKey>([o.type, ...(o.also || [])]));
  return {
    id: _id++, title: o.title, type: o.type, start, end, dateLabel,
    description, subtitle: o.subtitle || null, links, entity, group: `${o.type}::${entity}`,
    affiliations: o.affiliations || [],
    slug: o.slug || null, relatedSlugs: o.related || [], related: [],
    main: !!o.main, cats,
  };
}

const projects = await getCollection('projects');

const items: Item[] = [
  ...(education as any[]).map(e => mkItem({
    title: e.degree, type: 'education', start: e.start, end: e.end, entity: e.institution,
    description: [e.institution, e.honors].filter(Boolean).join(' · '),
    links: [{ label: 'Website', url: e.url }], main: e.main,
    slug: e.slug, related: e.related,
  })),
  ...([...affiliations.current, ...affiliations.past] as any[]).map(a => mkItem({
    // `categories` (optional): first entry is the primary (colour/lane); the rest are
    // extra filters this role also shows under. Defaults to a plain "work" role.
    title: a.role, type: (a.categories?.[0] ?? 'work') as CatKey, also: (a.categories?.slice(1) ?? []) as CatKey[],
    start: a.startDate, end: a.endDate, entity: a.entity,
    description: [a.entity, a.location].filter(Boolean).join(' · '),
    links: [{ label: 'Website', url: a.url }], main: a.main,
    slug: a.slug, related: a.related,
  })),
  ...(publications as any[]).map(p => mkItem({
    // Publications share the "awards/pubs" category with awards/scholarships.
    title: p.title, type: 'awards', start: p.date, point: true, entity: p.title,
    description: [(p.authors && p.authors.length) ? p.authors.join(', ') : null, p.venue].filter(Boolean).join(' — '),
    links: [{ label: 'Read', url: p.url }], main: p.main,
    slug: p.slug, related: p.related,
  })),
  ...(awards as any[]).map(a => mkItem({
    // Awards, honors & scholarships — point events under "awards/pubs".
    title: a.name, type: 'awards', start: a.date, point: true, entity: a.name,
    links: [{ label: 'View', url: a.url }], main: a.main,
    slug: a.slug, related: a.related,
  })),
  ...(leadership as any[]).flatMap(org =>
    org.roles.map((r: any) => mkItem({
      // Clubs mirror work roles: the role is the title, while the organisation,
      // location and an optional freeform detail line live in the drawer body.
      title: r.role, type: 'clubs', start: r.start, end: r.end, entity: org.organization,
      subtitle: [org.organization, r.location ?? org.location].filter(Boolean).join(' · ') || null,
      description: r.description ?? null,
      links: [{ label: 'Website', url: r.url ?? org.url }],
      main: r.main ?? org.main,
      slug: r.slug, related: r.related,
    }))
  ),
  ...projects.map(p => mkItem({
    title: p.data.title, type: 'projects', start: p.data.startDate, end: p.data.endDate, entity: p.data.title,
    description: p.data.description, affiliations: p.data.affiliations || [],
    links: [{ label: 'Visit', url: p.data.url }, { label: 'Repo', url: p.data.repo }], main: p.data.main,
    slug: p.data.slug, related: p.data.related,
  })),
  // "Misc." — a catch-all for conferences attended and any other one-off timeline
  // events worth noting (talks, trips, ceremonies, milestones, etc.). Conferences
  // come from conferences.json; freeform entries from misc.json. Both render as
  // point markers, unless a misc entry sets an `end` (then it becomes a ranged bar).
  ...(conferences as any[]).map(c => mkItem({
    title: c.name, type: 'misc', start: c.date, point: true, entity: c.name,
    subtitle: c.location || null, description: c.description ?? null,
    links: [{ label: 'View', url: c.url }], main: c.main,
    slug: c.slug, related: c.related,
  })),
  ...(misc as any[]).map(m => mkItem({
    title: m.name, type: 'misc', start: m.date, end: m.end, point: !m.end, entity: m.name,
    subtitle: m.location || null, description: m.description ?? null,
    links: [{ label: 'View', url: m.url }], main: m.main,
    slug: m.slug, related: m.related,
  })),
].filter((s): s is Item => s !== null);

// Resolve slug-based cross-links into concrete item ids and make them
// bidirectional: if A declares B as related, B is linked back to A too. Only an
// item that sets a `slug` can be referenced; the referencing item just lists
// that slug in its `related`. Unknown slugs and self-links are ignored.
const bySlug = new Map<string, Item>();
for (const it of items) if (it.slug && !bySlug.has(it.slug)) bySlug.set(it.slug, it);
const relSets = new Map<number, Set<number>>(items.map(it => [it.id, new Set<number>()]));
for (const it of items) {
  for (const slug of it.relatedSlugs) {
    const target = bySlug.get(slug);
    if (!target || target.id === it.id) continue;
    relSets.get(it.id)!.add(target.id);
    relSets.get(target.id)!.add(it.id);
  }
}
for (const it of items) {
  it.related = [...relSets.get(it.id)!];
  delete (it as Partial<Item>).relatedSlugs; // transient — keep out of the client payload
}

const undated = (involvements as any[]).map(i => ({
  title: i.name, category: 'clubs' as CatKey, detail: i.role ?? null, url: i.url ?? null, main: !!i.main,
}));

const nowYear = new Date().getFullYear();
const yearsOf = items.flatMap(it => [new Date(it.start).getFullYear(), new Date(it.end ?? Date.now()).getFullYear()]);
const minYear = Math.min(...yearsOf);
const maxYear = Math.max(...yearsOf, nowYear);
const years: number[] = [];
for (let y = maxYear; y >= minYear; y--) years.push(y);

const counts: Record<string, number> = { all: items.length + undated.length };
for (const c of CATEGORIES) {
  counts[c.key] = items.filter(s => s.cats.includes(c.key)).length + undated.filter(u => u.category === c.key).length;
}
counts.main = items.filter(s => s.main).length + undated.filter(u => u.main).length;

// Only surface a filter (and legend entry) for categories that actually have
// at least one item; likewise hide the Main filter when nothing is flagged.
const shownCategories = CATEGORIES.filter(c => counts[c.key] > 0);
const showMain = counts.main > 0;

const cfg = { categories: CATEGORIES, typeOrder: TYPE_ORDER, summerCols: SUMMER_COLS };
---

<BaseLayout title="Experience — Buzz" description="Current and past affiliations, shown as an interactive timeline or an organisation-grouped list.">
  <script is:inline>
    // Runs before the view markup is parsed: honour the URL's view up-front so a
    // reload on the list view renders the list straight away — no flash of the
    // timeline and no replay of its shrink. The module script below removes
    // `view-init` after the first paint, re-enabling transitions for clicks.
    (function () {
      var de = document.documentElement;
      de.classList.add('view-init');
      de.dataset.initialView = location.hash.replace('#', '') === 'list' ? 'list' : 'timeline';
    })();
  </script>
  <h1>Experience</h1>

  <div class="view-switch" role="group" aria-label="Choose how to view experience">
    <button class="view-btn active" data-view="timeline" aria-pressed="true">Timeline</button>
    <button class="view-btn" data-view="list" aria-pressed="false">List</button>
  </div>

  {/* ===================== TIMELINE VIEW (default) ===================== */}
  <section class="view view-timeline active" data-view="timeline" aria-label="Timeline view">
    <div class="tl-layout">
      <div class="tl-content">
        <p class="view-intro">
          Years run down the page; months across. Summer months are shaded. Click any bar to see details and
          highlight everything from the same organisation. Filter by category.
        </p>

        <div class="tl-filters" role="group" aria-label="Filter timeline by category">
          <button class="tl-filter active" data-filter="all">All <span class="count">{counts.all}</span></button>
          {showMain && <button class="tl-filter tl-filter-main" data-filter="main">★ Main <span class="count">{counts.main}</span></button>}
          {showMain && shownCategories.length > 0 && <span class="tl-filter-sep" aria-hidden="true"></span>}
          {shownCategories.map(c => (
            <button class="tl-filter" data-filter={c.key}>{c.label} <span class="count">{counts[c.key]}</span></button>
          ))}
        </div>

        <div class="gantt-wrap">
          <div class="gantt">
            {years.map((year, i) => (
              <div class="tl-row">
                <div class="tl-rail">
                  <div class="tl-year"><span>{year}</span></div>
                  <div class="tl-rail-line"></div>
                </div>
                <div class="tl-panel">
                  <div class="tl-months">
                    {MONTH_LABELS.map((m, mi) => (
                      <div class:list={['tl-month', { summer: SUMMER_COLS.includes(mi) }]}>{m}</div>
                    ))}
                  </div>
                  <div class="tl-body" data-year={year}>
                    <div class="tl-grid">
                      {MONTH_LABELS.map((_, mi) => (
                        <div class:list={['tl-grid-cell', { summer: SUMMER_COLS.includes(mi) }]}></div>
                      ))}
                    </div>
                    <div class="tl-bars"></div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="tl-legend">
          {shownCategories.map(c => (
            <span class="leg"><span class="sw" style={`background:${c.color}`}></span>{c.label}</span>
          ))}
          <span class="leg leg-summer"><span class="sw sw-summer"></span>Summer</span>
        </div>

        {undated.length > 0 && (
          <div class="undated">
            <span class="undated-label">Ongoing / undated</span>
            <div class="undated-items">
              {undated.map(u => (
                <span class="undated-item" data-category={u.category} data-main={String(u.main)} style={`--cat: ${CATEGORIES.find(c => c.key === u.category)!.color}`}>
                  {u.url ? <a href={u.url} target="_blank" rel="noopener noreferrer">{u.title}</a> : u.title}
                  {u.detail && <span class="undated-detail"> — {u.detail}</span>}
                </span>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* ===== INFO TAB — the sticky detail panel that slides in on the right
          when a bar is clicked. Its top stays pinned to the viewport and it
          scrolls independently of the timeline. (a.k.a. `.tl-detail`.) ===== */}
      <aside class="tl-detail" aria-hidden="true">
        <div class="tl-detail-panel">
          <button class="tl-detail-close" aria-label="Close details (Esc)">
            <svg class="tl-detail-close-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            <span class="tl-detail-close-label">esc</span>
          </button>
          <div class="tl-detail-body"></div>
        </div>
      </aside>
    </div>
  </section>

  {/* ===================== EXPERIENCE (list) VIEW ===================== */}
  <section class="view view-list" data-view="list" aria-label="Experience list view" hidden>
    <p class="view-intro">Current and past affiliations.</p>

    <h2>Current</h2>
    <div class="groups">
      {currentGroups.map(group => (
        <div class="org-group">
          <div class="entity-row">
            <span class="org-name">
              {group.url
                ? <a href={group.url} target="_blank" rel="noopener noreferrer">{group.entity}</a>
                : group.entity}
            </span>
            {group.location && <span class="org-location">{group.location}</span>}
          </div>
          <div class="roles">
            {group.roles.map((r, i) => {
              const isLast = i === group.roles.length - 1;
              const glyph = isLast ? '└' : '├';
              return (
                <div class="role-row">
                  <span class="bracket">{glyph}</span>
                  <span class="role-name">{r.role}</span>
                  <span class="role-dates">{dateRange(r.startDate, r.endDate)}</span>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <h2>Past</h2>
    <div class="groups">
      {pastGroups.map(group => (
        <div class="org-group">
          <div class="entity-row">
            <span class="org-name">
              {group.url
                ? <a href={group.url} target="_blank" rel="noopener noreferrer">{group.entity}</a>
                : group.entity}
            </span>
            {group.location && <span class="org-location">{group.location}</span>}
          </div>
          <div class="roles">
            {group.roles.map((r, i) => {
              const isLast = i === group.roles.length - 1;
              const glyph = isLast ? '└' : '├';
              return (
                <div class="role-row">
                  <span class="bracket">{glyph}</span>
                  <span class="role-name">{r.role}</span>
                  <span class="role-dates">{dateRange(r.startDate, r.endDate)}</span>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    {leaderGroups.length > 0 && (
      <>
        <h2>Leadership</h2>
        <div class="groups">
          {leaderGroups.map(group => (
            <div class="org-group">
              <div class="entity-row">
                <span class="org-name">
                  {group.url
                    ? <a href={group.url} target="_blank" rel="noopener noreferrer">{group.organization}</a>
                    : group.organization}
                </span>
                {group.location && <span class="org-location">{group.location}</span>}
              </div>
              {group.roles.map((item, i) => {
                const isLast = i === group.roles.length - 1;
                const glyph = isLast ? '└' : '├';
                const dates = dateRange(item.start, item.end);
                const roleUrl = item.url ?? null;
                return (
                  <div class="role-row">
                    <span class="bracket">{glyph}</span>
                    <span class="role-name">{roleUrl
                      ? <a href={roleUrl} target="_blank" rel="noopener noreferrer">{item.role}</a>
                      : item.role}</span>
                    {dates && <span class="role-dates">{dates}</span>}
                  </div>
                );
              })}
            </div>
          ))}
        </div>
      </>
    )}

    {awards.length > 0 && (
      <>
        <h2>Awards & Honors</h2>
        <ul class="involvement-list">
          {awards.map(award => (
            <li class="award-row">
              <span class="inv-name">{award.url
                ? <a href={award.url} target="_blank" rel="noopener noreferrer">{award.name}</a>
                : award.name}</span>
              <span class="role-dates">{formatDate(award.date)}</span>
            </li>
          ))}
        </ul>
      </>
    )}

    {conferences.length > 0 && (
      <>
        <h2>Conferences</h2>
        <ul class="involvement-list">
          {conferences.map(conf => (
            <li class="award-row">
              <span class="inv-name">{conf.url
                ? <a href={conf.url} target="_blank" rel="noopener noreferrer">{conf.name}</a>
                : conf.name}</span>
              <span class="role-dates">{formatDate(conf.date)}</span>
            </li>
          ))}
        </ul>
      </>
    )}

    {involvements.length > 0 && (
      <>
        <h2>Involvements</h2>
        <ul class="involvement-list">
          {involvements.map(inv => (
            <li>
              <span class="inv-name">{inv.url
                ? <a href={inv.url} target="_blank" rel="noopener noreferrer">{inv.name}</a>
                : inv.name}</span>
              {inv.role && <span class="inv-role"> &mdash; {inv.role}</span>}
            </li>
          ))}
        </ul>
      </>
    )}
  </section>

  <script type="application/json" id="tl-data" set:html={JSON.stringify(items)}></script>
  <script type="application/json" id="tl-cfg" set:html={JSON.stringify(cfg)}></script>
</BaseLayout>

<!-- Page-only: width + globally-styled JS-created bars. Width rules are gated on
     the timeline view being the active one, so the list view keeps the default
     (narrower) page width. -->
<style is:global>
  /* Keep the width transition on `main` at all times (the switcher is always
     present) so the page animates smoothly when SHRINKING to the list view too —
     not just when growing back to the timeline. Slow, ease-in-out for a gentle
     expand/retract. */
  main:has(.view-switch) { transition: max-width 0.55s cubic-bezier(0.4, 0, 0.2, 1); }
  main:has(.view-timeline.active) { max-width: 1080px; }
  /* Drawer-open width = closed content (1040) + drawer (360) + main padding (40).
     Because this width and the drawer's flex-basis share the same transition,
     the timeline's own width stays constant while the drawer slides in. */
  main:has(.view-timeline.active .tl-detail.open) { max-width: 1440px; }
  /* Always reserve the page scrollbar gutter so widths don't jump on scroll. */
  html:has(.view-timeline.active) { scrollbar-gutter: stable; }

  /* Pre-hydration: the inline script at the top of the page sets these on <html>
     from the URL hash BEFORE the view markup is parsed, so a reload on the list
     view shows the list immediately — no timeline flash, no shrink replay. All
     rules are gated on `.view-init`, which the view script removes once the
     correct view has painted; normal class/[hidden] control + the width
     transition then take over. */
  html.view-init main { transition: none !important; }
  html.view-init[data-initial-view='list'] main:has(.view-timeline.active) { max-width: var(--max-width); }
