  .d-subtitle { font-size: 0.88rem; color: var(--text); margin: -0.4rem 0 0.8rem; line-height: 1.45; }
  .d-dot { width: 9px; height: 9px; border-radius: 2px; display: inline-block; flex-shrink: 0; }
  .d-desc { font-size: 0.9rem; margin-bottom: 0.9rem; line-height: 1.6; }
  .d-links { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
  .d-links a { font-size: 0.82rem; padding: 0.25rem 0.6rem; border: 1px solid var(--border); border-radius: 4px; text-decoration: none; color: var(--accent); }
  .d-links a:hover { border-color: var(--accent); }
  .d-related-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin: 0.25rem 0 0.6rem; }
  .d-timeline { list-style: none; margin: 0; padding: 0; position: relative; }
