  .d-links a:hover { border-color: var(--accent); }
  .d-related-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin: 0.25rem 0 0.6rem; }
  .d-timeline { list-style: none; margin: 0; padding: 0; position: relative; }
