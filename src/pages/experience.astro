<script>
  const dataEl = document.getElementById('tl-data');
  const cfgEl = document.getElementById('tl-cfg');
  if (dataEl && cfgEl) {
    interface Item {
      id: number; title: string; type: string; start: number; end: number | null;
      startMonthNum: number; endMonthNum: number | null; dateLabel: string;
      description: string | null; subtitle: string | null; links: { label: string; url: string }[];
      entity: string; entityShort: string; group: string; affiliations: string[]; relationGroups: string[];
      main: boolean; cats: string[]; laneKey?: string | null;
    }
    const items: Item[] = JSON.parse(dataEl.textContent || '[]');
    const cfg = JSON.parse(cfgEl.textContent || '{}');
    const byId: Record<number, Item> = {};
    for (const it of items) byId[it.id] = it;
    // Lane chains: every bar of a multi-bar entity is kept on ONE timeline lane
    // (see layout()), so an org's roles read as a single continuous progression —
    // e.g. the Discrete-Math TA ladder (Undergraduate → Senior → Head) all at
    // "College of Computing" sits on one lane instead of stair-stepping onto
    // separate lanes when consecutive roles abut. This also subsumes the carved
    // "Member" chains (member segments + the specific roles they yield to), which
    // are always multi-bar by construction. A single-bar entity stays unkeyed so
    // it can still share a lane with unrelated bars (compact packing). Tag chained
    // items with their org as `laneKey`.
    const entityBarCount: Record<string, number> = {};
    for (const it of items) entityBarCount[it.entity] = (entityBarCount[it.entity] ?? 0) + 1;
    for (const it of items) it.laneKey = entityBarCount[it.entity] > 1 ? it.entity : null;
    const colorOf: Record<string, string> = {};
    const labelOf: Record<string, string> = {};
    for (const c of cfg.categories) { colorOf[c.key] = c.color; labelOf[c.key] = c.label; }
    const order: Record<string, number> = cfg.typeOrder;
    // Present items fill THROUGH the current month, so their exclusive end column
    // is the first of next month (absolute month index, matching item.*MonthNum).
    const nd = new Date();
    const nowMonthNum = nd.getFullYear() * 12 + nd.getMonth() + 1;

    // Row membership uses absolute month indices (timezone-independent integers),
    // NOT the baked-at-build `start`/`end` ms timestamps. Those instants are computed
    // in the BUILD machine's timezone, but the year boundary below is recomputed in
    // the VIEWER's timezone at runtime. When the two differ (e.g. CI builds in UTC,
    // viewer in EST) a Jan-starting item's start instant lands just before the year
    // boundary, so an ms compare wrongly put it as a far-right sliver in the prior
    // year. Month indices match what pct() uses, keeping membership and position in
    // lockstep. A year spans months [base, base+12); an item spans [start, end).
    const activeIn = (it: Item, y: number) => {
      const base = y * 12;
      return it.startMonthNum < base + 12 && (it.endMonthNum ?? nowMonthNum) > base;
    };
    // Bars snap to whole-month columns: a role present any day of a month fills that
    // whole column. Positions come from absolute month indices (not day-fractions),
    // so every edge lands exactly on a column boundary. `y` is the row's year.
    function pct(it: Item, y: number) {
      const base = y * 12;                                   // month index of this row's January
      const col = (m: number) => Math.max(0, Math.min(12, m - base)) / 12 * 100;
      return { sp: col(it.startMonthNum), ep: col(it.endMonthNum ?? nowMonthNum) };
    }

    // `drawer` is the INFO TAB (the sliding detail panel); `drawerBody` is its
    // scrollable contents. See the .tl-detail CSS for the sticky/scroll setup.
    const drawer = document.querySelector<HTMLElement>('.view-timeline .tl-detail')!;
    const drawerBody = document.querySelector<HTMLElement>('.view-timeline .tl-detail-body')!;
    const rows = Array.from(document.querySelectorAll<HTMLElement>('.tl-row'));

    // --- selection state ---
    let selectedId: number | null = null;
    let selectedGroup: string | null = null;
    let selectedEntity: string | null = null;
    let selectedTitle: string | null = null;
    let selectedGroups: string[] = [];

    function inForeground(it: Item): boolean {
      if (selectedGroup === null) return true;
      if (it.group === selectedGroup) return true;
      // projects tagged (via affiliations) to the selected organisation stay lit
      if (it.type === 'projects' && selectedEntity && it.affiliations.includes(selectedEntity)) return true;
      // shared relation-group tags (many-to-many, matched live on selection)
      if (selectedGroups.length && it.relationGroups.some(g => selectedGroups.includes(g))) return true;
      return false;
    }
    function applySelection() {
      const sel = selectedGroup !== null;
      for (const bar of Array.from(document.querySelectorAll<HTMLElement>('.tl-bar'))) {
        const it = byId[parseInt(bar.dataset.id!)];
        if (!it) continue;
        const fg = inForeground(it);
        // primary = the same role (same org + same title), incl. its continuations
        // across years; related = anything else still lit (other roles at the same
        // org, tagged projects); the rest is dimmed.
        const primary = sel && it.group === selectedGroup && it.title === selectedTitle;
        bar.classList.toggle('dim', sel && !fg);
        bar.classList.toggle('sel-primary', primary);
        bar.classList.toggle('sel-related', sel && fg && !primary);
      }
    }

    function buildDrawer(it: Item) {
      drawerBody.innerHTML = '';
      const h = document.createElement('h2'); h.className = 'd-title'; h.textContent = it.title;
      const meta = document.createElement('div'); meta.className = 'd-meta';
      const dot = document.createElement('span'); dot.className = 'd-dot'; dot.style.background = colorOf[it.type];
      const mt = document.createElement('span'); mt.textContent = `${labelOf[it.type] || it.type} · ${it.dateLabel}`;
      meta.appendChild(dot); meta.appendChild(mt);
      drawerBody.appendChild(h); drawerBody.appendChild(meta);

      if (it.subtitle) {
        const sub = document.createElement('div'); sub.className = 'd-subtitle'; sub.textContent = it.subtitle;
        drawerBody.appendChild(sub);
      }
      if (it.description) {
        const p = document.createElement('p'); p.className = 'd-desc'; p.textContent = it.description;
        drawerBody.appendChild(p);
      }
      if (it.links.length) {
        const wrap = document.createElement('div'); wrap.className = 'd-links';
        for (const l of it.links) {
          const a = document.createElement('a'); a.href = l.url; a.target = '_blank'; a.rel = 'noopener noreferrer';
          a.textContent = l.label; wrap.appendChild(a);
        }
        drawerBody.appendChild(wrap);
      }
      // Everything highlighted alongside this item (same organisation, tagged
      // projects, shared relation-groups), shown as a compact vertical timeline
      // (newest first). A role
      // may be several bars — its own carved continuations, or just a multi-year
      // span — so collapse by (group + title): drop the clicked item's own role
      // and keep only the newest bar of every other role.
      const roleKey = (x: Item) => x.group + ' ' + x.title;
      const seenRoles = new Set<string>([roleKey(it)]);
      const related = items
        .filter(x => x.id !== it.id && inForeground(x))
        .sort((a, b) => {
          const ka = a.end ?? Number.MAX_SAFE_INTEGER, kb = b.end ?? Number.MAX_SAFE_INTEGER;
          return kb - ka || b.start - a.start;
        })
        .filter(x => { const k = roleKey(x); if (seenRoles.has(k)) return false; seenRoles.add(k); return true; });
      if (related.length) {
        const lab = document.createElement('div'); lab.className = 'd-related-label'; lab.textContent = 'Related';
        const ul = document.createElement('ul'); ul.className = 'd-timeline';
        for (const r of related) {
          const li = document.createElement('li'); li.className = 'd-tl-item';
          const dot = document.createElement('span'); dot.className = 'd-tl-dot'; dot.style.background = colorOf[r.type];
          const btn = document.createElement('button'); btn.className = 'd-tl-link';
          btn.addEventListener('click', () => selectItem(r, { scroll: true }));
          const t = document.createElement('span'); t.className = 'd-tl-title';
          t.textContent = r.entityShort && r.entityShort !== r.title ? `${r.title} · ${r.entityShort}` : r.title;
          const d = document.createElement('span'); d.className = 'd-tl-date'; d.textContent = r.dateLabel;
          btn.appendChild(t); btn.appendChild(d);
          if (r.description) {
            const desc = document.createElement('span'); desc.className = 'd-tl-desc'; desc.textContent = r.description;
            btn.appendChild(desc);
          }
          li.appendChild(dot); li.appendChild(btn);
          ul.appendChild(li);
        }
        drawerBody.appendChild(lab); drawerBody.appendChild(ul);
      }
    }

    // Open / close the INFO TAB (the sliding detail panel).
    function openDrawer(it: Item) { buildDrawer(it); drawer.classList.add('open'); drawer.setAttribute('aria-hidden', 'false'); }
    function closeDrawer() { drawer.classList.remove('open'); drawer.setAttribute('aria-hidden', 'true'); }

    // Bring a freshly-selected item's bar into view (used when jumping to a
    // related item from the info tab). An item can span several year rows — one
    // bar per year — so we target the occurrence CLOSEST to where you're already
    // looking. If that occurrence is already comfortably on-screen we only nudge
    // a little in its direction (a directional hint); otherwise we scroll it to
    // a comfortable spot in the viewport. Vertical only — years run down the
    // page, and the header isn't sticky so the whole viewport height is usable.
    function scrollToItem(it: Item) {
      const bars = Array.from(document.querySelectorAll<HTMLElement>('.tl-bar'))
        .filter(b => b.dataset.id === String(it.id) && b.offsetParent !== null);
      if (!bars.length) return;  // filtered out / not rendered → nothing to scroll to
      const vh = window.innerHeight;
      const vCenter = vh / 2;
      // Pick the occurrence whose centre is nearest the viewport centre, i.e.
      // the closest one / the one needing the least scrolling.
      let rect: DOMRect | null = null, bestDist = Infinity;
      for (const bar of bars) {
        const r = bar.getBoundingClientRect();
        const dist = Math.abs(r.top + r.height / 2 - vCenter);
        if (dist < bestDist) { bestDist = dist; rect = r; }
      }
      if (!rect) return;
      const center = rect.top + rect.height / 2;
      const margin = vh * 0.12;  // comfort padding kept clear at top & bottom
      const inView = rect.top >= margin && rect.bottom <= vh - margin;
      let delta: number;
      if (inView) {
        // already visible → gentle nudge toward it (capped), scaled by how far
        // off-centre it sits; a bar already near the centre barely moves.
        const dir = center < vCenter ? -1 : 1;
        delta = dir * Math.min(Math.abs(center - vCenter) * 0.35, 80);
      } else {
        // off-screen or clipped → scroll its centre to ~40% down the viewport.
        delta = center - vh * 0.4;
      }
      if (Math.abs(delta) < 1) return;
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.scrollBy({ top: delta, left: 0, behavior: reduce ? 'auto' : 'smooth' });
    }

    function selectItem(it: Item, opts?: { scroll?: boolean }) {
      if (selectedId === it.id) { deselect(); return; }
      selectedId = it.id; selectedGroup = it.group; selectedEntity = it.entity; selectedTitle = it.title;
      selectedGroups = it.relationGroups || [];
      applySelection();
      openDrawer(it); // every item opens the info tab — even sparse ones show title/category/related
      if (opts?.scroll) scrollToItem(it);
    }
    function deselect() {
      selectedId = selectedGroup = null; selectedEntity = selectedTitle = null;
      selectedGroups = [];
      applySelection(); closeDrawer();
    }

    function layout(filter: string) {
      let lastVisible: HTMLElement | null = null;
      for (const row of rows) {
        const body = row.querySelector('.tl-body') as HTMLElement;
        const bars = body.querySelector('.tl-bars') as HTMLElement;
        const y = parseInt(body.dataset.year!);
        let act = items.filter(it => activeIn(it, y));
        if (filter === 'main') act = act.filter(it => it.main);
        else if (filter !== 'all') act = act.filter(it => it.cats.includes(filter));
        bars.innerHTML = '';
        // (.tl-row sets display:flex, which overrides the [hidden] default, so toggle display directly)
        if (!act.length) { row.style.display = 'none'; continue; }  // skip empty years entirely
        row.style.display = ''; lastVisible = row;
        act.sort((p, q) => {
          const d = (order[p.type] ?? 5) - (order[q.type] ?? 5);
          return d !== 0 ? d : p.start - q.start;
        });
        // Lane packing. Bars sharing a `laneKey` (a carved "Member" chain — the
        // member segments plus the specific roles they yield to, all at one org)
        // are kept on a single lane and butt up with no gap, so the role changes
        // read as one continuous line. Unrelated bars keep a small gap and never
        // land on a lane another chain has claimed.
        const laneEnd: number[] = [];           // furthest-right occupied position per lane
        const laneKey: (string | null)[] = [];  // chain a lane is reserved for (or null)
        const laneOf: Record<number, number> = {};
        for (const it of act) {
          const { sp, ep } = pct(it, y);
          const key = it.laneKey ?? null;
          let c = -1;
          // 1) same-chain bars prefer the lane their chain already holds (zero gap)
          if (key) for (let i = 0; i < laneEnd.length; i++) {
            if (laneKey[i] === key && laneEnd[i] <= sp + 0.5) { c = i; break; }
          }
          // 2) otherwise the first lane that fits and isn't claimed by another chain
          if (c === -1) for (let i = 0; i < laneEnd.length; i++) {
            if (laneEnd[i] <= sp + 0.5 && (laneKey[i] === null || laneKey[i] === key)) { c = i; break; }
          }
          if (c === -1) { c = laneEnd.length; laneEnd.push(0); laneKey.push(null); }
          laneEnd[c] = ep + (key ? 0 : 1); // no padding within a chain → bars touch
          laneKey[c] = key;                // a chain claims its lane; null leaves it open
          laneOf[it.id] = c;
        }
        const b = Math.max(...act.map(it => laneOf[it.id])) + 1;
        body.style.height = Math.max(36 * b + 12, 60) + 'px';
        for (const it of act) {
          const { sp, ep } = pct(it, y);
          const lane = laneOf[it.id];
          const el = document.createElement('div');
          el.classList.add('tl-bar');
          el.dataset.id = String(it.id);
          el.style.left = sp + '%';
          el.style.width = `max(${Math.max(ep - sp, 2)}%, 40px)`;
          el.style.top = (36 * lane + 4) + 'px';
          el.style.height = '28px';
          el.style.borderLeftColor = colorOf[it.type] || 'var(--border)';
          // Organisation label trails the title "space permitting" as
          // "Role · Org": the org's large flex-shrink (see .o CSS) makes it
          // surrender width — and truncate — long before the title does. Prefer
          // the compact short form when the org has one, else the full name.
          // Skipped entirely when the org would just echo the title
          // (projects/awards/etc. set entity = title).
          const org = it.entityShort && it.entityShort !== it.title ? it.entityShort
            : (it.entity && it.entity !== it.title ? it.entity : '');
          el.addEventListener('click', () => selectItem(it));
          const span = document.createElement('span'); span.className = 't'; span.textContent = it.title;
          el.title = `${it.title}${org ? ', ' + org : ''} · ${it.dateLabel}`;
          el.appendChild(span);
          if (org) {
            const osp = document.createElement('span'); osp.className = 'o'; osp.textContent = org;
            el.appendChild(osp);
          }
          bars.appendChild(el);
        }
      }
      // Hide the trailing connector line on the last visible year.
      for (const row of rows) {
        const line = row.querySelector('.tl-rail-line') as HTMLElement | null;
        if (line) line.style.display = row === lastVisible ? 'none' : '';
      }
      applySelection();
    }

    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.tl-filter'));
    const chips = Array.from(document.querySelectorAll<HTMLElement>('.undated-item'));
    const bottomParaEls = Array.from(document.querySelectorAll<HTMLElement>('.undated-items'));
    const bottomGroupEls = Array.from(document.querySelectorAll<HTMLElement>('.undated'));

    // --- list-view info tab -------------------------------------------------
    // The list view gets the SAME sliding panel as the timeline, opened by
    // clicking a list row. Each row carries a `data-li` id into the
    // #tl-list-data dataset; selecting one builds the panel (reusing the .d-*
    // styles + colorOf/labelOf) and lights every related row — same entity or a
    // shared relation-group — dimming the rest, mirroring the timeline's
    // selection emphasis. `ldDeselect` is exposed (no-op until wired) so the
    // view switcher and Esc can close this tab too.
    let ldDeselect = () => {};
    const listDataEl = document.getElementById('tl-list-data');
    const listDrawer = document.querySelector<HTMLElement>('.view-list .tl-detail');
    const listDrawerBody = listDrawer?.querySelector<HTMLElement>('.tl-detail-body') ?? null;
    if (listDataEl && listDrawer && listDrawerBody) {
      interface LDetail {
        id: number; title: string; type: string; dateLabel: string | null;
        subtitle: string | null; description: string | null;
        links: { label: string; url: string }[]; entity: string;
        relationGroups: string[]; main: boolean;
      }
      const ldItems: LDetail[] = JSON.parse(listDataEl.textContent || '[]');
      const ldById: Record<number, LDetail> = {};
      for (const d of ldItems) ldById[d.id] = d;
      const ldRows = Array.from(document.querySelectorAll<HTMLElement>('.view-list [data-li]'));
      const ldRowById: Record<number, HTMLElement> = {};
      for (const row of ldRows) ldRowById[parseInt(row.dataset.li!)] = row;
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      let ldSelected: number | null = null;

      // Foreground = same organisation/entity, or a shared relation-group tag.
      const ldForeground = (d: LDetail, sel: LDetail): boolean =>
        d.entity === sel.entity ||
        (sel.relationGroups.length > 0 && d.relationGroups.some(g => sel.relationGroups.includes(g)));

      function ldApply() {
        const sel = ldSelected !== null ? ldById[ldSelected] : null;
        for (const row of ldRows) {
          const d = ldById[parseInt(row.dataset.li!)];
          if (!d) continue;
          const primary = !!sel && d.id === sel.id;
          const fg = !!sel && ldForeground(d, sel);
          row.classList.toggle('li-sel-primary', primary);
          row.classList.toggle('li-sel-related', !!sel && fg && !primary);
          row.classList.toggle('li-dim', !!sel && !fg);
        }
      }

      function ldBuild(d: LDetail) {
        listDrawerBody!.innerHTML = '';
        const h = document.createElement('h2'); h.className = 'd-title'; h.textContent = d.title;
        const meta = document.createElement('div'); meta.className = 'd-meta';
        const dot = document.createElement('span'); dot.className = 'd-dot'; dot.style.background = colorOf[d.type] || 'var(--border)';
        const mt = document.createElement('span');
        const lab = labelOf[d.type] || d.type;
        mt.textContent = d.dateLabel ? `${lab} · ${d.dateLabel}` : lab;
        meta.appendChild(dot); meta.appendChild(mt);
        listDrawerBody!.appendChild(h); listDrawerBody!.appendChild(meta);
        if (d.subtitle) { const s = document.createElement('div'); s.className = 'd-subtitle'; s.textContent = d.subtitle; listDrawerBody!.appendChild(s); }
        if (d.description) { const p = document.createElement('p'); p.className = 'd-desc'; p.textContent = d.description; listDrawerBody!.appendChild(p); }
        if (d.links.length) {
          const wrap = document.createElement('div'); wrap.className = 'd-links';
          for (const l of d.links) { const a = document.createElement('a'); a.href = l.url; a.target = '_blank'; a.rel = 'noopener noreferrer'; a.textContent = l.label; wrap.appendChild(a); }
          listDrawerBody!.appendChild(wrap);
        }
        // Related rows (same entity / shared relation-group), shown as the same
        // compact vertical timeline the bar drawer uses; kept in list order.
        const related = ldItems.filter(x => x.id !== d.id && ldForeground(x, d));
        if (related.length) {
          const rlab = document.createElement('div'); rlab.className = 'd-related-label'; rlab.textContent = 'Related';
          const ul = document.createElement('ul'); ul.className = 'd-timeline';
          for (const r of related) {
            const li = document.createElement('li'); li.className = 'd-tl-item';
            const rdot = document.createElement('span'); rdot.className = 'd-tl-dot'; rdot.style.background = colorOf[r.type] || 'var(--border)';
            const btn = document.createElement('button'); btn.className = 'd-tl-link';
            btn.addEventListener('click', () => ldSelect(r.id, { scroll: true }));
            const t = document.createElement('span'); t.className = 'd-tl-title';
            t.textContent = r.entity && r.entity !== r.title ? `${r.title} · ${r.entity}` : r.title;
            btn.appendChild(t);
            if (r.dateLabel) { const dt = document.createElement('span'); dt.className = 'd-tl-date'; dt.textContent = r.dateLabel; btn.appendChild(dt); }
            if (r.description) { const ds = document.createElement('span'); ds.className = 'd-tl-desc'; ds.textContent = r.description; btn.appendChild(ds); }
            li.appendChild(rdot); li.appendChild(btn); ul.appendChild(li);
          }
          listDrawerBody!.appendChild(rlab); listDrawerBody!.appendChild(ul);
        }
      }

      function ldOpen() { listDrawer!.classList.add('open'); listDrawer!.setAttribute('aria-hidden', 'false'); }
      function ldClose() { listDrawer!.classList.remove('open'); listDrawer!.setAttribute('aria-hidden', 'true'); }

      function ldSelect(id: number, opts?: { scroll?: boolean }) {
        if (ldSelected === id) { ldDeselect(); return; }   // clicking the open row closes it
        const d = ldById[id]; if (!d) return;
        ldSelected = id;
        ldBuild(d); ldApply(); ldOpen();
        if (opts?.scroll) ldRowById[id]?.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'center' });
      }

      ldDeselect = () => { if (ldSelected === null) return; ldSelected = null; ldApply(); ldClose(); };

      for (const row of ldRows) {
        const id = parseInt(row.dataset.li!);
        row.addEventListener('click', () => ldSelect(id));
        row.addEventListener('keydown', e => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); ldSelect(id); }
        });
      }
      listDrawer.querySelector('.tl-detail-close')?.addEventListener('click', () => ldDeselect());
    }

    // --- view switching (Timeline ⇄ Experience list) ---
    const viewButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.view-btn'));
    const timelineView = document.querySelector<HTMLElement>('.view-timeline');
    const listView = document.querySelector<HTMLElement>('.view-list');
    let currentView = 'timeline';
    let currentFilter = 'all';

    // One hash carries both bits of state: `#list` selects the list view;
    // any category key (or nothing) selects the timeline view at that filter.
    function syncHash() {
      let h = '';
      if (currentView === 'list') h = 'list';
      else if (currentFilter !== 'all') h = currentFilter;
      history.replaceState(null, '', h ? `#${h}` : location.pathname);
    }

    function setView(v: string) {
      currentView = v;
      const tlActive = v === 'timeline';
      viewButtons.forEach(b => {
        const on = b.dataset.view === v;
        b.classList.toggle('active', on);
        b.setAttribute('aria-pressed', String(on));
      });
      if (timelineView) { timelineView.hidden = !tlActive; timelineView.classList.toggle('active', tlActive); }
      if (listView) listView.hidden = tlActive;
      deselect();      // clear any timeline selection + close its info tab
      ldDeselect();    // clear any list selection + close its info tab
      syncHash();
      syncDetailTop(); // re-measure the now-visible layout for the sticky info tab
    }

    function setFilter(f: string) {
      currentFilter = f;
      // Keep the info tab open when switching filters IF the selected item still
      // belongs to the new category (it matches "all", or "main" when flagged, or
      // lists the category in its `cats`). Otherwise clear the selection and close
      // the tab — the selected bar is about to be filtered out.
      const sel = selectedId !== null ? byId[selectedId] : null;
      const keepSelection = !!sel && (f === 'all' || (f === 'main' ? sel.main : sel.cats.includes(f)));
      if (!keepSelection) {
        selectedId = selectedGroup = null; selectedEntity = selectedTitle = null; selectedGroups = []; closeDrawer();
      }
      buttons.forEach(b => b.classList.toggle('active', b.dataset.filter === f));
      chips.forEach(c => {
        c.hidden = !(f === 'all' || (f === 'main' ? c.dataset.main === 'true' : c.dataset.category === f));
      });
      // Collapse a paragraph row, then a whole bottom group (incl. its header),
      // once all of its chips are filtered out.
      bottomParaEls.forEach(p => {
        p.hidden = !Array.from(p.querySelectorAll<HTMLElement>('.undated-item')).some(c => !c.hidden);
      });
      bottomGroupEls.forEach(g => {
        g.hidden = !Array.from(g.querySelectorAll<HTMLElement>('.undated-item')).some(c => !c.hidden);
      });
      layout(f);
      syncHash();
    }

    buttons.forEach(btn => btn.addEventListener('click', () => {
      const f = btn.dataset.filter!;
      // Clicking the already-active category toggles back to "all".
      setFilter(f === currentFilter && f !== 'all' ? 'all' : f);
    }));
    viewButtons.forEach(btn => btn.addEventListener('click', () => setView(btn.dataset.view!)));
    document.querySelector('.view-timeline .tl-detail-close')?.addEventListener('click', () => deselect());
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { deselect(); ldDeselect(); } });
    // When the info tab floats as an overlay, tapping the dimmed scrim behind it
    // closes whichever panel is open (harmless no-op when nothing is selected).
    document.querySelector('.tl-scrim')?.addEventListener('click', () => { deselect(); ldDeselect(); });

    // Measure the gap above the info tab at rest — i.e. the page header (title +
    // view switch) that sits above .tl-layout — and expose it as --tl-detail-top.
    // The CSS shows that FULL gap when scrolled to the top and pins the tab at
    // HALF of it once it sticks (see the .tl-detail rule). Re-measure on resize
    // and once fonts load, since both can change the header's height.
    // Both views host a .tl-layout (timeline + list); measure whichever is on
    // screen and set the offset on <html> so BOTH info tabs inherit it (custom
    // properties cascade) — each drawer then pins correctly under the header.
    const tlLayouts = Array.from(document.querySelectorAll<HTMLElement>('.tl-layout'));
    function syncDetailTop() {
      const vis = tlLayouts.find(l => l.offsetParent !== null) ?? tlLayouts[0];
      if (!vis) return;
      const top = vis.getBoundingClientRect().top + window.scrollY;
      document.documentElement.style.setProperty('--tl-detail-top', `${Math.round(top)}px`);
    }
    syncDetailTop();
    window.addEventListener('resize', syncDetailTop);
    document.fonts?.ready.then(syncDetailTop);

    // Initial state from the hash. Always build the timeline first (so its bars
    // are ready even when the list view is shown first), then pick the view.
    const initial = location.hash.replace('#', '');
    const isFilter = buttons.some(b => b.dataset.filter === initial);
    setFilter(isFilter ? initial : 'all');
    // Mirror the pre-hydration script: phones default to the list view unless the
    // hash explicitly asks otherwise (#list, or a category filter ⇒ timeline).
    const phone = window.matchMedia('(max-width: 640px)').matches;
    const initialView = (initial === 'list' || (initial === '' && phone)) ? 'list' : 'timeline';
    setView(initialView);

    // The view above now matches what the pre-hydration CSS already painted, so
    // drop `view-init` (after a frame, to be sure the initial state has painted)
    // to re-enable the width transition for subsequent view switches.
    requestAnimationFrame(() => requestAnimationFrame(() => {
      document.documentElement.classList.remove('view-init');
    }));
  }
</script>
