---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkCard from '../components/WorkCard.astro';
import { isRouteEnabled } from '@config/site';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../utils/reading-time';
import { extraLinks, type UrlEntry, type Link as WorkLink } from '../utils/links';
import profile from '../data/profile.json';
import publications from '../data/publications.json';

if (!isRouteEnabled('works')) return Astro.rewrite('/404');

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');

// Unified ordering for EVERY tab (including the merged "Recent activity" feed):
//   1. `main`-flagged items first  2. then by start date, newest first.
// For ranges / multi-date items the START date is the sort key.
const byMainThenDate = (
  a: { main: boolean; sortDate: number },
  b: { main: boolean; sortDate: number },
) => (Number(b.main) - Number(a.main)) || (b.sortDate - a.sortDate);

const fmtMonthYear = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
const fmtFullDate = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

// Kind → experience-timeline category colour, so the feed is colour-keyed to the
// timeline (see CATEGORIES in experience.astro). Blog has no timeline category,
// so it borrows Misc by design.
const KIND_CAT: Record<'Project' | 'Publication' | 'Blog', string> = {
  Project: '#e0883c',     // timeline 'projects'
  Publication: '#a06fd6', // timeline 'research'
  Blog: '#3aa6ad',        // timeline 'misc'
};

// The "urls"/"features" listed-links formats and their label logic are shared
// by every entity — see ../utils/links (hostLabel, extraLinks, UrlEntry).

// De-dupe chips by URL (keep the first) so an explicit Live/Repo link isn't
// repeated by a `urls` entry pointing at the same place.
function dedupeLinks(links: WorkLink[]): WorkLink[] {
  const seen = new Set<string>();
  return links.filter(l => (seen.has(l.url) ? false : (seen.add(l.url), true)));
}

// Every Works item — from any category — is normalized to this one shape, so
// each tab feeds identical data into <WorkCard>. Only `kind` (Recent activity)
// toggles the featured-tag placement.
interface WorkItem {
  kind: 'Project' | 'Publication' | 'Blog';
  main: boolean;
  sortDate: number;
  title: string;
  href: string | null;
  external: boolean;
  dateLabel: string;
  description?: string;
  subtitle?: string;
  tags: string[];
  links: WorkLink[];
}

interface Publication {
  title: string;
  authors: string[];
  venue: string;
  date: string;
  url?: string | null;
  urls?: UrlEntry[];
  features?: UrlEntry[];
  tags?: string[];
  main?: boolean;
}
const pubData = publications as Publication[];

// Each category is gathered only when its route is enabled, normalized to a
// WorkItem, then sorted with the shared comparator. An empty list (disabled OR
// no items) hides its tab.
const projectItems: WorkItem[] = (isRouteEnabled('projects') ? await getCollection('projects') : [])
  .map(entry => ({
    kind: 'Project' as const,
    main: entry.data.main,
    sortDate: entry.data.startDate.valueOf(),
    title: entry.data.title,
    href: `${base}/projects/${entry.id}`,
    external: false,
    dateLabel: entry.data.endDate
      ? `${fmtMonthYear(entry.data.startDate)} – ${fmtMonthYear(entry.data.endDate)}`
      : `${fmtMonthYear(entry.data.startDate)} – Present`,
    description: entry.data.description,
    subtitle: entry.data.role,
    tags: entry.data.tags,
    links: dedupeLinks([
      ...(entry.data.url ? [{ label: 'Live', url: entry.data.url }] : []),
      ...(entry.data.repo ? [{ label: 'Repo', url: entry.data.repo }] : []),
      ...extraLinks(entry.data.urls),
      ...extraLinks(entry.data.features),
    ]),
  }))
  .sort(byMainThenDate);

const pubItems: WorkItem[] = (isRouteEnabled('publications') ? pubData : [])
  .map(pub => ({
    kind: 'Publication' as const,
    main: pub.main === true,
    sortDate: new Date(pub.date).valueOf(),
    title: pub.title,
    // The paper link is the title's href; the extra `urls`/`features` become chips.
    href: pub.url || null,
    external: true,
    dateLabel: String(pub.date),
    description: pub.authors.join(', '),
    subtitle: pub.venue,
    tags: pub.tags ?? [],
    links: dedupeLinks([...extraLinks(pub.urls), ...extraLinks(pub.features)]),
  }))
  .sort(byMainThenDate);

const postItems: WorkItem[] = (isRouteEnabled('blog') ? (await getCollection('blog')).filter(p => !p.data.draft) : [])
  .map(entry => ({
    kind: 'Blog' as const,
    main: entry.data.main,
    sortDate: entry.data.date.valueOf(),
    title: entry.data.title,
    href: `${base}/blog/${entry.id}`,
    external: false,
    dateLabel: `${fmtFullDate(entry.data.date)} · ${getReadingTime(entry.body!)}`,
    description: entry.data.description,
    tags: entry.data.tags ?? [],
    links: dedupeLinks([...extraLinks(entry.data.urls), ...extraLinks(entry.data.features)]),
  }))
  .sort(byMainThenDate);

// "Recent activity" — every enabled category merged into one feed, same sort.
const activity: WorkItem[] = [...projectItems, ...pubItems, ...postItems].sort(byMainThenDate);

// Tab order: Recent activity, Publications, Projects, Blog posts. A tab is
// listed only when it has something to show.
const tabs = [
  activity.length > 0 && { id: 'recent', label: 'Recent activity' },
  pubItems.length > 0 && { id: 'publications', label: 'Publications' },
  projectItems.length > 0 && { id: 'projects', label: 'Projects' },
  postItems.length > 0 && { id: 'blog', label: 'Blog posts' },
].filter(Boolean) as { id: string; label: string }[];

const activeId = tabs[0]?.id ?? null;
---

<BaseLayout title="Works" description={profile.pageMeta.works}>
  <h1>Works</h1>
  <p class="works-intro">{profile.pageMeta.works}</p>

  {tabs.length === 0 && <p class="empty">Nothing here yet. Check back soon.</p>}

  {tabs.length > 0 && (
    <div class="works">
      <div class="works-tablist" role="tablist" aria-label="Works categories">
        {tabs.map(t => (
          <button
            class="works-tab"
            role="tab"
            id={`tab-${t.id}`}
            data-tab={t.id}
            aria-controls={`panel-${t.id}`}
            aria-selected={t.id === activeId ? 'true' : 'false'}
            tabindex={t.id === activeId ? 0 : -1}
          >{t.label}</button>
        ))}
      </div>

      {activity.length > 0 && (
        <section class="works-panel" id="panel-recent" role="tabpanel" aria-labelledby="tab-recent" hidden={activeId !== 'recent'}>
          <h2 class="panel-heading">Recent activity</h2>
          {activity.map(item => (
            <WorkCard
              title={item.title}
              href={item.href}
              external={item.external}
              dateLabel={item.dateLabel}
              description={item.description}
              subtitle={item.subtitle}
              tags={item.tags}
              links={item.links}
              featured={item.main}
              kind={item.kind}
              kindColor={KIND_CAT[item.kind]}
            />
          ))}
        </section>
      )}

      {pubItems.length > 0 && (
        <section class="works-panel" id="panel-publications" role="tabpanel" aria-labelledby="tab-publications" hidden={activeId !== 'publications'}>
          <h2 class="panel-heading">Publications</h2>
          {pubItems.map(item => (
            <WorkCard
              title={item.title}
              href={item.href}
              external={item.external}
              dateLabel={item.dateLabel}
              description={item.description}
              subtitle={item.subtitle}
              tags={item.tags}
              links={item.links}
              featured={item.main}
            />
          ))}
        </section>
      )}

      {projectItems.length > 0 && (
        <section class="works-panel" id="panel-projects" role="tabpanel" aria-labelledby="tab-projects" hidden={activeId !== 'projects'}>
          <h2 class="panel-heading">Projects</h2>
          {projectItems.map(item => (
            <WorkCard
              title={item.title}
              href={item.href}
              external={item.external}
              dateLabel={item.dateLabel}
              description={item.description}
              subtitle={item.subtitle}
              tags={item.tags}
              links={item.links}
              featured={item.main}
            />
          ))}
        </section>
      )}

      {postItems.length > 0 && (
        <section class="works-panel" id="panel-blog" role="tabpanel" aria-labelledby="tab-blog" hidden={activeId !== 'blog'}>
          <h2 class="panel-heading">Blog posts</h2>
          {postItems.map(item => (
            <WorkCard
              title={item.title}
              href={item.href}
              external={item.external}
              dateLabel={item.dateLabel}
              description={item.description}
              subtitle={item.subtitle}
              tags={item.tags}
              links={item.links}
              featured={item.main}
            />
          ))}
        </section>
      )}
    </div>
  )}

  {/* Pick the right tab (and scroll) BEFORE the first paint. Kept is:inline and
      placed after the panels so it runs synchronously during parse — the module
      script below is deferred and only runs after paint, so leaving this to it
      would flash the default tab / jump the scroll from the top. Handles both
      the "← Back to Works" return and any /works#<tab> deep link or browser-back. */}
  <script is:inline>
    (function () {
      try {
        const root = document.querySelector('.works');
        if (!root) return;
        const tabs = Array.prototype.slice.call(root.querySelectorAll('[role="tab"]'));
        const ids = tabs.map((t) => t.dataset.tab);
        const show = (id) => {
          if (ids.indexOf(id) === -1) return false;
          tabs.forEach((t) => {
            const sel = t.dataset.tab === id;
            t.setAttribute('aria-selected', sel ? 'true' : 'false');
            t.tabIndex = sel ? 0 : -1;
          });
          root.querySelectorAll('[role="tabpanel"]').forEach((p) => {
            p.hidden = p.id !== 'panel-' + id;
          });
          return true;
        };

        // (1) Returning via a detail page's "← Back to Works" button: reopen the
        // saved tab AND restore the saved scroll. One-shot flag.
        if (sessionStorage.getItem('works:restore')) {
          sessionStorage.removeItem('works:restore');
          const saved = JSON.parse(sessionStorage.getItem('works:return') || 'null');
          sessionStorage.removeItem('works:return');
          if (saved) {
            if (saved.tab && show(saved.tab)) history.replaceState(null, '', '#' + saved.tab);
            if (typeof saved.y === 'number') {
              // The footer parses AFTER this script, so the page isn't tall enough
              // yet and scrollTo would clamp short (snapping toward the top on the
              // first frame). Reserve just enough height to land the scroll exactly,
              // then release it once the real content has fully parsed.
              const de = document.documentElement;
              const prevMinHeight = de.style.minHeight;
              de.style.minHeight = (saved.y + window.innerHeight) + 'px';
              window.scrollTo(0, saved.y);
              window.addEventListener('DOMContentLoaded', () => { de.style.minHeight = prevMinHeight; }, { once: true });
            }
            return;
          }
        }

        // (2) Deep link / redirect / browser-back to /works#<tab>: open that tab
        // up front too, so it never flashes the default tab first.
        const hash = location.hash.replace(/^#/, '');
        if (hash) show(hash);
      } catch (e) { /* corrupt state — fall back to the default view */ }
    })();
  </script>

  {/* No-JS fallback: show every panel stacked with its heading, hide the
      (non-functional) tab bar. Kept inside <noscript> via is:inline so Astro
      doesn't hoist it into <head> where it would always apply. */}
  <noscript>
    <style is:inline>
      .works-tablist { display: none !important; }
      .works-panel[hidden] { display: block !important; }
      .panel-heading { display: block !important; }
    </style>
  </noscript>
</BaseLayout>

<script>
  const works = document.querySelector<HTMLElement>('.works');
  if (works) {
    const tabs = Array.from(works.querySelectorAll<HTMLElement>('[role="tab"]'));
    const panels = Array.from(works.querySelectorAll<HTMLElement>('[role="tabpanel"]'));
    const ids = tabs.map(t => t.dataset.tab!);

    const activate = (rawId: string, setFocus = false) => {
      const id = ids.includes(rawId) ? rawId : ids[0];
      tabs.forEach(t => {
        const selected = t.dataset.tab === id;
        t.setAttribute('aria-selected', selected ? 'true' : 'false');
        t.tabIndex = selected ? 0 : -1;
        if (selected && setFocus) t.focus();
      });
      panels.forEach(p => { p.hidden = p.id !== `panel-${id}`; });
    };

    tabs.forEach(t => {
      t.addEventListener('click', () => {
        const id = t.dataset.tab!;
        activate(id);
        history.replaceState(null, '', `#${id}`);
      });
    });

    // The currently selected tab id (falls back to the first tab).
    const activeTab = () =>
      tabs.find(t => t.getAttribute('aria-selected') === 'true')?.dataset.tab ?? ids[0];

    // Clicking through to a project/blog detail page: remember which tab was
    // open and how far down the visitor had scrolled, so its "← Back to Works"
    // button can drop them right back where they were. Internal detail links
    // only — external ones (publication titles, ↗ chips) open a new tab.
    works.addEventListener('click', (event) => {
      const link = (event.target as HTMLElement).closest?.('.work-title a') as HTMLAnchorElement | null;
      if (!link || link.target === '_blank') return;
      sessionStorage.setItem('works:return', JSON.stringify({ tab: activeTab(), y: window.scrollY }));
    });

    works.querySelector('.works-tablist')!.addEventListener('keydown', (event) => {
      const e = event as KeyboardEvent;
      const current = (document.activeElement as HTMLElement | null)?.dataset?.tab;
      const i = current ? ids.indexOf(current) : -1;
      if (i === -1) return;
      let n = i;
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') n = (i + 1) % ids.length;
      else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') n = (i - 1 + ids.length) % ids.length;
      else if (e.key === 'Home') n = 0;
      else if (e.key === 'End') n = ids.length - 1;
      else return;
      e.preventDefault();
      activate(ids[n], true);
      history.replaceState(null, '', `#${ids[n]}`);
    });

    // Honor deep links (e.g. /works#projects, redirected from /projects) and
    // back/forward navigation between tabs.
    window.addEventListener('hashchange', () => {
      const id = location.hash.replace(/^#/, '');
      if (ids.includes(id)) activate(id);
    });
    const initial = location.hash.replace(/^#/, '');
    if (ids.includes(initial)) activate(initial);

    // NOTE: restoring the tab + scroll when returning from a detail page is done
    // by the separate is:inline script above — it runs synchronously before the
    // first paint, whereas this module script is deferred and loads *after* it
    // (which would make the restored scroll visibly jump from the top).
  }
</script>

<style>
  .works-intro {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .empty {
    color: var(--text-muted);
  }

  /* ── Tab bar ───────────────────────────────────────────────────────────── */
  .works-tablist {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }

  .works-tab {
    background: none;
    border: none;
    font: inherit;
    font-size: 0.9rem;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0 0 0.5rem;
    margin-bottom: -1px;
    border-bottom: 2px solid transparent;
  }

  .works-tab:hover {
    color: var(--accent);
  }

  .works-tab[aria-selected="true"] {
    color: var(--text);
    border-bottom-color: var(--accent);
  }

  /* In JS mode the tab IS the heading, so the in-panel heading is hidden.
     The <noscript> block above re-shows it when scripting is off. */
  .panel-heading {
    display: none;
  }

  .works-panel[hidden] {
    display: none;
  }
</style>
