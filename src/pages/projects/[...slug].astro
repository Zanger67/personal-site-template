---
import { getCollection, render } from 'astro:content';
import ProjectPost from '../../layouts/ProjectPost.astro';
import { isRouteEnabled } from '@config/site';
import { getRelatedWorks, relatedGroupSuffix } from '../../utils/works';

export async function getStaticPaths() {
  // When the projects route is disabled, build no detail pages at all.
  if (!isRouteEnabled('projects')) return [];
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

// "Related" list (bottom of the page): other works sharing a relation-group or
// affiliation. The header mirrors the timeline drawer's "Related (…)".
const related = await getRelatedWorks({
  key: `Project:${project.id}`,
  relationGroups: project.data.relationGroups,
  affiliations: project.data.affiliations,
});
const relatedLabel = 'Related' + relatedGroupSuffix(project.data.relationGroups);
---

<ProjectPost
  title={project.data.title}
  description={project.data.description}
  role={project.data.role}
  affiliations={project.data.affiliations}
  collaborators={project.data.collaborators}
  contributions={project.data.contributions}
  startDate={project.data.startDate}
  endDate={project.data.endDate}
  tags={project.data.tags}
  url={project.data.url}
  repo={project.data.repo}
  template={project.data.template}
  sample={project.data.sample}
  urls={project.data.urls}
  features={project.data.features}
  metrics={project.data.metrics}
  related={related}
  relatedLabel={relatedLabel}
>
  <Content />
</ProjectPost>
