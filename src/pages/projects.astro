---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

function projectSortKey(p: { data: { endDate?: Date; startDate: Date } }): number {
  return (p.data.endDate ?? p.data.startDate).valueOf();
}
const allProjects = (await getCollection('projects'))
  .sort((a, b) => projectSortKey(b) - projectSortKey(a));

const pinned = allProjects.filter(p => p.data.pinned);
const rest = allProjects.filter(p => !p.data.pinned);
---

<BaseLayout title="Projects — Buzz" description="Selected projects and campus initiatives.">
  <h1>Projects</h1>
  <p style="color: var(--text-muted); margin-bottom: 1.5rem;">
    Selected projects and campus initiatives.
  </p>

  {pinned.length > 0 && (
    <section>
      <h2 class="section-label">Pinned</h2>
      {pinned.map(project => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          startDate={project.data.startDate}
          endDate={project.data.endDate}
          url={project.data.url || project.data.repo}
          tags={project.data.tags}
        />
      ))}
    </section>
  )}

  {rest.length > 0 && (
    <section>
      {pinned.length > 0 && <h2 class="section-label">All</h2>}
      {rest.map(project => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          startDate={project.data.startDate}
          endDate={project.data.endDate}
          url={project.data.url || project.data.repo}
          tags={project.data.tags}
        />
      ))}
    </section>
  )}
</BaseLayout>

<style>
  .section-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-top: 1.5rem;
    margin-bottom: 0.25rem;
  }

  section:first-of-type .section-label {
    margin-top: 0;
  }
</style>
