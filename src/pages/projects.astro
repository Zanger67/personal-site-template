---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

type ProjectEntry = { data: { endDate?: Date; startDate: Date } };
function projectSort(a: ProjectEntry, b: ProjectEntry): number {
  // Present (no endDate) items first
  if (!a.data.endDate && b.data.endDate) return -1;
  if (a.data.endDate && !b.data.endDate) return 1;
  // By endDate descending
  const endDiff = (b.data.endDate?.valueOf() ?? 0) - (a.data.endDate?.valueOf() ?? 0);
  if (endDiff !== 0) return endDiff;
  // Tiebreak by startDate descending
  return b.data.startDate.valueOf() - a.data.startDate.valueOf();
}
const allProjects = (await getCollection('projects')).sort(projectSort);

const pinned = allProjects.filter(p => p.data.pinned);
const rest = allProjects.filter(p => !p.data.pinned);
---

<BaseLayout title="Projects — Buzz" description="Selected projects and campus initiatives.">
  <h1>Projects</h1>
  <p style="color: var(--text-muted); margin-bottom: 1.5rem;">
    Selected projects and campus initiatives.
  </p>

  {pinned.length > 0 && (
    <section>
      <h2 class="section-label">Pinned</h2>
      {pinned.map(project => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          startDate={project.data.startDate}
          endDate={project.data.endDate}
          url={project.data.url || project.data.repo}
          tags={project.data.tags}
        />
      ))}
    </section>
  )}

  {rest.length > 0 && (
    <section>
      {pinned.length > 0 && <h2 class="section-label">All</h2>}
      {rest.map(project => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          startDate={project.data.startDate}
          endDate={project.data.endDate}
          url={project.data.url || project.data.repo}
          tags={project.data.tags}
        />
      ))}
    </section>
  )}
</BaseLayout>

<style>
  .section-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-top: 1.5rem;
    margin-bottom: 0.25rem;
  }

  section:first-of-type .section-label {
    margin-top: 0;
  }
</style>
