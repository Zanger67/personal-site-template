---
// The map paths are ~160KB. Rather than server-render them into every page's
// HTML (which buried later content and bloated the document), this component
// renders only the chrome + an aspect-ratio-reserved canvas, then lazily
// client-renders the interactive SVG on scroll-into-view: the heavy path data
// is dynamic-imported (a separate, cached code-split chunk) and handed to
// buildMapSvg() (src/utils/mapSvg.ts). Same component on / and /map.
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['map-container', className]} data-map>
  <div class="map-header">
    <span class="map-prompt">$</span> cat places.map --visited
  </div>
  <div class="map-body">
    <div class="map-tooltip" id="map-tooltip" aria-live="polite">
      <span class="tooltip-abbr" id="tooltip-abbr"></span>
      <span class="tooltip-name" id="tooltip-name"></span>
    </div>
    <div class="map-canvas" data-map-canvas>
      <noscript><p class="map-noscript">The interactive map needs JavaScript.</p></noscript>
    </div>
  </div>
  <div class="map-legend">
    <span class="legend-item">
      <span class="legend-swatch visited"></span> visited
    </span>
    <span class="legend-item">
      <span class="legend-swatch"></span> not yet
    </span>
    <span class="legend-item">
      <svg class="legend-icon" viewBox="0 0 10 10" width="10" height="10">
        <polygon points="5,1 6.2,3.8 9,3.8 6.9,5.5 7.6,8.5 5,6.5 2.4,8.5 3.1,5.5 1,3.8 3.8,3.8" fill="var(--accent)" />
      </svg>
      current
    </span>
    <span class="legend-item">
      <span class="legend-square"></span> hometown
    </span>
    <span class="legend-item">
      <span class="legend-dot"></span> past
    </span>
  </div>
</div>

<style>
  .map-container {
    --map-land: #e4e7e5;
    --map-visited: #c2dbc5;
    --map-water: #f7f9fb;
    --map-border: #b8c2b9;
    --map-hover: #5a8f62;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg);
  }

  :global(html[data-theme="dark"]) .map-container {
    --map-land: var(--bg-alt);
    --map-visited: var(--accent-light);
    --map-water: var(--bg);
    --map-border: var(--border);
    --map-hover: var(--accent);
  }

  .map-header {
    font-family: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
    font-size: 0.8rem;
    color: var(--text-muted);
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-alt);
  }

  .map-prompt {
    color: var(--accent);
    font-weight: 600;
  }

  .map-body {
    position: relative;
    padding: 0.5rem;
  }

  /* Reserve the map's aspect ratio (viewBox 561x351) so the lazily injected
     SVG doesn't cause layout shift. */
  .map-canvas {
    width: 100%;
    aspect-ratio: 561 / 351;
  }

  .map-canvas :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }

  /* The map data is fetched lazily, so the SVG lands a beat after first paint.
     Fade it in mirroring the page-enter fade — same duration, easing, and
     subtle rise — so it eases in rather than popping; it simply starts whenever
     the chunk arrives (a slight lag behind the page fade is fine). The fixed
     duration also floors the speed, so it never appears instantly. Applied to
     the injected SVG (not the canvas) so the <noscript> note stays visible with
     JS off, and skipped under reduced-motion. Fade-OUT on navigation is already
     handled by the page-leave transition (the map lives inside <main>). */
  @media (prefers-reduced-motion: no-preference) {
    .map-canvas :global(svg) {
      opacity: 0;
      transform: translateY(10px);
      transition:
        opacity var(--page-enter-duration, 0.36s) cubic-bezier(0.22, 1, 0.36, 1),
        transform var(--page-enter-duration, 0.36s) cubic-bezier(0.22, 1, 0.36, 1);
    }

    .map-canvas.map-loaded :global(svg) {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .map-noscript {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-align: center;
    padding: 2rem 0;
    margin: 0;
  }

  .map-tooltip {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-family: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
    text-align: right;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
    z-index: 1;
  }

  .map-tooltip.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .tooltip-abbr {
    display: block;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.2;
  }

  .tooltip-name {
    display: block;
    font-size: 0.7rem;
    color: var(--text-muted);
    line-height: 1.3;
  }

  /* Map-element styles target the client-injected SVG, so they are scoped to
     the (server-rendered) container and made :global for its injected children.
     The --map-* custom properties above cascade in from .map-container. */
  .map-container :global(.region) {
    fill: var(--map-land);
    stroke: var(--map-border);
    stroke-width: 0.8;
    stroke-dasharray: 3 2;
    cursor: pointer;
    transition: fill 0.15s ease, stroke 0.15s ease;
  }

  .map-container :global(.lake) {
    fill: var(--map-water);
    stroke: var(--map-border);
    stroke-width: 0.4;
    stroke-dasharray: 1.5 1.5;
    pointer-events: none;
  }

  .map-container :global(.region.visited) {
    fill: var(--map-visited);
  }

  .map-container :global(.region:hover),
  .map-container :global(.region.hovered) {
    fill: var(--map-hover);
    fill-opacity: 0.35;
    stroke: var(--map-hover);
    stroke-width: 0.8;
    stroke-dasharray: none;
  }

  .map-container :global(.hi-inset-regions .region) {
    stroke-width: 0.22;
    stroke-dasharray: 0.8 0.6;
  }

  .map-container :global(.hi-inset-regions .region:hover) {
    stroke-width: 0.3;
  }

  .map-container :global(.dc-inset-regions .region) {
    stroke-width: 0.03;
    stroke-dasharray: 0.12 0.1;
  }

  .map-container :global(.dc-inset-regions .region:hover) {
    stroke-width: 0.05;
  }

  .map-container :global(.dc-leader) {
    stroke: var(--border);
    stroke-width: 0.5;
    stroke-dasharray: 2 2;
  }

  .map-container :global(.region.visited:hover),
  .map-container :global(.region.visited.hovered) {
    fill: var(--map-hover);
    fill-opacity: 0.35;
  }

  .map-container :global(.inset-border) {
    fill: var(--map-water);
    stroke: var(--map-border);
    stroke-width: 0.5;
    stroke-dasharray: 2 2;
  }

  .map-container :global(.inset-label) {
    font-family: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
    font-size: 7px;
    fill: var(--text-muted);
    opacity: 0.6;
  }

  .map-container :global(.city-dot),
  .map-container :global(.city-star),
  .map-container :global(.city-square) {
    fill: var(--accent);
  }

  .map-container :global(.city-line) {
    stroke: var(--text-muted);
    stroke-width: 0.5;
    stroke-dasharray: 2 1;
  }

  .map-container :global(.city-label) {
    font-family: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
    font-size: 8px;
    fill: var(--text-muted);
  }

  .map-legend {
    display: flex;
    gap: 1.25rem;
    padding: 0.5rem 0.75rem;
    border-top: 1px solid var(--border);
    font-family: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .legend-icon {
    flex-shrink: 0;
  }

  .legend-swatch {
    display: inline-block;
    width: 12px;
    height: 12px;
    border: 1px dashed var(--map-border);
    border-radius: 2px;
    background: var(--map-land);
  }

  .legend-swatch.visited {
    background: var(--map-visited);
    border-style: solid;
    border-color: var(--accent);
  }

  .legend-square {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 1px;
  }

  .legend-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  @media (max-width: 480px) {
    .map-container :global(.city-label),
    .map-container :global(.city-line) {
      display: none;
    }

    .map-tooltip {
      font-size: 0.85rem;
    }
  }
</style>

<script>
  import { buildMapSvg } from '../utils/mapSvg';

  function initInteractivity(container: Element, svg: SVGSVGElement) {
    const tooltip = container.querySelector<HTMLElement>('.map-tooltip');
    const tooltipAbbr = container.querySelector<HTMLElement>('.tooltip-abbr');
    const tooltipName = container.querySelector<HTMLElement>('.tooltip-name');
    if (!tooltip || !tooltipAbbr || !tooltipName) return;

    let currentRegionId: string | null = null;

    // Shared region borders are drawn twice (once by each neighbour). On hover only
    // the hovered path switches to a solid stroke, but SVG paints in DOM order with no
    // z-index, so a neighbour that comes later in the document re-covers the shared edge
    // with its dashed stroke. Raise the hovered path(s) to the end of their group so the
    // solid stroke always paints last; remember their original slot to restore on leave.
    let raisedRegions: { el: Element; parent: Node; next: Node | null }[] = [];

    function restoreRaised() {
      // Undo in reverse so each insertBefore reference is still valid.
      for (let i = raisedRegions.length - 1; i >= 0; i--) {
        const { el, parent, next } = raisedRegions[i];
        parent.insertBefore(el, next);
      }
      raisedRegions = [];
    }

    function showTooltip(region: Element) {
      const regionId = region.getAttribute('data-region');
      if (regionId === currentRegionId) return;

      if (currentRegionId) {
        svg.querySelectorAll(`.region[data-region="${currentRegionId}"]`).forEach((el) => {
          el.classList.remove('hovered');
        });
      }
      restoreRaised();

      currentRegionId = regionId;
      tooltipAbbr!.textContent = region.getAttribute('data-abbr') || '';
      tooltipName!.textContent = region.getAttribute('data-name') || '';

      tooltip!.classList.remove('visible');
      void tooltip!.offsetWidth;
      tooltip!.classList.add('visible');

      if (regionId) {
        svg.querySelectorAll(`.region[data-region="${regionId}"]`).forEach((el) => {
          el.classList.add('hovered');
          const parent = el.parentNode;
          if (parent) {
            raisedRegions.push({ el, parent, next: el.nextSibling });
            parent.appendChild(el);
          }
        });
      }
    }

    function hideTooltip() {
      if (currentRegionId) {
        svg.querySelectorAll(`.region[data-region="${currentRegionId}"]`).forEach((el) => {
          el.classList.remove('hovered');
        });
        currentRegionId = null;
      }
      restoreRaised();
      tooltip!.classList.remove('visible');
    }

    svg.addEventListener('mouseover', (e) => {
      const region = (e.target as Element).closest('.region');
      if (region) showTooltip(region);
      else hideTooltip();
    });

    svg.addEventListener('mouseleave', () => hideTooltip());

    // Click to toggle visited — sync all paths for the same region
    svg.addEventListener('click', (e) => {
      const region = (e.target as Element).closest('.region');
      if (!region) return;
      const regionId = region.getAttribute('data-region');
      if (!regionId) return;
      const isVisited = !region.classList.contains('visited');
      svg.querySelectorAll(`.region[data-region="${regionId}"]`).forEach((el) => {
        el.classList.toggle('visited', isVisited);
      });
    });

    // Touch support
    svg.addEventListener(
      'touchstart',
      (e) => {
        const region = (e.target as Element).closest('.region');
        if (region) {
          e.preventDefault();
          showTooltip(region);
        } else {
          hideTooltip();
        }
      },
      { passive: false },
    );
  }

  function mountMap(container: Element) {
    const canvas = container.querySelector('[data-map-canvas]');
    if (!canvas || canvas.getAttribute('data-mounted')) return;
    canvas.setAttribute('data-mounted', '1');

    Promise.all([import('../data/map-paths'), import('../data/map-config.json')])
      .then(([paths, cfg]) => {
        canvas.innerHTML = buildMapSvg(paths as any, (cfg as any).default);
        const svg = canvas.querySelector('svg');
        if (svg) initInteractivity(container, svg as unknown as SVGSVGElement);
        // Fade the freshly injected SVG in on the next frame (mirrors page-enter).
        requestAnimationFrame(() => canvas.classList.add('map-loaded'));
      })
      .catch(() => {
        canvas.removeAttribute('data-mounted');
      });
  }

  document.querySelectorAll('.map-container[data-map]').forEach((container) => {
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              obs.disconnect();
              mountMap(container);
            }
          });
        },
        { rootMargin: '300px' },
      );
      io.observe(container);
    } else {
      mountMap(container);
    }
  });
</script>
