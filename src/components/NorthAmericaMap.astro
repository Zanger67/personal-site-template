---
import { regions, alaskaInset, alaskaSimple, hawaiiInset, greatLakes, dcAreaHiRes } from '../data/map-paths';
import mapConfig from '../data/map-config.json';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const visitedSet = new Set(mapConfig.visited);
const activeSet = new Set(mapConfig.activeCities);
const continentalRegions = [...regions.filter(r => r.id !== 'US-HI' && r.id !== 'US-AK'), alaskaSimple];
const activeCities = mapConfig.cities.filter(c => activeSet.has(c.id));
// Use high-res 10m data for DC inset instead of the 50m continental paths
---

<div class:list={['map-container', className]}>
  <div class="map-header">
    <span class="map-prompt">$</span> cat places.map --visited
  </div>
  <div class="map-body">
    <div class="map-tooltip" id="map-tooltip" aria-live="polite">
      <span class="tooltip-abbr" id="tooltip-abbr"></span>
      <span class="tooltip-name" id="tooltip-name"></span>
    </div>
    <svg
      viewBox="372 222 561 351"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="Map of visited places in North America"
    >
      <g class="regions">
        {continentalRegions.map((r) => (
          <path
            id={r.id}
            d={r.d}
            fill-rule={r.fillRule || undefined}
            class:list={['region', { visited: visitedSet.has(r.id) }]}
            data-abbr={r.abbr}
            data-name={r.name}
            data-region={r.id}
          />
        ))}
      </g>

      <g class="lakes">
        {greatLakes.map((lake) => (
          <path
            d={lake.d}
            fill-rule={lake.fillRule || undefined}
            class="lake"
          />
        ))}
      </g>

      {/* Alaska inset — bottom-left */}
      <g class="inset-group">
        <rect x="383" y="497" width="88" height="66" class="inset-border" rx="2" />
        <text x="387" y="507" class="inset-label">AK</text>
        <g transform="translate(383, 497) scale(0.73)">
          <path
            id={alaskaInset.id}
            d={alaskaInset.d}
            fill-rule={alaskaInset.fillRule || undefined}
            class:list={['region', { visited: visitedSet.has(alaskaInset.id) }]}
            data-abbr={alaskaInset.abbr}
            data-name={alaskaInset.name}
            data-region={alaskaInset.id}
          />
        </g>
      </g>

      {/* Hawaii inset — next to Alaska */}
      <g class="inset-group">
        <rect x="475" y="521" width="65" height="42" class="inset-border" rx="2" />
        <text x="479" y="531" class="inset-label">HI</text>
        <g class="hi-inset-regions" transform="translate(361, 460) scale(2.8)">
          <path
            id={hawaiiInset.id}
            d={hawaiiInset.d}
            fill-rule={hawaiiInset.fillRule || undefined}
            class:list={['region', { visited: visitedSet.has(hawaiiInset.id) }]}
            data-abbr={hawaiiInset.abbr}
            data-name={hawaiiInset.name}
            data-region={hawaiiInset.id}
          />
        </g>
      </g>

      {/* DC area inset — bottom-right */}
      <g class="inset-group">
        <defs>
          <clipPath id="dc-clip">
            <rect x="858" y="502" width="72" height="60" />
          </clipPath>
        </defs>
        <rect x="858" y="502" width="72" height="60" class="inset-border" rx="2" />
        <g clip-path="url(#dc-clip)">
          <g class="dc-inset-regions" transform="translate(-15911, -8730) scale(21)">
            {dcAreaHiRes.map((r) => (
              <path
                d={r.d}
                fill-rule={r.fillRule || undefined}
                class:list={['region', { visited: visitedSet.has(r.id) }]}
                data-abbr={r.abbr}
                data-name={r.name}
                data-region={r.id}
              />
            ))}
          </g>
        </g>
        <text x="862" y="512" class="inset-label">DC</text>
        {/* Leader lines from DC on main map to inset */}
        <line x1="800" y1="441" x2="858" y2="510" class="dc-leader" />
        <line x1="800" y1="441" x2="858" y2="540" class="dc-leader" />
      </g>

      <g class="cities">
        {activeCities.map((city) => (
          <g class="city-marker">
            <line
              x1={city.x}
              y1={city.y}
              x2={city.x + city.labelOffset.dx}
              y2={city.y + city.labelOffset.dy}
              class="city-line"
            />
            {city.type === 'current' ? (
              <polygon
                points={`${city.x},${city.y - 3.5} ${city.x + 1.2},${city.y - 1.2} ${city.x + 3.5},${city.y - 1.2} ${city.x + 1.7},${city.y + 0.5} ${city.x + 2.3},${city.y + 3.5} ${city.x},${city.y + 1.5} ${city.x - 2.3},${city.y + 3.5} ${city.x - 1.7},${city.y + 0.5} ${city.x - 3.5},${city.y - 1.2} ${city.x - 1.2},${city.y - 1.2}`}
                class="city-star"
              />
            ) : city.type === 'hometown' ? (
              <rect
                x={city.x - 2.5}
                y={city.y - 2.5}
                width="5"
                height="5"
                class="city-square"
              />
            ) : (
              <circle cx={city.x} cy={city.y} r="2.5" class="city-dot" />
            )}
            <text
              x={city.x + city.labelOffset.dx + (city.labelAnchor === 'start' ? 3 : -3)}
              y={city.y + city.labelOffset.dy}
              text-anchor={city.labelAnchor}
              class="city-label"
            >
              {city.label}
            </text>
          </g>
        ))}
      </g>
    </svg>
  </div>
  <div class="map-legend">
    <span class="legend-item">
      <span class="legend-swatch visited"></span> visited
    </span>
    <span class="legend-item">
      <span class="legend-swatch"></span> not yet
    </span>
    <span class="legend-item">
      <svg class="legend-icon" viewBox="0 0 10 10" width="10" height="10">
        <polygon points="5,1 6.2,3.8 9,3.8 6.9,5.5 7.6,8.5 5,6.5 2.4,8.5 3.1,5.5 1,3.8 3.8,3.8" fill="var(--accent)" />
      </svg>
      current
    </span>
    <span class="legend-item">
      <span class="legend-square"></span> hometown
    </span>
    <span class="legend-item">
      <span class="legend-dot"></span> past
    </span>
  </div>
</div>

<style>
  .map-container {
    --map-land: #e4e7e5;
    --map-visited: #c2dbc5;
    --map-water: #f7f9fb;
    --map-border: #b8c2b9;
    --map-hover: #5a8f62;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg);
  }

  :global(html[data-theme="dark"]) .map-container {
    --map-land: var(--bg-alt);
    --map-visited: var(--accent-light);
    --map-water: var(--bg);
    --map-border: var(--border);
    --map-hover: var(--accent);
  }

  .map-header {
    font-family: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
    font-size: 0.8rem;
    color: var(--text-muted);
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-alt);
  }

  .map-prompt {
    color: var(--accent);
    font-weight: 600;
  }

  .map-body {
    position: relative;
    padding: 0.5rem;
  }

  .map-tooltip {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-family: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
    text-align: right;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
    z-index: 1;
  }

  .map-tooltip.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .tooltip-abbr {
    display: block;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.2;
  }

  .tooltip-name {
    display: block;
    font-size: 0.7rem;
    color: var(--text-muted);
    line-height: 1.3;
  }

  svg:not(.legend-icon) {
    display: block;
    width: 100%;
    height: auto;
  }

  .region {
    fill: var(--map-land);
    stroke: var(--map-border);
    stroke-width: 0.8;
    stroke-dasharray: 3 2;
    cursor: pointer;
    transition: fill 0.15s ease, stroke 0.15s ease;
  }

  .lake {
    fill: var(--map-water);
    stroke: var(--map-border);
    stroke-width: 0.4;
    stroke-dasharray: 1.5 1.5;
    pointer-events: none;
  }

  .region.visited {
    fill: var(--map-visited);
  }

  .region:hover,
  .region.hovered {
    fill: var(--map-hover);
    fill-opacity: 0.35;
    stroke: var(--map-hover);
    stroke-width: 0.8;
    stroke-dasharray: none;
  }

  .hi-inset-regions .region {
    stroke-width: 0.22;
    stroke-dasharray: 0.8 0.6;
  }

  .hi-inset-regions .region:hover {
    stroke-width: 0.3;
  }

  .dc-inset-regions .region {
    stroke-width: 0.03;
    stroke-dasharray: 0.12 0.1;
  }

  .dc-inset-regions .region:hover {
    stroke-width: 0.05;
  }

  .dc-leader {
    stroke: var(--border);
    stroke-width: 0.5;
    stroke-dasharray: 2 2;
  }

  .region.visited:hover,
  .region.visited.hovered {
    fill: var(--map-hover);
    fill-opacity: 0.35;
  }

  .inset-border {
    fill: var(--map-water);
    stroke: var(--map-border);
    stroke-width: 0.5;
    stroke-dasharray: 2 2;
  }

  .inset-label {
    font-family: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
    font-size: 7px;
    fill: var(--text-muted);
    opacity: 0.6;
  }


  .city-dot {
    fill: var(--accent);
  }

  .city-star {
    fill: var(--accent);
  }

  .city-square {
    fill: var(--accent);
  }

  .city-line {
    stroke: var(--text-muted);
    stroke-width: 0.5;
    stroke-dasharray: 2 1;
  }

  .city-label {
    font-family: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
    font-size: 8px;
    fill: var(--text-muted);
  }

  .map-legend {
    display: flex;
    gap: 1.25rem;
    padding: 0.5rem 0.75rem;
    border-top: 1px solid var(--border);
    font-family: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .legend-icon {
    flex-shrink: 0;
  }

  .legend-swatch {
    display: inline-block;
    width: 12px;
    height: 12px;
    border: 1px dashed var(--map-border);
    border-radius: 2px;
    background: var(--map-land);
  }

  .legend-swatch.visited {
    background: var(--map-visited);
    border-style: solid;
    border-color: var(--accent);
  }

  .legend-square {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 1px;
  }

  .legend-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  @media (max-width: 480px) {
    .city-label,
    .city-line {
      display: none;
    }

    .map-tooltip {
      font-size: 0.85rem;
    }
  }
</style>

<script>
  const STORAGE_KEY = 'map-visited';

  const container = document.querySelector('.map-container');
  const svg = container?.querySelector('svg');
  const tooltip = document.getElementById('map-tooltip');
  const tooltipAbbr = document.getElementById('tooltip-abbr');
  const tooltipName = document.getElementById('tooltip-name');

  if (svg && tooltip && tooltipAbbr && tooltipName) {
    let currentRegion: Element | null = null;

    let currentRegionId: string | null = null;

    function showTooltip(region: Element) {
      const regionId = region.getAttribute('data-region');
      if (regionId === currentRegionId) return;

      // Clear previous hover
      if (currentRegionId) {
        svg!.querySelectorAll(`.region[data-region="${currentRegionId}"]`).forEach(el => {
          el.classList.remove('hovered');
        });
      }

      currentRegionId = regionId;
      tooltipAbbr.textContent = region.getAttribute('data-abbr') || '';
      tooltipName.textContent = region.getAttribute('data-name') || '';

      tooltip.classList.remove('visible');
      void tooltip.offsetWidth;
      tooltip.classList.add('visible');

      // Highlight all matching paths
      if (regionId) {
        svg!.querySelectorAll(`.region[data-region="${regionId}"]`).forEach(el => {
          el.classList.add('hovered');
        });
      }
    }

    function hideTooltip() {
      if (currentRegionId) {
        svg!.querySelectorAll(`.region[data-region="${currentRegionId}"]`).forEach(el => {
          el.classList.remove('hovered');
        });
        currentRegionId = null;
      }
      tooltip.classList.remove('visible');
    }

    svg.addEventListener('mouseover', (e) => {
      const region = (e.target as Element).closest('.region');
      if (region) {
        showTooltip(region);
      } else {
        hideTooltip();
      }
    });

    svg.addEventListener('mouseleave', () => {
      hideTooltip();
    });

    // Click to toggle visited — sync all paths for the same region
    svg.addEventListener('click', (e) => {
      const region = (e.target as Element).closest('.region');
      if (!region) return;
      const regionId = region.getAttribute('data-region');
      if (!regionId) return;
      const isVisited = !region.classList.contains('visited');
      svg.querySelectorAll(`.region[data-region="${regionId}"]`).forEach(el => {
        el.classList.toggle('visited', isVisited);
      });
    });

    // Touch support
    svg.addEventListener('touchstart', (e) => {
      const region = (e.target as Element).closest('.region');
      if (region) {
        e.preventDefault();
        showTooltip(region);
      } else {
        hideTooltip();
      }
    }, { passive: false });
  }
</script>
