---
import { navRoutes } from '@config/site';
import profile from '../data/profile.json';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const withBase = (href: string) => `${base}${href}`;

// Nav links are derived from the visibility config (src/config/site.ts);
// disabled routes are dropped automatically.
const navLinks = navRoutes('main').map(r => ({ id: r.id, href: withBase(r.href), label: r.label }));
const miscLinks = navRoutes('misc').map(r => ({ id: r.id, href: withBase(r.href), label: r.label }));

// When the bar is too narrow to fit everything it collapses to a dropdown that
// keeps Home (the title) and Contact visible. Everything else moves into the
// menu: the main links other than Home/Contact, followed by every misc link.
const contactLink = navLinks.find(l => l.id === 'contact');
const collapsedLinks = [
  ...navLinks.filter(l => l.id !== 'home' && l.id !== 'contact'),
  ...miscLinks,
];

const currentPath = Astro.url.pathname;

const stripTrailing = (p: string) => p.replace(/\/+$/, '') || '/';
const homeHref = stripTrailing(`${base}/`);
const current = stripTrailing(currentPath);

// The home link should only be active on the home page itself. Every other
// link is active on its own page and any nested route beneath it.
const isActive = (href: string) => {
  const target = stripTrailing(href);
  if (target === homeHref) return current === target;
  return current === target || current.startsWith(`${target}/`);
};
---

<header class="site-header">
  <nav>
    <a href={`${base}/`} class="site-title">{profile.name}</a>
    <div class="nav-right">
      <ul class="desktop-nav">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[{ active: isActive(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li class="misc-dropdown">
          <button class="misc-toggle" aria-expanded="false">Misc</button>
          <div class="misc-menu">
            <ul>
              {miscLinks.map(link => (
                <li>
                  <a
                    href={link.href}
                    class:list={[{ active: isActive(link.href) }]}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </li>
      </ul>

      {contactLink && (
        <a
          href={contactLink.href}
          class:list={['contact-quick', { active: isActive(contactLink.href) }]}
        >
          {contactLink.label}
        </a>
      )}

      <button class="nav-toggle" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

      <button id="theme-toggle" aria-label="Toggle dark mode">
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>

    <div class="mobile-menu" id="mobile-menu">
      <ul>
        {collapsedLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[{ active: isActive(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('theme-toggle')!;

  toggle.addEventListener('click', () => {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    if (isDark) {
      document.documentElement.removeAttribute('data-theme');
      localStorage.setItem('theme', 'light');
    } else {
      document.documentElement.setAttribute('data-theme', 'dark');
      localStorage.setItem('theme', 'dark');
    }
  });

  // Collapsed-nav dropdown (shown only at narrow widths via CSS).
  const navToggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  if (navToggle && mobileMenu) {
    const closeMenu = () => {
      navToggle.setAttribute('aria-expanded', 'false');
      mobileMenu.classList.remove('open');
    };

    navToggle.addEventListener('click', (event) => {
      event.stopPropagation();
      const isOpen = navToggle.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        closeMenu();
      } else {
        navToggle.setAttribute('aria-expanded', 'true');
        mobileMenu.classList.add('open');
      }
    });

    // Close when clicking outside the menu, on Escape, or when the viewport
    // grows back to a width that shows the full bar again.
    document.addEventListener('click', (event) => {
      const target = event.target as Node;
      if (!mobileMenu.contains(target) && !navToggle.contains(target)) {
        closeMenu();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMenu();
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth > 768) closeMenu();
    });
  }
</script>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  nav {
    max-width: 1012px;
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-title {
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--text);
    text-decoration: none;
  }

  .site-title:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  ul {
    display: flex;
    list-style: none;
    gap: 1.25rem;
    padding: 0;
    margin: 0;
  }

  li a {
    font-size: 0.9rem;
    color: var(--text-muted);
    text-decoration: none;
    padding-bottom: 2px;
  }

  li a:hover,
  li a.active {
    color: var(--accent);
    border-bottom: 1.5px solid var(--accent);
  }

  #theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 0.25rem;
    display: flex;
    align-items: center;
  }

  #theme-toggle:hover {
    color: var(--accent);
  }

  .icon-sun { display: none; }
  .icon-moon { display: block; }

  :global(html[data-theme="dark"]) .icon-sun { display: block; }
  :global(html[data-theme="dark"]) .icon-moon { display: none; }

  .misc-dropdown {
    position: relative;
  }

  .misc-toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
    color: var(--text-muted);
    padding: 0;
    padding-bottom: 2px;
    font-family: inherit;
  }

  .misc-toggle:hover {
    color: var(--accent);
    border-bottom: 1.5px solid var(--accent);
  }

  .misc-menu {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    padding-top: 0.4rem;
    z-index: 10;
  }

  .misc-dropdown:hover .misc-menu {
    display: block;
  }

  .misc-menu ul {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.15rem 0;
    padding-left: 0;
    margin: 0;
    min-width: 120px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    list-style: none;
    display: block;
    gap: 0;
  }

  .misc-menu li {
    margin: 0;
    padding: 0;
  }

  .misc-menu li a {
    display: block;
    padding: 0.15rem 0.75rem;
    font-size: 0.85rem;
    white-space: nowrap;
    border-bottom: none;
  }

  .misc-menu li a:hover {
    background: var(--bg-alt);
    border-bottom: none;
  }

  /* Collapsed-nav pieces: hidden on wide screens, revealed below the
     breakpoint where the full bar no longer fits. */
  .contact-quick {
    display: none;
    font-size: 0.9rem;
    color: var(--text-muted);
    text-decoration: none;
    padding-bottom: 2px;
  }

  .contact-quick:hover,
  .contact-quick.active {
    color: var(--accent);
    border-bottom: 1.5px solid var(--accent);
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 0.25rem;
    align-items: center;
  }

  .nav-toggle:hover {
    color: var(--accent);
  }

  .nav-toggle .icon-close { display: none; }
  .nav-toggle[aria-expanded="true"] .icon-open { display: none; }
  .nav-toggle[aria-expanded="true"] .icon-close { display: block; }

  .mobile-menu {
    display: none;
    position: absolute;
    top: 100%;
    right: 1.25rem;
    margin-top: 0.4rem;
    z-index: 10;
  }

  .mobile-menu ul {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.3rem 0;
    margin: 0;
    min-width: 180px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    list-style: none;
    display: block;
    gap: 0;
  }

  .mobile-menu li {
    margin: 0;
    padding: 0;
  }

  .mobile-menu li a {
    display: block;
    padding: 0.35rem 0.9rem;
    font-size: 0.9rem;
    white-space: nowrap;
    border-bottom: none;
  }

  .mobile-menu li a:hover,
  .mobile-menu li a.active {
    background: var(--bg-alt);
    border-bottom: none;
  }

  @media (max-width: 768px) {
    .desktop-nav { display: none; }
    .contact-quick { display: inline-flex; }
    .nav-toggle { display: inline-flex; }
    .mobile-menu.open { display: block; }
  }
</style>
