---
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const navLinks = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/projects`, label: 'Projects' },
  { href: `${base}/publications`, label: 'Publications' },
  { href: `${base}/experience`, label: 'Experience' },
  { href: `${base}/blog`, label: 'Blog' },
  { href: `${base}/contact`, label: 'Contact' },
];

const miscLinks = [
  { href: `${base}/map`, label: 'Map' },
  { href: `${base}/fun-facts`, label: 'Fun Facts' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <nav>
    <a href={`${base}/`} class="site-title">Buzz</a>
    <div class="nav-right">
      <ul>
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[{ active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li class="misc-dropdown">
          <button class="misc-toggle" aria-expanded="false">Misc</button>
          <ul class="misc-menu">
            {miscLinks.map(link => (
              <li>
                <a
                  href={link.href}
                  class:list={[{ active: currentPath === link.href || currentPath.startsWith(link.href) }]}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </li>
      </ul>
      <button id="theme-toggle" aria-label="Toggle dark mode">
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('theme-toggle')!;

  toggle.addEventListener('click', () => {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    if (isDark) {
      document.documentElement.removeAttribute('data-theme');
      localStorage.setItem('theme', 'light');
    } else {
      document.documentElement.setAttribute('data-theme', 'dark');
      localStorage.setItem('theme', 'dark');
    }
  });

</script>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
  }

  nav {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-title {
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--text);
    text-decoration: none;
  }

  .site-title:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  ul {
    display: flex;
    list-style: none;
    gap: 1.25rem;
    padding: 0;
    margin: 0;
  }

  li a {
    font-size: 0.9rem;
    color: var(--text-muted);
    text-decoration: none;
    padding-bottom: 2px;
  }

  li a:hover,
  li a.active {
    color: var(--accent);
    border-bottom: 1.5px solid var(--accent);
  }

  #theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 0.25rem;
    display: flex;
    align-items: center;
  }

  #theme-toggle:hover {
    color: var(--accent);
  }

  .icon-sun { display: none; }
  .icon-moon { display: block; }

  :global(html[data-theme="dark"]) .icon-sun { display: block; }
  :global(html[data-theme="dark"]) .icon-moon { display: none; }

  .misc-dropdown {
    position: relative;
  }

  .misc-toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
    color: var(--text-muted);
    padding: 0;
    padding-bottom: 2px;
    font-family: inherit;
  }

  .misc-toggle:hover {
    color: var(--accent);
    border-bottom: 1.5px solid var(--accent);
  }

  .misc-menu {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.4rem 0;
    min-width: 120px;
    flex-direction: column;
    gap: 0;
    z-index: 10;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .misc-dropdown:hover .misc-menu {
    display: flex;
  }

  .misc-menu li {
    list-style: none;
  }

  .misc-menu li a {
    display: block;
    padding: 0.35rem 0.75rem;
    font-size: 0.85rem;
    white-space: nowrap;
    border-bottom: none;
  }

  .misc-menu li a:hover {
    background: var(--bg-alt);
    border-bottom: none;
  }
</style>
