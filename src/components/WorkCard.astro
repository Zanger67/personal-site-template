---
// The single, standardized card used by every tab of the Works page
// (Recent activity, Publications, Projects, Blog). One layout so the header
// font/size/style, the date, the tags row, and the Live/Repo/link chips are
// identical everywhere — a tab only differs in the data it feeds in.
//
// Featured placement:
//   • Recent activity passes `kind` ("Project"/"Publication"/"Blog"), so the
//     "★ Featured" tag rides the top type-row alongside the kind label.
//   • Every other tab omits `kind`, so "★ Featured" sits in the header row
//     next to the title (the tab itself already says what the item is).
import Metrics from './Metrics.astro';
import { normalizeMetrics, type Metrics as MetricsDict } from '../utils/metrics';

interface WorkLink {
  label: string;
  url: string;
}

// One credited name on a card (publications). Pre-resolved by the caller so this
// component stays a dumb renderer: `href` already points wherever the name should
// go (a /collaborators dropdown, or the person's own site when `external`), and
// `marks` carries the item's contributor-level symbols + legend text.
interface AuthorChip {
  name: string;
  href?: string | null;
  external?: boolean;
  /** Me — rendered bold and never linked. */
  self?: boolean;
  marks?: { symbol: string; note: string | null }[];
}

interface Props {
  title: string;
  /** Title link. Internal URLs are already base-prefixed; external ones open in a new tab. */
  href?: string | null;
  /** Open `href` in a new tab (external links). */
  external?: boolean;
  /** Date range / date / date + reading-time — rendered at the end of the header row. */
  dateLabel?: string | null;
  /** Muted blurb under the header (description / authors). */
  description?: string | null;
  /** Optional italic line between header and description (e.g. a publication venue). */
  subtitle?: string | null;
  /** Credited names (publications) — rendered as their own line, each linked. */
  authors?: AuthorChip[];
  /** Affiliated orgs/labs — rendered as distinct outlined chips before the tags. */
  affiliations?: string[];
  tags?: string[];
  /** Generic stat chips (Repo Stars, Citations, …) — rendered on their own row. */
  metrics?: MetricsDict | null;
  /** Live / Repo / extra links — rendered as chips; simply omitted when empty. */
  links?: WorkLink[];
  /** `main`-flagged highlight — shows a "★ Featured" tag. */
  featured?: boolean;
  /** Recent-activity type label ("Project"/"Publication"/"Blog"). Omit on single-type tabs. */
  kind?: string | null;
  /** Colour for the kind swatch (experience-timeline category colour). */
  kindColor?: string | null;
}

const {
  title,
  href = null,
  external = false,
  dateLabel = null,
  description = null,
  subtitle = null,
  authors = [],
  affiliations = [],
  tags = [],
  metrics = null,
  links = [],
  featured = false,
  kind = null,
  kindColor = null,
} = Astro.props;

const extAttrs = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
const hasMetrics = normalizeMetrics(metrics).length > 0;
---

<article class="work-card">
  {kind && (
    <div class="work-typerow">
      <span class="work-kind" style={kindColor ? `--cat: ${kindColor}` : undefined}>{kind}</span>
      {featured && <span class="featured-tag" title="Featured — flagged as a highlight">★ Featured</span>}
    </div>
  )}

  <div class="work-header">
    <div class="work-title-wrap">
      <h3 class="work-title">
        {href
          ? <a href={href} {...extAttrs}>{title}</a>
          : title}
      </h3>
      {!kind && featured && <span class="featured-tag" title="Featured — flagged as a highlight">★ Featured</span>}
    </div>
    {dateLabel && <span class="work-date">{dateLabel}</span>}
  </div>

  {subtitle && <p class="work-subtitle">{subtitle}</p>}
  {authors.length > 0 && (
    <p class="work-authors">
      {authors.map((a, i) => (
        <Fragment>
          {i > 0 && ', '}
          {a.self
            ? <strong class="me">{a.name}</strong>
            : a.href
              ? <a href={a.href} {...(a.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>{a.name}</a>
              : <span>{a.name}</span>}
          {(a.marks ?? []).map(m => (
            <sup class="cmark" title={m.note} data-tip={m.note}>{m.symbol}</sup>
          ))}
        </Fragment>
      ))}
    </p>
  )}
  {description && <p class="work-desc">{description}</p>}

  {/* Four independent groups (affiliations · tags · metrics · links). Base render
      is one wrapping row; the client script below measures each card's own content
      and, only on overflow, progressively splits it across two lines — see the
      <script> and the `.work-metarow` styles for the staged cascade. */}
  {(affiliations.length > 0 || tags.length > 0 || links.length > 0 || hasMetrics) && (
    <div class="work-metarow" data-stage="0">
      {affiliations.length > 0 && (
        <div class="mr-group mr-affil">
          {affiliations.map(a => <span class="affil-chip" title={`Affiliated with ${a}`}>{a}</span>)}
        </div>
      )}
      {tags.length > 0 && (
        <div class="mr-group mr-tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
      <Metrics metrics={metrics} class="mr-group mr-metrics" />
      {links.length > 0 && (
        <div class="mr-group mr-links ext-links">
          {links.map(l => (
            <a href={l.url} target="_blank" rel="noopener noreferrer">{l.label} ↗</a>
          ))}
        </div>
      )}
    </div>
  )}
</article>

{/* Progressive-collapse for each card's meta row. Faithful to a *content*-overflow
    cascade (not fixed width breakpoints) so each card reacts to its OWN content:
      stage 0   A T M L              everything on one line
      stage 1   A / T M L            affiliations drop to their own line
      stage 2   A M / T L            metrics move up beside the affiliations
      stage 3   A M / T…(wrap) L     tags wrap; links tie to the bottom tag row
    Hoisted + deduped by Astro, so this one script drives every card on the page.
    With JS off, the base CSS leaves it as a single wrapping row. */}
<script>
  interface Groups {
    affil: HTMLElement | null;
    tags: HTMLElement | null;
    metrics: HTMLElement | null;
    links: HTMLElement | null;
  }

  const px = (v: string) => {
    const n = parseFloat(v);
    return Number.isFinite(n) ? n : 0;
  };

  // Natural single-line width of a chip group = Σ child widths + inner column-gaps.
  // Chip widths don't depend on wrapping, so this is stable wherever the group
  // currently sits (line 1, line 2, or already wrapped across rows).
  const naturalWidth = (g: HTMLElement | null): number => {
    if (!g) return 0;
    const kids = Array.from(g.children) as HTMLElement[];
    if (!kids.length) return 0;
    const gap = px(getComputedStyle(g).columnGap);
    let w = 0;
    for (const k of kids) w += k.getBoundingClientRect().width;
    return w + gap * (kids.length - 1);
  };

  const setup = (row: HTMLElement) => {
    const groups: Groups = {
      affil: row.querySelector<HTMLElement>('.mr-affil'),
      tags: row.querySelector<HTMLElement>('.mr-tags'),
      metrics: row.querySelector<HTMLElement>('.mr-metrics'),
      links: row.querySelector<HTMLElement>('.mr-links'),
    };

    // Two persistent line wrappers the groups get shuffled between per stage.
    const line1 = document.createElement('div');
    const line2 = document.createElement('div');
    line1.className = 'mr-line';
    line2.className = 'mr-line';

    // Do a set of groups fit on ONE line of width `W` (with the between-group
    // gap)? Absent / empty groups are ignored.
    const fits = (ws: number[], W: number, gap: number) => {
      const p = ws.filter(x => x > 0);
      if (!p.length) return true;
      return p.reduce((s, x) => s + x, 0) + gap * (p.length - 1) <= W + 1;
    };

    // Move the given (present) groups, in order, into a line wrapper.
    const fill = (line: HTMLElement, gs: (HTMLElement | null)[]) => {
      for (const g of gs) if (g) line.appendChild(g);
    };

    let current = -1;

    const layout = () => {
      const W = row.clientWidth;
      if (!W) return; // hidden tab panel — re-runs via ResizeObserver when shown.
      const gap = px(getComputedStyle(row).columnGap);
      const A = naturalWidth(groups.affil);
      const T = naturalWidth(groups.tags);
      const M = naturalWidth(groups.metrics);
      const L = naturalWidth(groups.links);

      let stage: number;
      if (fits([A, T, M, L], W, gap)) stage = 0;
      else if (A > 0 && fits([T, M, L], W, gap)) stage = 1;
      else if (fits([T, L], W, gap)) stage = 2;
      else stage = 3;

      if (stage === current) return; // no change — avoid needless reflow / RO churn.
      current = stage;
      row.dataset.stage = String(stage);

      line1.textContent = '';
      line2.textContent = '';
      if (stage === 0) {
        fill(line1, [groups.affil, groups.tags, groups.metrics, groups.links]);
      } else if (stage === 1) {
        fill(line1, [groups.affil]);
        fill(line2, [groups.tags, groups.metrics, groups.links]);
      } else {
        // Stages 2 & 3 share one arrangement; the stage-3 difference (tags wrap,
        // links tie to the bottom tag row) falls out of line 2's flex-wrap.
        fill(line1, [groups.affil, groups.metrics]);
        fill(line2, [groups.tags, groups.links]);
      }
      row.appendChild(line1);
      if (line2.childElementCount) row.appendChild(line2);
      else if (line2.parentNode) line2.remove();
    };

    layout();
    if ('ResizeObserver' in window) {
      let raf = 0;
      const ro = new ResizeObserver(() => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(layout);
      });
      ro.observe(row);
    } else {
      window.addEventListener('resize', layout);
    }
  };

  document.querySelectorAll<HTMLElement>('.work-metarow').forEach(setup);
</script>

<style>
  .work-card {
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .work-card:last-child {
    border-bottom: none;
  }

  /* ── Type row (Recent activity only) ───────────────────────────────────── */
  .work-typerow {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 0.35rem;
  }

  /* Colour-keyed to the experience timeline via the inline --cat variable. */
  .work-kind {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--cat, var(--text-muted));
  }

  .work-kind::before {
    content: '';
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 2px;
    background: var(--cat, var(--text-muted));
  }

  /* ── Header row: title (+ featured on single-type tabs) and date ───────── */
  .work-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .work-title-wrap {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.2rem 0.6rem;
    min-width: 0;
  }

  /* The one canonical header style, shared by every Works view. */
  .work-title {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0;
  }

  .work-title a {
    color: var(--text);
    text-decoration: none;
  }

  .work-title a:hover {
    color: var(--accent);
  }

  .work-date {
    font-size: 0.82rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* "★ Featured" — on the type row in Recent activity, in the header elsewhere. */
  .featured-tag {
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #d4a017;
    white-space: nowrap;
  }

  /* ── Body ──────────────────────────────────────────────────────────────── */
  .work-subtitle {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--text-muted);
    margin: 0.25rem 0 0;
  }

  .work-desc {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin: 0.3rem 0 0;
  }

  /* Credited names (publications) — same muted weight as the blurb it replaced,
     with each name linking to that person's collaborators dropdown. */
  .work-authors {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin: 0.3rem 0 0;
  }

  /* Me — bold, never a link. */
  .work-authors .me {
    color: var(--text);
    font-weight: 700;
  }

  .work-authors a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px dotted var(--border);
  }

  .work-authors a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* ── Meta row: affiliations · tags · metrics · links ───────────────────────
     Base state is a single wrapping flex row (this is also the no-JS fallback).
     The <script> above measures each card's own content and, only on overflow,
     reparents the groups into up to two `.mr-line` wrappers for the staged
     cascade (see the script header); `data-stage` records the current stage. */
  .work-metarow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.75rem;
    margin-top: 0.6rem;
  }

  /* JS-built line wrapper — full-width so the (up to two) lines stack. Global
     because the script creates these nodes (they carry no scoped attribute). */
  :global(.work-metarow .mr-line) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.75rem;
    flex-basis: 100%;
    min-width: 0;
  }

  .mr-affil,
  .mr-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
  }

  /* Links float to the right edge of whichever line they land on — in stage 3
     that ties them to the bottom row of the wrapped tags. */
  .mr-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  /* Neutralize the <Metrics> component's own top margin inside the row (it stands
     as its own block elsewhere — detail headers, drawer). Global + the extra
     class for specificity: the <ul> lives in Metrics' own style scope and may be
     reparented into a `.mr-line`. */
  :global(.work-metarow .mr-metrics.mr-group) {
    margin: 0;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  /* Affiliation chip — an org/lab the item is tied to. Outlined + muted (with a
     leading "@") to read as a distinct entity, not a topic tag. */
  .affil-chip {
    font-size: 0.75rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  .affil-chip::before {
    content: '@';
    margin-right: 0.15rem;
    opacity: 0.6;
  }

  .ext-links a {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .ext-links a:hover {
    color: var(--accent);
  }
</style>
