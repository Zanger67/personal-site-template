# src/dev — git-ignored scratch, archive & proofing area (see src/dev/README.md).
# Mirrors src/data & src/content; only the README and .gitkeep markers are tracked.
/src/dev/*
!/src/dev/README.md
!/src/dev/content/
!/src/dev/data/
/src/dev/content/*
!/src/dev/content/.gitkeep
/src/dev/data/*
!/src/dev/data/.gitkeep
